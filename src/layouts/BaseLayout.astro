---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  twitterCard?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  cssFiles?: string[];
  jsFiles?: string[];
  deferJsFiles?: string[];
  noIndex?: boolean;
  bodyClass?: string;
  mainClass?: string;
  mainStyle?: string;
  includeFeatures?: boolean;
  includeSmartFilter?: boolean;
  includeJobs?: boolean;
  includeStore?: boolean;
  includeFuel?: boolean;
  includeFuelComponents?: boolean;
  structuredData?: string;
  lang?: string;
}

const {
  title,
  description = '',
  canonical = '',
  ogTitle = '',
  ogDescription = '',
  ogImage = 'https://groupsmix.com/assets/img/og-default.png',
  ogUrl = '',
  ogType = 'website',
  twitterCard = 'summary_large_image',
  twitterTitle = '',
  twitterDescription = '',
  cssFiles = [],
  jsFiles = [],
  deferJsFiles = [],
  noIndex = false,
  bodyClass = '',
  mainClass = '',
  mainStyle = '',
  includeFeatures = false,
  includeSmartFilter = false,
  includeJobs = false,
  includeStore = false,
  includeFuel = false,
  includeFuelComponents = false,
  structuredData = '',
  lang = 'en',
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <!-- Observability + analytics config, then loaders. Each loader is a
         no-op when its config is absent, so /assets/js/site-config.js can
         be stamped at build time with only the values that apply to the
         current environment. -->
    <script is:inline src="/assets/js/site-config.js"></script>
    <script is:inline src="/assets/js/shared/sentry.js" defer></script>
    <script is:inline src="/assets/js/shared/plausible.js" defer></script>
    <script is:inline src="/assets/js/head-scripts.js" defer></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {ogType && <meta property="og:type" content={ogType} />}
    <meta property="og:site_name" content="GroupsMix">
    {(ogTitle || title) && <meta property="og:title" content={ogTitle || title} />}
    {(ogDescription || description) && <meta property="og:description" content={ogDescription || description} />}
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {twitterCard && <meta name="twitter:card" content={twitterCard} />}
    {(twitterTitle || ogTitle || title) && <meta name="twitter:title" content={twitterTitle || ogTitle || title} />}
    {(twitterDescription || ogDescription || description) && <meta name="twitter:description" content={twitterDescription || ogDescription || description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://hmlqppacanpxmrfdlkec.supabase.co">
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/dist/umd/supabase.min.js" as="script" crossorigin="anonymous">
    <link rel="preload" href="/assets/js/modules/icons.js" as="script">
    <link rel="preload" href="/assets/js/modules/config.js" as="script">
    <link rel="preload" href="/assets/js/modules/auth.js" as="script">
    <link rel="preload" href="/assets/js/modules/db.js" as="script">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap">
    </noscript>
    <link rel="stylesheet" href="/assets/css/shared.css">
    {cssFiles.map(f => <link rel="stylesheet" href={f} />)}
    <link rel="stylesheet" href="/assets/css/chatbot.css">
    <slot name="head" />
</head>
<body class={bodyClass || undefined}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header id="site-header"></header>
    <div id="announcement-bar"></div>
    <main id="main-content" class={mainClass || undefined} style={mainStyle || undefined}>
        <slot />
    </main>
    <footer id="site-footer"></footer>
    <div id="toast-container" class="toast-container" aria-live="polite"></div>
    <div id="modal-container"></div>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/dist/umd/supabase.min.js" crossorigin="anonymous"></script>
    <script is:inline src="/assets/js/supabase-config.js"></script>
    <!-- Core modules (no dependencies) -->
    <script is:inline src="/assets/js/shared/secure-random.js"></script>
    <script is:inline src="/assets/js/modules/icons.js"></script>
    <script is:inline src="/assets/js/modules/config.js"></script>
    <script is:inline src="/assets/js/modules/cache.js"></script>
    <!-- Security & Auth (depend on core) -->
    <script is:inline src="/assets/js/modules/security.js"></script>
    <script is:inline src="/assets/js/modules/auth.js"></script>
    <script is:inline src="/assets/js/modules/db.js"></script>
    <!-- Feature modules -->
    <script is:inline src="/assets/js/modules/theme.js"></script>
    <script is:inline src="/assets/js/modules/saved.js"></script>
    <script is:inline src="/assets/js/modules/recently-viewed.js"></script>
    <script is:inline src="/assets/js/modules/algorithms.js"></script>
    <script is:inline src="/assets/js/modules/pricing.js"></script>
    <script is:inline src="/assets/js/modules/group-health.js"></script>
    <!-- UI components (depends on core + feature modules) -->
    <script is:inline src="/assets/js/components.js"></script>
    <!-- Modules that reference UI -->
    <script is:inline src="/assets/js/modules/marketplace.js"></script>
    <script is:inline src="/assets/js/modules/interactions.js"></script>
    <script is:inline src="/assets/js/modules/comments.js"></script>
    <script is:inline src="/assets/js/modules/ui-render.js"></script>
    <script is:inline src="/assets/js/modules/settings.js"></script>
    <script is:inline src="/assets/js/modules/cookie-consent.js"></script>
    <script is:inline src="/assets/js/modules/maintenance.js"></script>
    <script is:inline src="/assets/js/modules/live-realtime.js"></script>
    <!-- Effects & global init (must be last) -->
    <script is:inline src="/assets/js/modules/ui-effects.js"></script>
    <script is:inline src="/assets/js/modules/init.js"></script>
    {includeFeatures && <script is:inline src="/assets/js/features.js"></script>}
    {includeSmartFilter && <script is:inline src="/assets/js/smart-filter.js"></script>}
    {includeJobs && <script is:inline src="/assets/js/jobs.js"></script>}
    {includeStore && <script is:inline src="/assets/js/store.js"></script>}
    {includeFuel && <script is:inline src="/assets/js/fuel-community.js"></script>}
    {includeFuelComponents && <script is:inline src="/assets/js/fuel-components.js"></script>}
    {jsFiles.map(f => <script is:inline src={f}></script>)}
    <script is:inline src="/assets/js/article-platform-features.js" defer></script>
    <script is:inline src="/assets/js/ai-features.js" defer></script>
    <script is:inline src="/assets/js/chatbot.js" defer></script>
    {deferJsFiles.map(f => <script is:inline src={f} defer></script>)}
    <slot name="scripts" />
    {structuredData && <script type="application/ld+json" set:html={structuredData} />}
</body>
</html>
