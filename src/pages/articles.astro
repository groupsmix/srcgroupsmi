---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Articles — GroupsMix"
  description="Read articles and guides about building, growing, and managing social media groups. Community-powered content platform."
  cssFiles={["/assets/css/articles.css?v=20260310b"]}
>

        <div class="articles-feed">
            <!-- Header -->
            <div class="articles-feed__header">
                <div class="articles-feed__header-left">
                    <h1 class="articles-feed__title">Articles</h1>
                </div>
                <div class="articles-feed__actions">
                    <div class="articles-search-bar__wrap">
                        <span class="articles-search-bar__icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </span>
                        <input type="text" id="articles-search" class="articles-search-bar__input" placeholder="Search articles..." autocomplete="off">
                    </div>
                    <a href="/write-article" id="btn-write-article" class="btn btn-primary btn-sm" style="display:none">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Write Article
                    </a>
                </div>
            </div>

            <!-- Tabs -->
            <div class="articles-tabs" role="tablist" aria-label="Article feeds">
                <button class="articles-tab articles-tab--active" data-tab="all" role="tab" aria-selected="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    All
                </button>
                <button class="articles-tab" data-tab="trending" role="tab" aria-selected="false">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    Trending
                </button>
                <button class="articles-tab" data-tab="following" role="tab" aria-selected="false" style="display:none" id="tab-following">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    Following
                </button>
                <button class="articles-tab" data-tab="my" role="tab" aria-selected="false" style="display:none" id="tab-my">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    My Articles
                </button>
                <a href="/reading-lists" class="articles-tab" role="tab" aria-selected="false" style="text-decoration:none">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                    Reading Lists
                </a>
            </div>

            <!-- Categories -->
            <div id="categories-bar" class="articles-categories"></div>

            <!-- AI Recommendations Banner (shown for logged in users) -->
            <div id="ai-rec-banner" class="ai-rec-banner" style="display:none">
                <div class="ai-rec-banner__header">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4c0 2 2 3 2 6H8"/><path d="M12 2a4 4 0 0 1 4 4c0 2-2 3-2 6h2"/><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/></svg>
                    Recommended for You
                </div>
                <div id="ai-rec-list" class="ai-rec-banner__list"></div>
            </div>

            <!-- Articles Grid -->
            <div id="articles-grid" class="articles-grid">
                <!-- Skeletons -->
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div><div class="article-skeleton__line article-skeleton__line--short"></div></div></div>
            </div>

            <!-- Empty State -->
            <div id="articles-empty" class="articles-empty" style="display:none">
                <div class="articles-empty__icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                </div>
                <div class="articles-empty__title">No Articles Found</div>
                <div class="articles-empty__text" id="articles-empty-text">Check back soon for new content!</div>
                <a href="/write-article" class="btn btn-primary btn-sm" id="btn-write-empty" style="display:none">Write the First Article</a>
            </div>

            <!-- Load More -->
            <div id="load-more-wrap" style="text-align:center;padding:var(--space-6);display:none">
                <button id="btn-load-more" class="btn btn-secondary">Load More Articles</button>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            ArticleFeed.init();
        });
    </script>
</Fragment>
</BaseLayout>
