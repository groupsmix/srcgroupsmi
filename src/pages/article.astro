---
---
<BaseLayout
  title="Article — GroupsMix"
  cssFiles={["/assets/css/articles.css"]}
  includeFuel={true}
  includeFuelComponents={true}
>

        <div class="article-detail" id="article-detail">
            <!-- Loading skeleton -->
            <div class="skeleton" style="height:32px;width:120px;border-radius:var(--radius-full);margin-bottom:var(--space-4)"></div>
            <div class="skeleton" style="height:48px;width:80%;margin-bottom:var(--space-4)"></div>
            <div class="skeleton" style="height:300px;border-radius:var(--radius-lg);margin-bottom:var(--space-6)"></div>
            <div class="skeleton" style="height:80px;border-radius:var(--radius-lg);margin-bottom:var(--space-6)"></div>
            <div class="skeleton" style="height:20px;width:60%;margin-bottom:var(--space-3)"></div>
            <div class="skeleton" style="height:20px;width:90%;margin-bottom:var(--space-3)"></div>
            <div class="skeleton" style="height:20px;width:75%;margin-bottom:var(--space-3)"></div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            ArticleDetail.init();
            // After article loads, init paywall and social conversion
            var checkArticle = setInterval(function() {
                if (ArticleDetail._article) {
                    clearInterval(checkArticle);
                    var article = ArticleDetail._article;
                    // Init paywall
                    if (typeof ArticlePaywall !== 'undefined') {
                        ArticlePaywall.initPaywall(article);
                    }
                    // Add social conversion button to toolbar
                    var toolbar = document.getElementById('article-toolbar');
                    if (toolbar && typeof SocialConversion !== 'undefined') {
                        toolbar.insertAdjacentHTML('beforeend', SocialConversion.renderButton());
                        SocialConversion.init(article);
                    }
                    // Track analytics view
                    if (typeof AuthorAnalytics !== 'undefined') {
                        AuthorAnalytics.trackView(article.id, 0, null);
                        // Track read completion on scroll
                        var maxScroll = 0;
                        window.addEventListener('scroll', function() {
                            var contentEl = document.querySelector('.article-detail__content');
                            if (!contentEl) return;
                            var rect = contentEl.getBoundingClientRect();
                            var total = contentEl.scrollHeight;
                            var visible = window.innerHeight - rect.top;
                            var pct = Math.min(100, Math.max(0, Math.round((visible / total) * 100)));
                            if (pct > maxScroll) {
                                maxScroll = pct;
                                if (maxScroll >= 25 && maxScroll % 25 === 0) {
                                    AuthorAnalytics.trackView(article.id, maxScroll, null);
                                }
                            }
                        }, { passive: true });
                    }
                }
            }, 300);
        });
    </script>
</Fragment>
</BaseLayout>
