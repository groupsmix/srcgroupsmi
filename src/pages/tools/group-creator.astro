---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="AI Group Creator — GroupsMix"
  description="Enter a topic and get 10 creative group names + 3 professional bios in one shot. AI-powered group identity creator."
  canonical="https://groupsmix.com/tools/group-creator"
>
<style is:inline>
        .name-container { max-width:var(--container-sm);margin:0 auto;padding:var(--space-8) var(--space-4); }
        .name-hero { text-align:center;padding:var(--space-8) var(--space-4);background:linear-gradient(135deg,rgba(245,158,11,0.12),rgba(139,92,246,0.1),transparent);border-radius:var(--radius-xl);margin-bottom:var(--space-6);border:1px solid rgba(245,158,11,0.2); }
        .name-hero__icon { font-size:56px;margin-bottom:var(--space-3);display:block; }
        .name-hero h1 { background:linear-gradient(135deg,#f59e0b,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:var(--space-2); }
        .name-form { background:var(--bg-card);border:1px solid var(--border-primary);border-radius:var(--radius-lg);padding:var(--space-5); }
        .name-form textarea { width:100%;min-height:80px;background:var(--bg-input);border:2px solid var(--border-primary);border-radius:var(--radius-md);padding:var(--space-4);color:var(--text-primary);font-size:var(--text-base);resize:vertical;transition:all 0.3s;font-family:inherit; }
        .name-form textarea::placeholder { color:var(--text-muted); }
        .name-form textarea:focus { border-color:#f59e0b;box-shadow:0 0 0 4px rgba(245,158,11,0.15);outline:none; }
        .option-grid { display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3); }
        @media(max-width:500px) { .option-grid { grid-template-columns:1fr; } }
        .custom-input-wrap { margin-top:var(--space-2);display:none; }
        .name-form select, .name-form input[type="text"] { width:100%;height:44px;padding:0 var(--space-3);background:var(--bg-input);border:2px solid var(--border-primary);border-radius:var(--radius-md);color:var(--text-primary);font-size:var(--text-sm);transition:border-color 0.3s; }
        .name-form input[type="text"]::placeholder { color:var(--text-muted); }
        .spark-btn { width:100%;height:56px;margin-top:var(--space-4);border:none;border-radius:14px;cursor:pointer;font-size:var(--text-lg);font-weight:700;color:#fff;background:linear-gradient(135deg,#f59e0b,#8B5CF6);box-shadow:0 4px 20px rgba(245,158,11,0.4);transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:var(--space-2); }
        .spark-btn:hover { transform:translateY(-2px);box-shadow:0 8px 30px rgba(245,158,11,0.5); }
        .spark-btn:disabled { opacity:0.6;cursor:not-allowed;transform:none; }

        .name-loading { display:none;text-align:center;padding:var(--space-8); }
        .name-loading__text { font-size:var(--text-base);font-weight:600;color:#fbbf24;min-height:24px; }

        .name-result { display:none;animation:slideUp 0.6s ease; }
        @keyframes slideUp { from{opacity:0;transform:translateY(30px);} to{opacity:1;transform:translateY(0);} }
        .result-section { margin-bottom:var(--space-5); }
        .result-section__title { font-size:var(--text-lg);font-weight:700;margin-bottom:var(--space-3);display:flex;align-items:center;gap:var(--space-2); }
        .name-list { display:flex;flex-direction:column;gap:var(--space-2); }
        .name-item { display:flex;align-items:center;justify-content:space-between;padding:var(--space-3) var(--space-4);background:var(--bg-tertiary);border:1px solid var(--border-primary);border-radius:var(--radius-md);transition:all 0.2s; }
        .name-item:hover { border-color:rgba(245,158,11,0.3);background:rgba(245,158,11,0.05); }
        .name-item__text { font-weight:600;font-size:var(--text-sm);color:var(--text-primary); }
        .name-item__num { width:28px;height:28px;background:rgba(245,158,11,0.15);color:#f59e0b;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:var(--text-xs);font-weight:700;flex-shrink:0;margin-right:var(--space-3); }
        .name-item__left { display:flex;align-items:center; }
        .copy-name-btn { width:32px;height:32px;border-radius:8px;border:1px solid var(--border-primary);background:var(--bg-input);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all 0.2s;flex-shrink:0; }
        .copy-name-btn:hover { background:var(--accent-primary);color:#fff;border-color:var(--accent-primary); }
        .bio-item { padding:var(--space-4);background:var(--bg-tertiary);border:1px solid var(--border-primary);border-radius:var(--radius-md);margin-bottom:var(--space-2); }
        .bio-item__text { font-size:var(--text-sm);color:var(--text-secondary);line-height:1.7;margin-bottom:var(--space-2);white-space:pre-wrap; }
        .bio-item__footer { display:flex;justify-content:flex-end; }

        .name-actions { display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap;margin-top:var(--space-5); }
    </style>


        <div class="name-container">
            <div class="name-hero">
                <span class="name-hero__icon">&#x2728;</span>
                <h1>AI Group Creator</h1>
                <p style="color:var(--text-secondary)">Enter a topic and get 10 creative names + 3 professional bios in one shot</p>
            </div>
            <div class="name-form" id="input-section">
                <label class="form-label" style="color:#fbbf24">Tell me about your group idea in simple words...</label>
                <textarea id="name-input" rows="3" placeholder="e.g. selling traditional clothes, programming lovers, jokes and memes, fitness motivation..."></textarea>
                <div class="option-grid" style="margin-top:var(--space-3)">
                    <div class="form-group">
                        <label class="form-label" style="color:#fbbf24;font-size:var(--text-sm)">Name Style</label>
                        <select id="name-style">
                            <option value="creative">Creative &amp; Unique</option>
                            <option value="professional">Professional</option>
                            <option value="fun">Fun &amp; Playful</option>
                            <option value="short">Short &amp; Punchy</option>
                            <option value="luxury">Luxury &amp; Premium</option>
                            <option value="custom">Custom (type your own)</option>
                        </select>
                        <div class="custom-input-wrap" id="custom-style-wrap">
                            <input type="text" id="custom-style" placeholder="e.g. minimalist, techy, arabic-inspired...">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" style="color:#fbbf24;font-size:var(--text-sm)">Tone</label>
                        <select id="name-tone">
                            <option value="auto">Auto (based on topic)</option>
                            <option value="formal">Formal</option>
                            <option value="casual">Casual</option>
                            <option value="humorous">Humorous</option>
                            <option value="inspirational">Inspirational</option>
                            <option value="custom">Custom (type your own)</option>
                        </select>
                        <div class="custom-input-wrap" id="custom-tone-wrap">
                            <input type="text" id="custom-tone" placeholder="e.g. mysterious, energetic, warm...">
                        </div>
                    </div>
                </div>
                <div class="form-group" style="margin-top:var(--space-3)">
                    <label class="form-label" style="color:#fbbf24;font-size:var(--text-sm)">Output Language</label>
                    <select id="lang-select" style="width:100%;height:44px;padding:0 var(--space-3);background:var(--bg-input);border:2px solid var(--border-primary);border-radius:var(--radius-md);color:var(--text-primary);font-size:var(--text-sm);cursor:pointer;transition:border-color 0.3s;">
                        <option value="en">English</option>
                        <option value="ar">العربية (Arabic)</option>
                        <option value="fr">Français (French)</option>
                        <option value="es">Español (Spanish)</option>
                        <option value="tr">Türkçe (Turkish)</option>
                        <option value="pt">Português (Portuguese)</option>
                        <option value="de">Deutsch (German)</option>
                        <option value="id">Bahasa Indonesia</option>
                        <option value="hi">हिन्दी (Hindi)</option>
                        <option value="ur">اردو (Urdu)</option>
                        <option value="zh">中文 (Chinese)</option>
                        <option value="ru">Русский (Russian)</option>
                        <option value="ja">日本語 (Japanese)</option>
                        <option value="ko">한국어 (Korean)</option>
                        <option value="it">Italiano (Italian)</option>
                        <option value="nl">Nederlands (Dutch)</option>
                        <option value="pl">Polski (Polish)</option>
                        <option value="ms">Bahasa Melayu</option>
                        <option value="th">ไทย (Thai)</option>
                        <option value="vi">Tiếng Việt (Vietnamese)</option>
                        <option value="sw">Kiswahili (Swahili)</option>
                        <option value="bn">বাংলা (Bengali)</option>
                    </select>
                </div>
                <button class="spark-btn" id="spark-btn">&#x1FA84; Spark Creativity</button>
            </div>
            <div class="name-loading" id="name-loading">
                <div style="width:60px;height:60px;margin:0 auto var(--space-4);border:4px solid rgba(245,158,11,0.2);border-top-color:#f59e0b;border-radius:50%;animation:spin 1s linear infinite;"></div>
                <div class="name-loading__text" id="name-load-text">Searching for rare words...</div>
            </div>
            <div class="name-result" id="name-result">
                <div class="result-section">
                    <div class="result-section__title">&#x1F4A1; Suggested Names (10)</div>
                    <div class="name-list" id="names-list"></div>
                </div>
                <div class="result-section">
                    <div class="result-section__title">&#x1F4DD; Professional Descriptions (3)</div>
                    <div id="bios-list"></div>
                </div>
                <div class="name-actions">
                    <button class="spark-btn" style="width:auto;padding:0 24px;height:48px;font-size:var(--text-base)" id="more-btn">&#x1F504; Give Me More</button>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    (function() {
        'use strict';
        var loadTexts = ['Searching for rare words...','Generating attention-grabbing names...','Crafting a description that elevates value...','Adding creative spark...'];

        // Rate limiting: max 5 requests per 5 minutes, 30s cooldown
        var requestLog = [];
        var RATE_COOLDOWN = 30000;
        var RATE_WINDOW = 300000;
        var RATE_MAX = 5;
        var lastRequestTime = 0;
        function checkRateLimit() {
            var now = Date.now();
            if (now - lastRequestTime < RATE_COOLDOWN) { UI.toast('Please wait ' + Math.ceil((RATE_COOLDOWN - (now - lastRequestTime)) / 1000) + ' seconds before trying again.', 'error'); return false; }
            requestLog = requestLog.filter(function(t) { return now - t < RATE_WINDOW; });
            if (requestLog.length >= RATE_MAX) { UI.toast('Too many requests. Please wait a few minutes.', 'error'); return false; }
            return true;
        }

        // Custom style/tone toggle
        document.getElementById('name-style').addEventListener('change', function() {
            document.getElementById('custom-style-wrap').style.display = this.value === 'custom' ? 'block' : 'none';
        });
        document.getElementById('name-tone').addEventListener('change', function() {
            document.getElementById('custom-tone-wrap').style.display = this.value === 'custom' ? 'block' : 'none';
        });

        // Language persistence
        var langSel = document.getElementById('lang-select');
        var savedLang = localStorage.getItem('gm_tool_lang');
        if (savedLang && langSel.querySelector('option[value="' + savedLang + '"]')) langSel.value = savedLang;
        langSel.addEventListener('change', function() { localStorage.setItem('gm_tool_lang', this.value); });

        document.getElementById('spark-btn').addEventListener('click', generate);
        document.getElementById('more-btn').addEventListener('click', generate);

        async function generate() {
            var input = document.getElementById('name-input').value.trim();
            if (!input) { UI.toast('Please describe your group idea.', 'error'); return; }
            if (!checkRateLimit()) return;
            lastRequestTime = Date.now();
            requestLog.push(Date.now());
            var btn = document.getElementById('spark-btn');
            btn.disabled = true;
            document.getElementById('input-section').style.display = 'none';
            document.getElementById('name-loading').style.display = 'block';
            document.getElementById('name-result').style.display = 'none';
            document.getElementById('name-loading').scrollIntoView({behavior:'smooth', block:'start'});

            var msgIdx = 0;
            var loadEl = document.getElementById('name-load-text');
            var msgInt = setInterval(function() {
                msgIdx = (msgIdx + 1) % loadTexts.length;
                loadEl.textContent = loadTexts[msgIdx];
            }, 1500);

            try {
                var res = await fetch('/api/groq', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        tool: 'name-generator',
                        lang: document.getElementById('lang-select').value,
                        prompt: (function() {
                            var style = document.getElementById('name-style').value;
                            if (style === 'custom') style = document.getElementById('custom-style').value.trim() || 'creative';
                            var tone = document.getElementById('name-tone').value;
                            if (tone === 'custom') tone = document.getElementById('custom-tone').value.trim() || 'auto';
                            return 'Group idea: ' + input + '\nName style: ' + style + '\nTone: ' + tone + '\nGenerate 10 creative names and 3 professional descriptions.';
                        })()
                    })
                });
                if (!res.ok) throw new Error('AI unavailable');
                var reader = res.body.getReader();
                var decoder = new TextDecoder();
                var fullText = '';
                var sseBuffer = '';
                while (true) {
                    var result = await reader.read();
                    if (result.done) break;
                    sseBuffer += decoder.decode(result.value, { stream: true });
                    var sseLines = sseBuffer.split('\n');
                    sseBuffer = sseLines.pop() || '';
                    for (var i = 0; i < sseLines.length; i++) {
                        var line = sseLines[i].trim();
                        if (!line.startsWith('data: ')) continue;
                        var data = line.slice(6).trim();
                        if (data === '[DONE]') continue;
                        try { var parsed = JSON.parse(data); if (parsed.text) fullText += parsed.text; } catch(e) {}
                    }
                }
                if (sseBuffer.trim()) { var lastLine = sseBuffer.trim(); if (lastLine.startsWith('data: ')) { var ld = lastLine.slice(6).trim(); if (ld !== '[DONE]') { try { var lp = JSON.parse(ld); if (lp.text) fullText += lp.text; } catch(e) {} } } }
                var cleaned = fullText.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();
                var jsonMatch = cleaned.match(/\{[\s\S]*\}/);
                if (jsonMatch) { var d = JSON.parse(jsonMatch[0]); renderResult(d.names, d.bios); }
                else { throw new Error('Parse failed'); }
            } catch (err) {
                console.error('Name gen failed, using fallback:', err);
                var fb = fallbackNames(input);
                renderResult(fb.names, fb.bios);
                UI.toast('Generated (offline mode)', 'info');
            } finally {
                clearInterval(msgInt);
                document.getElementById('name-loading').style.display = 'none';
                btn.disabled = false;
            }
        }

        function fallbackNames(input) {
            var w = input.split(/\s+/).slice(0, 3).map(function(s){return s.charAt(0).toUpperCase()+s.slice(1);}).join(' ');
            return {
                names: [
                    w + ' Hub', w + ' Nation', 'The ' + w + ' Club', w + ' Elite',
                    w + ' Central', w + ' Squad', w + ' Tribe', 'All About ' + w,
                    w + ' Spot', w + ' Circle'
                ],
                bios: [
                    '\uD83C\uDF1F Welcome to the ultimate ' + input + ' community! Join us for daily discussions, tips, and connections with like-minded people.',
                    '\uD83D\uDE80 A premium group dedicated to ' + input + '. We share knowledge, build connections, and grow together. Members only!',
                    '\uD83D\uDCA1 Your go-to space for everything ' + input + '. Expert advice, real discussions, and a supportive community waiting for you.'
                ]
            };
        }

        function renderResult(names, bios) {
            var namesList = document.getElementById('names-list');
            namesList.innerHTML = '';
            (names || []).forEach(function(name, i) {
                var div = document.createElement('div');
                div.className = 'name-item';
                div.innerHTML = '<div class="name-item__left"><span class="name-item__num">' + (i+1) + '</span><span class="name-item__text">' + Security.sanitize(name) + '</span></div><button class="copy-name-btn" data-name="' + Security.sanitize(name).replace(/"/g,'&quot;') + '">\uD83D\uDCCB</button>';
                namesList.appendChild(div);
            });
            namesList.querySelectorAll('.copy-name-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    UI.copyToClipboard(this.dataset.name);
                    this.textContent = '\u2705';
                    var b = this;
                    setTimeout(function() { b.textContent = '\uD83D\uDCCB'; }, 1500);
                });
            });

            var biosList = document.getElementById('bios-list');
            biosList.innerHTML = '';
            (bios || []).forEach(function(bio, i) {
                var div = document.createElement('div');
                div.className = 'bio-item';
                div.innerHTML = '<div class="bio-item__text">' + Security.sanitize(bio) + '</div><div class="bio-item__footer"><button class="copy-name-btn" data-bio="' + i + '">\uD83D\uDCCB Copy</button></div>';
                biosList.appendChild(div);
                div.querySelector('.copy-name-btn').addEventListener('click', function() {
                    UI.copyToClipboard(bio);
                    this.textContent = '\u2705 Copied!';
                    var b = this;
                    setTimeout(function() { b.textContent = '\uD83D\uDCCB Copy'; }, 1500);
                });
            });

            document.getElementById('name-result').style.display = 'block';
            document.getElementById('input-section').style.display = '';
            document.getElementById('name-result').scrollIntoView({behavior:'smooth', block:'start'});
            UI.toast('10 names + 3 bios ready!', 'success');
        }
    })();
    </script>
</Fragment>
</BaseLayout>
