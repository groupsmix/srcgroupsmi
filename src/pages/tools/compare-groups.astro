---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Compare Groups Side by Side — GroupsMix"
  description="Compare 2-3 social media groups side by side. Trust score, member count, rating, activity — all in one view. A GroupsMix exclusive."
  canonical="https://groupsmix.com/tools/compare-groups"
  ogTitle="Compare Groups Side by Side — GroupsMix"
  ogDescription="Compare 2-3 social media groups side by side. Trust score, member count, rating, activity — all in one view."
  ogUrl="https://groupsmix.com/tools/compare-groups"
>
<style is:inline>
    .compare-page {
        max-width: var(--container-lg);
        margin: 0 auto;
        padding: var(--space-8) var(--space-4);
    }
    .compare-hero {
        text-align: center;
        margin-bottom: var(--space-8);
    }
    .compare-hero__badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: linear-gradient(135deg, var(--accent-primary), #9c27b0);
        color: #fff;
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: var(--font-bold);
        margin-bottom: var(--space-3);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .compare-hero__title {
        font-size: var(--text-3xl);
        font-weight: var(--font-bold);
        margin-bottom: var(--space-3);
    }
    .compare-hero__subtitle {
        color: var(--text-secondary);
        font-size: var(--text-base);
        max-width: 600px;
        margin: 0 auto;
    }

    /* ── Slot Picker ── */
    .compare-slots {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-4);
        margin-bottom: var(--space-8);
    }
    .compare-slot {
        background: var(--bg-card);
        border: 2px dashed var(--border-primary);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        text-align: center;
        min-height: 180px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: border-color 0.2s, box-shadow 0.2s;
        position: relative;
    }
    .compare-slot--filled {
        border-style: solid;
        border-color: var(--accent-primary);
    }
    .compare-slot__add-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-full);
        background: rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-2xl);
        margin-bottom: var(--space-3);
        color: var(--text-tertiary);
        cursor: pointer;
        transition: all 0.2s;
    }
    .compare-slot__add-icon:hover {
        background: rgba(255,255,255,0.12);
        color: var(--text-primary);
        transform: scale(1.05);
    }
    .compare-slot__label {
        font-size: var(--text-sm);
        color: var(--text-tertiary);
        font-weight: var(--font-medium);
    }
    .compare-slot__name {
        font-size: var(--text-lg);
        font-weight: var(--font-bold);
        margin-bottom: var(--space-1);
        color: var(--text-primary);
    }
    .compare-slot__platform {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        margin-bottom: var(--space-3);
    }
    .compare-slot__remove {
        position: absolute;
        top: var(--space-2);
        right: var(--space-2);
        width: 28px;
        height: 28px;
        border-radius: var(--radius-full);
        border: 1px solid var(--border-primary);
        background: var(--bg-card);
        color: var(--text-tertiary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: var(--text-sm);
        transition: all 0.2s;
    }
    .compare-slot__remove:hover {
        background: var(--error);
        color: #fff;
        border-color: var(--error);
    }

    /* ── Search Dropdown ── */
    .compare-search-wrap {
        position: relative;
        max-width: 400px;
        margin: 0 auto;
    }
    .compare-search-wrap .form-input {
        width: 100%;
    }
    .compare-search-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-lg);
        margin-top: var(--space-1);
        max-height: 240px;
        overflow-y: auto;
        z-index: 100;
        box-shadow: var(--shadow-lg);
    }
    .compare-search-item {
        padding: var(--space-3) var(--space-4);
        cursor: pointer;
        border-bottom: 1px solid var(--border-primary);
        transition: background 0.15s;
    }
    .compare-search-item:last-child {
        border-bottom: none;
    }
    .compare-search-item:hover {
        background: rgba(255,255,255,0.04);
    }
    .compare-search-item__name {
        font-weight: var(--font-semibold);
        font-size: var(--text-sm);
    }
    .compare-search-item__meta {
        font-size: var(--text-xs);
        color: var(--text-tertiary);
    }

    /* ── Comparison Table ── */
    .compare-table-wrap {
        display: none;
        margin-bottom: var(--space-8);
    }
    .compare-table-wrap--visible {
        display: block;
    }
    .compare-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .compare-table th,
    .compare-table td {
        padding: var(--space-3) var(--space-4);
        text-align: center;
        border-bottom: 1px solid var(--border-primary);
    }
    .compare-table th {
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-tertiary);
        font-weight: var(--font-semibold);
        background: var(--bg-secondary);
        position: sticky;
        top: 0;
        z-index: 1;
    }
    .compare-table th:first-child,
    .compare-table td:first-child {
        text-align: left;
        font-weight: var(--font-semibold);
        color: var(--text-secondary);
        font-size: var(--text-sm);
        min-width: 140px;
    }
    .compare-table td {
        font-size: var(--text-sm);
    }
    .compare-winner {
        background: rgba(76, 175, 80, 0.08);
        font-weight: var(--font-bold);
        color: var(--success);
        position: relative;
    }
    .compare-winner::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border: 2px solid rgba(76, 175, 80, 0.2);
        border-radius: 0;
        pointer-events: none;
    }

    /* ── Score Bars ── */
    .compare-bar {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        justify-content: center;
    }
    .compare-bar__track {
        width: 80px;
        height: 6px;
        background: var(--bg-tertiary);
        border-radius: var(--radius-full);
        overflow: hidden;
    }
    .compare-bar__fill {
        height: 100%;
        border-radius: var(--radius-full);
        transition: width 0.5s ease;
    }
    .compare-bar__fill--green { background: var(--success); }
    .compare-bar__fill--yellow { background: #f59e0b; }
    .compare-bar__fill--red { background: var(--error); }
    .compare-bar__fill--accent { background: var(--accent-primary); }

    /* ── Best Pick Banner ── */
    .compare-best-pick {
        display: none;
        background: linear-gradient(135deg, rgba(76, 175, 80, 0.1), rgba(76, 175, 80, 0.05));
        border: 1px solid rgba(76, 175, 80, 0.3);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        margin-bottom: var(--space-6);
        text-align: center;
    }
    .compare-best-pick--visible {
        display: block;
        animation: fadeIn 0.5s ease;
    }
    .compare-best-pick__trophy {
        font-size: var(--text-4xl);
        margin-bottom: var(--space-2);
    }
    .compare-best-pick__title {
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        margin-bottom: var(--space-1);
    }
    .compare-best-pick__reason {
        font-size: var(--text-sm);
        color: var(--text-secondary);
    }

    /* ── Share Bar ── */
    .compare-actions {
        display: flex;
        justify-content: center;
        gap: var(--space-3);
        margin-bottom: var(--space-8);
    }

    /* ── Responsive ── */
    @media (max-width: 767px) {
        .compare-hero__title { font-size: var(--text-2xl); }
        .compare-slots { grid-template-columns: 1fr; }
        .compare-table-wrap { overflow-x: auto; }
        .compare-table { min-width: 500px; }
        .compare-bar__track { width: 50px; }
    }
</style>

<div class="compare-page">
    <!-- Hero -->
    <div class="compare-hero">
        <span class="compare-hero__badge">&#9878;&#65039; Exclusive Tool</span>
        <h1 class="compare-hero__title">Compare Groups Side by Side</h1>
        <p class="compare-hero__subtitle">Pick 2-3 groups and instantly see which one wins on trust, activity, rating, and more. No other platform does this.</p>
    </div>

    <!-- Search -->
    <div class="compare-search-wrap" id="compare-search-wrap">
        <input type="text" class="form-input" id="compare-search-input" placeholder="Search for a group to add..." autocomplete="off">
        <div class="compare-search-results" id="compare-search-results" style="display:none"></div>
    </div>

    <!-- Slots -->
    <div class="compare-slots" id="compare-slots" style="margin-top:var(--space-6)">
        <div class="compare-slot" id="slot-0">
            <div class="compare-slot__add-icon" data-slot="0">+</div>
            <div class="compare-slot__label">Add Group 1</div>
        </div>
        <div class="compare-slot" id="slot-1">
            <div class="compare-slot__add-icon" data-slot="1">+</div>
            <div class="compare-slot__label">Add Group 2</div>
        </div>
        <div class="compare-slot" id="slot-2">
            <div class="compare-slot__add-icon" data-slot="2">+</div>
            <div class="compare-slot__label">Add Group 3 (optional)</div>
        </div>
    </div>

    <!-- Best Pick -->
    <div class="compare-best-pick" id="compare-best-pick">
        <div class="compare-best-pick__trophy">&#127942;</div>
        <div class="compare-best-pick__title" id="best-pick-name"></div>
        <div class="compare-best-pick__reason" id="best-pick-reason"></div>
    </div>

    <!-- Comparison Table -->
    <div class="compare-table-wrap" id="compare-table-wrap">
        <table class="compare-table" id="compare-table">
            <thead id="compare-thead"></thead>
            <tbody id="compare-tbody"></tbody>
        </table>
    </div>

    <!-- Actions -->
    <div class="compare-actions" id="compare-actions" style="display:none">
        <button class="btn btn-primary" id="compare-share-btn">&#128279; Share Comparison</button>
        <button class="btn btn-secondary" id="compare-reset-btn">&#128260; Reset</button>
    </div>
</div>

<Fragment slot="scripts">
<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    var slots = [null, null, null];
    var activeSlot = -1;
    var debounceTimer = null;
    var searchInput = document.getElementById('compare-search-input');
    var searchResults = document.getElementById('compare-search-results');

    // Load from URL params
    var params = new URLSearchParams(window.location.search);
    var idsParam = params.get('ids');
    if (idsParam) {
        var ids = idsParam.split(',').slice(0, 3);
        var loadPromises = ids.map(function(id) { return DB.groups.getOne(id.trim()); });
        Promise.all(loadPromises).then(function(groups) {
            for (var i = 0; i < groups.length; i++) {
                if (groups[i]) {
                    slots[i] = groups[i];
                    renderSlot(i);
                }
            }
            if (getFilledCount() >= 2) renderComparison();
        });
    }

    // Search input
    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = searchInput.value.trim();
        if (q.length < 2) { searchResults.style.display = 'none'; return; }
        debounceTimer = setTimeout(function() { doSearch(q); }, 300);
    });

    searchInput.addEventListener('focus', function() {
        if (searchInput.value.trim().length >= 2) doSearch(searchInput.value.trim());
    });

    document.addEventListener('click', function(e) {
        if (!e.target.closest('#compare-search-wrap')) searchResults.style.display = 'none';
    });

    // Slot add-icon clicks focus search
    document.querySelectorAll('.compare-slot__add-icon').forEach(function(icon) {
        icon.addEventListener('click', function() {
            activeSlot = parseInt(icon.dataset.slot);
            searchInput.focus();
            searchInput.placeholder = 'Search for Group ' + (activeSlot + 1) + '...';
        });
    });

    // Share button
    document.getElementById('compare-share-btn').addEventListener('click', function() {
        var ids = slots.filter(function(s) { return s !== null; }).map(function(s) { return s.id; });
        var url = window.location.origin + '/tools/compare-groups?ids=' + ids.join(',');
        if (navigator.clipboard) {
            navigator.clipboard.writeText(url).then(function() {
                UI.toast('Comparison link copied!', 'success');
            });
        } else {
            UI.toast('Copy this URL: ' + url, 'info');
        }
    });

    // Reset button
    document.getElementById('compare-reset-btn').addEventListener('click', function() {
        slots = [null, null, null];
        for (var i = 0; i < 3; i++) renderSlot(i);
        document.getElementById('compare-table-wrap').classList.remove('compare-table-wrap--visible');
        document.getElementById('compare-best-pick').classList.remove('compare-best-pick--visible');
        document.getElementById('compare-actions').style.display = 'none';
        window.history.replaceState({}, '', '/tools/compare-groups');
    });

    async function doSearch(query) {
        try {
            var result = await DB.groups.search(query, { limit: 6 });
            var groups = result.data || result || [];
            if (!groups.length) {
                searchResults.innerHTML = '<div class="compare-search-item"><div class="compare-search-item__name" style="color:var(--text-tertiary)">No groups found</div></div>';
                searchResults.style.display = 'block';
                return;
            }
            // Filter out already-selected groups
            var selectedIds = slots.filter(function(s) { return s !== null; }).map(function(s) { return s.id; });
            groups = groups.filter(function(g) { return selectedIds.indexOf(g.id) === -1; });
            if (!groups.length) {
                searchResults.innerHTML = '<div class="compare-search-item"><div class="compare-search-item__name" style="color:var(--text-tertiary)">All results already added</div></div>';
                searchResults.style.display = 'block';
                return;
            }
            searchResults.innerHTML = groups.map(function(g) {
                var platform = CONFIG.platforms.find(function(p) { return p.id === g.platform; });
                return '<div class="compare-search-item" data-id="' + g.id + '">' +
                    '<div class="compare-search-item__name">' + Security.sanitize(g.name || 'Group') + '</div>' +
                    '<div class="compare-search-item__meta">' +
                    (platform ? platform.emoji + ' ' + Security.sanitize(platform.name) : Security.sanitize(g.platform || '')) +
                    ' &middot; ' + UI.formatNumber(g.members_count || 0) + ' members' +
                    ' &middot; Trust: ' + Algorithms.calculateTrustScore(g) +
                    '</div></div>';
            }).join('');
            searchResults.style.display = 'block';

            searchResults.querySelectorAll('.compare-search-item').forEach(function(item) {
                item.addEventListener('click', function() {
                    var gid = item.dataset.id;
                    var group = groups.find(function(g) { return g.id === gid; });
                    if (!group) return;
                    addGroup(group);
                });
            });
        } catch (err) {
            console.error('Compare search:', err);
        }
    }

    function addGroup(group) {
        // Find the slot to fill
        var slotIndex = activeSlot >= 0 && slots[activeSlot] === null ? activeSlot : findEmptySlot();
        if (slotIndex === -1) {
            UI.toast('Remove a group first to add a new one (max 3).', 'warning');
            return;
        }
        slots[slotIndex] = group;
        renderSlot(slotIndex);
        searchInput.value = '';
        searchResults.style.display = 'none';
        activeSlot = -1;
        searchInput.placeholder = 'Search for a group to add...';

        if (getFilledCount() >= 2) {
            renderComparison();
            updateUrl();
        }
    }

    function findEmptySlot() {
        for (var i = 0; i < 3; i++) {
            if (slots[i] === null) return i;
        }
        return -1;
    }

    function getFilledCount() {
        return slots.filter(function(s) { return s !== null; }).length;
    }

    function renderSlot(index) {
        var el = document.getElementById('slot-' + index);
        var group = slots[index];
        if (!group) {
            el.className = 'compare-slot';
            el.innerHTML = '<div class="compare-slot__add-icon" data-slot="' + index + '">+</div>' +
                '<div class="compare-slot__label">Add Group ' + (index + 1) + (index === 2 ? ' (optional)' : '') + '</div>';
            el.querySelector('.compare-slot__add-icon').addEventListener('click', function() {
                activeSlot = index;
                searchInput.focus();
                searchInput.placeholder = 'Search for Group ' + (index + 1) + '...';
            });
            return;
        }
        var platform = CONFIG.platforms.find(function(p) { return p.id === group.platform; });
        var tier = Algorithms.getEffectiveTier(group);
        el.className = 'compare-slot compare-slot--filled';
        el.innerHTML = '<button class="compare-slot__remove" data-slot="' + index + '" title="Remove">&times;</button>' +
            '<div class="compare-slot__name">' + Security.sanitize(group.name || 'Group') +
            (tier !== 'none' ? ' ' + UI.trustBadge(tier) : '') + '</div>' +
            '<div class="compare-slot__platform">' +
            (platform ? platform.emoji + ' ' + Security.sanitize(platform.name) : Security.sanitize(group.platform || '')) +
            '</div>' +
            '<div style="font-size:var(--text-2xl);font-weight:var(--font-extrabold);color:var(--accent-primary)">' +
            Algorithms.calculateTrustScore(group) + '<span style="font-size:var(--text-xs);color:var(--text-tertiary);margin-left:4px">Trust</span></div>';

        el.querySelector('.compare-slot__remove').addEventListener('click', function() {
            slots[index] = null;
            renderSlot(index);
            if (getFilledCount() < 2) {
                document.getElementById('compare-table-wrap').classList.remove('compare-table-wrap--visible');
                document.getElementById('compare-best-pick').classList.remove('compare-best-pick--visible');
                document.getElementById('compare-actions').style.display = 'none';
            } else {
                renderComparison();
            }
            updateUrl();
        });
    }

    function updateUrl() {
        var ids = slots.filter(function(s) { return s !== null; }).map(function(s) { return s.id; });
        if (ids.length >= 2) {
            window.history.replaceState({}, '', '/tools/compare-groups?ids=' + ids.join(','));
        } else {
            window.history.replaceState({}, '', '/tools/compare-groups');
        }
    }

    function renderComparison() {
        var filled = slots.filter(function(s) { return s !== null; });
        if (filled.length < 2) return;

        // Build header
        var thead = document.getElementById('compare-thead');
        var headerHtml = '<tr><th>Metric</th>';
        filled.forEach(function(g) {
            headerHtml += '<th>' + Security.sanitize((g.name || 'Group').slice(0, 20)) + '</th>';
        });
        headerHtml += '</tr>';
        thead.innerHTML = headerHtml;

        // Calculate scores
        var metrics = buildMetrics(filled);

        // Build body
        var tbody = document.getElementById('compare-tbody');
        var bodyHtml = '';
        metrics.forEach(function(metric) {
            bodyHtml += '<tr>';
            bodyHtml += '<td>' + metric.icon + ' ' + metric.label + '</td>';
            metric.values.forEach(function(val, i) {
                var isWinner = metric.winnerIndex === i;
                bodyHtml += '<td class="' + (isWinner ? 'compare-winner' : '') + '">';
                if (metric.type === 'bar') {
                    var pct = metric.maxVal > 0 ? Math.round((val.raw / metric.maxVal) * 100) : 0;
                    var color = pct >= 70 ? 'green' : pct >= 40 ? 'yellow' : 'red';
                    bodyHtml += '<div class="compare-bar"><span>' + val.display + '</span>' +
                        '<div class="compare-bar__track"><div class="compare-bar__fill compare-bar__fill--' + color + '" style="width:' + pct + '%"></div></div></div>';
                } else {
                    bodyHtml += val.display;
                }
                bodyHtml += '</td>';
            });
            bodyHtml += '</tr>';
        });
        tbody.innerHTML = bodyHtml;

        // Show table
        document.getElementById('compare-table-wrap').classList.add('compare-table-wrap--visible');
        document.getElementById('compare-actions').style.display = 'flex';

        // Best pick
        determineBestPick(filled, metrics);
    }

    function buildMetrics(groups) {
        var metrics = [];

        // Trust Score
        var trustScores = groups.map(function(g) { return Algorithms.calculateTrustScore(g); });
        metrics.push(createMetric('&#128737;&#65039;', 'Trust Score', trustScores, 'bar', 100, 'higher'));

        // Members Count
        var members = groups.map(function(g) { return g.members_count || 0; });
        metrics.push(createMetric('&#128101;', 'Members', members, 'bar', Math.max.apply(null, members) || 1, 'higher', true));

        // Rating
        var ratings = groups.map(function(g) { return parseFloat(g.avg_rating) || 0; });
        metrics.push(createMetric('&#11088;', 'Rating', ratings, 'bar', 5, 'higher', false, 1));

        // Review Count
        var reviews = groups.map(function(g) { return g.review_count || 0; });
        metrics.push(createMetric('&#128172;', 'Reviews', reviews, 'bar', Math.max.apply(null, reviews) || 1, 'higher'));

        // Views
        var views = groups.map(function(g) { return g.views || 0; });
        metrics.push(createMetric('&#128065;', 'Views', views, 'bar', Math.max.apply(null, views) || 1, 'higher', true));

        // Clicks
        var clicks = groups.map(function(g) { return g.click_count || 0; });
        metrics.push(createMetric('&#128073;', 'Clicks', clicks, 'bar', Math.max.apply(null, clicks) || 1, 'higher', true));

        // 7-Day Engagement
        var engagement = groups.map(function(g) { return Algorithms.calculate7DayEngagement(g); });
        metrics.push(createMetric('&#128200;', '7-Day Engagement', engagement, 'bar', Math.max.apply(null, engagement) || 1, 'higher', false, 1));

        // Reports (lower is better)
        var reports = groups.map(function(g) { return g.reports || 0; });
        metrics.push(createMetric('&#128681;', 'Reports', reports, 'text', 0, 'lower'));

        // Platform
        var platforms = groups.map(function(g) {
            var p = CONFIG.platforms.find(function(pl) { return pl.id === g.platform; });
            return p ? p.emoji + ' ' + p.name : g.platform || 'Unknown';
        });
        metrics.push({ icon: '&#128241;', label: 'Platform', values: platforms.map(function(v) { return { raw: 0, display: v }; }), type: 'text', winnerIndex: -1 });

        // Category
        var categories = groups.map(function(g) {
            var c = CONFIG.categories.find(function(ct) { return ct.id === g.category; });
            return c ? c.emoji + ' ' + c.name : g.category || 'General';
        });
        metrics.push({ icon: '&#127991;', label: 'Category', values: categories.map(function(v) { return { raw: 0, display: v }; }), type: 'text', winnerIndex: -1 });

        // VIP Tier
        var tiers = groups.map(function(g) {
            var tier = Algorithms.getEffectiveTier(g);
            if (tier === 'none') return 'None';
            return UI.trustBadge(tier);
        });
        metrics.push({ icon: '&#128081;', label: 'VIP Tier', values: tiers.map(function(v) { return { raw: 0, display: v }; }), type: 'text', winnerIndex: -1 });

        return metrics;
    }

    function createMetric(icon, label, rawValues, type, maxVal, direction, formatNum, decimals) {
        var winnerIndex = -1;
        var winnerVal = direction === 'higher' ? -Infinity : Infinity;
        rawValues.forEach(function(v, i) {
            if (direction === 'higher' && v > winnerVal) { winnerVal = v; winnerIndex = i; }
            if (direction === 'lower' && v < winnerVal) { winnerVal = v; winnerIndex = i; }
        });
        // No winner if all values are the same
        var allSame = rawValues.every(function(v) { return v === rawValues[0]; });
        if (allSame) winnerIndex = -1;

        var values = rawValues.map(function(v) {
            var display = '';
            if (formatNum) {
                display = UI.formatNumber(v);
            } else if (decimals !== undefined) {
                display = v.toFixed(decimals);
            } else {
                display = String(v);
            }
            return { raw: v, display: display };
        });

        return { icon: icon, label: label, values: values, type: type, maxVal: maxVal, winnerIndex: winnerIndex };
    }

    function determineBestPick(groups, metrics) {
        var scores = groups.map(function() { return 0; });
        metrics.forEach(function(m) {
            if (m.winnerIndex >= 0) scores[m.winnerIndex] += 1;
        });

        var bestIndex = 0;
        var bestScore = scores[0];
        for (var i = 1; i < scores.length; i++) {
            if (scores[i] > bestScore) { bestScore = scores[i]; bestIndex = i; }
        }

        // Only show if there's a clear winner
        var secondBest = 0;
        for (var j = 0; j < scores.length; j++) {
            if (j !== bestIndex && scores[j] > secondBest) secondBest = scores[j];
        }

        var bestPick = document.getElementById('compare-best-pick');
        if (bestScore > secondBest) {
            document.getElementById('best-pick-name').textContent = groups[bestIndex].name || 'Group';
            document.getElementById('best-pick-reason').textContent =
                'Wins in ' + bestScore + ' out of ' + metrics.filter(function(m) { return m.winnerIndex >= 0; }).length + ' comparable metrics. ' +
                'Trust Score: ' + Algorithms.calculateTrustScore(groups[bestIndex]) + '/100';
            bestPick.classList.add('compare-best-pick--visible');
        } else {
            bestPick.classList.remove('compare-best-pick--visible');
        }
    }
});
</script>
</Fragment>
</BaseLayout>
