---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Multi-Platform Post Formatter — GroupsMix"
  description="Write once, get formatted versions for WhatsApp, Telegram, Discord, and Facebook. Save time posting across platforms."
  canonical="https://groupsmix.com/tools/post-formatter"
>
<style is:inline>
        .fmt-container { max-width:var(--container-sm);margin:0 auto;padding:var(--space-8) var(--space-4); }
        .fmt-hero { text-align:center;padding:var(--space-8) var(--space-4);background:linear-gradient(135deg,rgba(99,102,241,0.12),rgba(236,72,153,0.08),transparent);border-radius:var(--radius-xl);margin-bottom:var(--space-6);border:1px solid rgba(99,102,241,0.2); }
        .fmt-hero__icon { font-size:56px;margin-bottom:var(--space-3);display:block; }
        .fmt-hero h1 { background:linear-gradient(135deg,#6366F1,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:var(--space-2); }
        .fmt-form { background:var(--bg-card);border:1px solid var(--border-primary);border-radius:var(--radius-lg);padding:var(--space-5); }
        .fmt-form textarea { width:100%;min-height:140px;background:var(--bg-input);border:2px solid var(--border-primary);border-radius:var(--radius-md);padding:var(--space-4);color:var(--text-primary);font-size:var(--text-base);resize:vertical;transition:all 0.3s;font-family:inherit; }
        .fmt-form textarea::placeholder { color:var(--text-muted); }
        .fmt-form textarea:focus { border-color:#6366F1;box-shadow:0 0 0 4px rgba(99,102,241,0.15);outline:none; }
        .format-btn { width:100%;height:56px;margin-top:var(--space-4);border:none;border-radius:14px;cursor:pointer;font-size:var(--text-lg);font-weight:700;color:#fff;background:linear-gradient(135deg,#6366F1,#ec4899);box-shadow:0 4px 20px rgba(99,102,241,0.4);transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:var(--space-2); }
        .format-btn:hover { transform:translateY(-2px);box-shadow:0 8px 30px rgba(99,102,241,0.5); }
        .format-btn:disabled { opacity:0.6;cursor:not-allowed;transform:none; }
        .fmt-result { display:none;animation:slideUp 0.6s ease; }
        @keyframes slideUp { from{opacity:0;transform:translateY(30px);} to{opacity:1;transform:translateY(0);} }
        .platform-tabs { display:flex;gap:var(--space-2);margin-bottom:var(--space-4);overflow-x:auto;padding-bottom:var(--space-2); }
        .platform-tab { padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);font-size:var(--text-sm);font-weight:600;cursor:pointer;border:2px solid var(--border-primary);background:transparent;color:var(--text-secondary);transition:all 0.2s;white-space:nowrap;display:flex;align-items:center;gap:var(--space-1); }
        .platform-tab:hover { border-color:var(--accent-primary); }
        .platform-tab--active { border-color:#6366F1;background:rgba(99,102,241,0.1);color:#6366F1; }
        .platform-output { background:var(--bg-card);border:1px solid var(--border-primary);border-radius:var(--radius-lg);overflow:hidden; }
        .platform-output__header { padding:var(--space-3) var(--space-4);background:var(--bg-tertiary);display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border-primary); }
        .platform-output__name { font-weight:700;font-size:var(--text-sm);display:flex;align-items:center;gap:var(--space-2); }
        .platform-output__body { padding:var(--space-4);white-space:pre-wrap;font-size:var(--text-sm);color:var(--text-secondary);line-height:1.7;min-height:80px;font-family:inherit; }
        .platform-output__footer { padding:var(--space-3) var(--space-4);border-top:1px solid var(--border-primary);display:flex;gap:var(--space-2);justify-content:flex-end; }
        .copy-fmt-btn { height:36px;padding:0 14px;border-radius:10px;font-weight:600;font-size:var(--text-sm);background:var(--gradient-accent);color:#fff;border:none;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;gap:var(--space-1); }
        .copy-fmt-btn:hover { transform:translateY(-1px); }
        .fmt-actions { display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap;margin-top:var(--space-5); }
        .char-count { font-size:var(--text-xs);color:var(--text-muted);text-align:right;margin-top:var(--space-1); }
        .fmt-tips { margin-top:var(--space-4);padding:var(--space-4);background:rgba(99,102,241,0.05);border:1px solid rgba(99,102,241,0.15);border-radius:var(--radius-md); }
        .fmt-tips__title { font-size:var(--text-xs);font-weight:700;color:#6366F1;text-transform:uppercase;margin-bottom:var(--space-2); }
        .fmt-tips__list { font-size:var(--text-xs);color:var(--text-secondary);line-height:1.6; }
    </style>


        <div class="fmt-container">
            <div class="fmt-hero">
                <span class="fmt-hero__icon">&#x1F4DD;</span>
                <h1>Multi-Platform Post Formatter</h1>
                <p style="color:var(--text-secondary)">Write once, get formatted versions for WhatsApp, Telegram, Discord, and Facebook</p>
            </div>
            <div class="fmt-form" id="input-section">
                <label class="form-label" style="color:#818cf8">Write your post content</label>
                <textarea id="post-input" rows="6" placeholder="Write your post here... Use **bold**, _italic_, ~strikethrough~, and regular line breaks. The formatter will adapt it to each platform's syntax."></textarea>
                <div class="char-count"><span id="char-count">0</span> characters</div>
                <div class="fmt-tips">
                    <div class="fmt-tips__title">Formatting Tips</div>
                    <div class="fmt-tips__list">
                        <strong>**bold text**</strong> &bull; <em>_italic text_</em> &bull; <s>~strikethrough~</s> &bull; <code>`code`</code><br>
                        Use blank lines for paragraphs. Emojis work on all platforms.
                    </div>
                </div>
                <button class="format-btn" id="format-btn">&#x1F4DD; Format for All Platforms</button>
            </div>
            <div class="fmt-result" id="fmt-result">
                <div class="platform-tabs" id="platform-tabs"></div>
                <div id="platform-outputs"></div>
                <div class="fmt-actions">
                    <button class="format-btn" style="width:auto;padding:0 24px;height:48px;font-size:var(--text-base)" id="edit-btn">&#x270F;&#xFE0F; Edit Post</button>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    (function() {
        'use strict';

        var platforms = [
            { id: 'whatsapp', name: 'WhatsApp', icon: '\uD83D\uDCAC', color: '#25D366' },
            { id: 'telegram', name: 'Telegram', icon: '\u2708\uFE0F', color: '#0088cc' },
            { id: 'discord', name: 'Discord', icon: '\uD83C\uDFAE', color: '#5865F2' },
            { id: 'facebook', name: 'Facebook', icon: '\uD83D\uDC65', color: '#1877F2' }
        ];
        var currentPlatform = 'whatsapp';
        var formattedPosts = {};

        // Char counter
        document.getElementById('post-input').addEventListener('input', function() {
            document.getElementById('char-count').textContent = this.value.length;
        });

        document.getElementById('format-btn').addEventListener('click', formatPost);
        document.getElementById('edit-btn').addEventListener('click', function() {
            document.getElementById('fmt-result').style.display = 'none';
            document.getElementById('input-section').style.display = '';
            document.getElementById('post-input').focus();
            document.getElementById('input-section').scrollIntoView({behavior:'smooth', block:'start'});
        });

        function formatPost() {
            var raw = document.getElementById('post-input').value;
            if (!raw.trim()) { UI.toast('Please write your post content first.', 'error'); return; }

            // Format for each platform
            formattedPosts = {
                whatsapp: formatWhatsApp(raw),
                telegram: formatTelegram(raw),
                discord: formatDiscord(raw),
                facebook: formatFacebook(raw)
            };

            renderTabs();
            renderOutput('whatsapp');

            document.getElementById('input-section').style.display = 'none';
            document.getElementById('fmt-result').style.display = 'block';
            document.getElementById('fmt-result').scrollIntoView({behavior:'smooth', block:'start'});
            UI.toast('Formatted for 4 platforms!', 'success');
        }

        function formatWhatsApp(text) {
            // WhatsApp uses *bold*, _italic_, ~strikethrough~, ```monospace```
            // Already the base format, just clean up markdown-style
            var out = text;
            // Convert **bold** to *bold*
            out = out.replace(/\*\*(.+?)\*\*/g, '*$1*');
            // _italic_ stays the same
            // ~strikethrough~ stays the same
            // `code` → ```code```
            out = out.replace(/`([^`]+)`/g, '```$1```');
            return out;
        }

        function formatTelegram(text) {
            // Telegram uses **bold**, __italic__, ~~strikethrough~~, `code`
            var out = text;
            // **bold** stays
            // _italic_ → __italic__
            out = out.replace(/(?<!\w)_([^_]+)_(?!\w)/g, '__$1__');
            // ~strikethrough~ → ~~strikethrough~~
            out = out.replace(/(?<!\~)~([^~]+)~(?!\~)/g, '~~$1~~');
            // `code` stays the same
            return out;
        }

        function formatDiscord(text) {
            // Discord uses **bold**, *italic*, ~~strikethrough~~, `code`
            var out = text;
            // **bold** stays
            // _italic_ → *italic*
            out = out.replace(/(?<!\w)_([^_]+)_(?!\w)/g, '*$1*');
            // ~strikethrough~ → ~~strikethrough~~
            out = out.replace(/(?<!\~)~([^~]+)~(?!\~)/g, '~~$1~~');
            // `code` stays the same
            return out;
        }

        function formatFacebook(text) {
            // Facebook has limited formatting. Strip markdown formatting for clean text.
            var out = text;
            // Remove bold markers
            out = out.replace(/\*\*(.+?)\*\*/g, '$1');
            out = out.replace(/\*(.+?)\*/g, '$1');
            // Remove italic markers
            out = out.replace(/(?<!\w)_([^_]+)_(?!\w)/g, '$1');
            // Remove strikethrough markers
            out = out.replace(/~([^~]+)~/g, '$1');
            // Remove code markers
            out = out.replace(/`([^`]+)`/g, '$1');
            // Facebook posts work best with emojis and line spacing
            // Add extra line spacing between paragraphs
            out = out.replace(/\n\n/g, '\n\n\n');
            return out;
        }

        function renderTabs() {
            var tabsEl = document.getElementById('platform-tabs');
            tabsEl.innerHTML = '';
            platforms.forEach(function(p) {
                var btn = document.createElement('button');
                btn.className = 'platform-tab' + (p.id === currentPlatform ? ' platform-tab--active' : '');
                btn.innerHTML = p.icon + ' ' + p.name;
                btn.addEventListener('click', function() {
                    currentPlatform = p.id;
                    renderTabs();
                    renderOutput(p.id);
                });
                tabsEl.appendChild(btn);
            });
        }

        function renderOutput(platformId) {
            var p = platforms.find(function(x) { return x.id === platformId; });
            if (!p) return;
            var text = formattedPosts[platformId] || '';
            var outputsEl = document.getElementById('platform-outputs');
            outputsEl.innerHTML =
                '<div class="platform-output">' +
                    '<div class="platform-output__header">' +
                        '<div class="platform-output__name">' + p.icon + ' ' + p.name + '</div>' +
                        '<span style="font-size:var(--text-xs);color:var(--text-tertiary)">' + text.length + ' chars</span>' +
                    '</div>' +
                    '<div class="platform-output__body" id="output-text"></div>' +
                    '<div class="platform-output__footer">' +
                        '<button class="copy-fmt-btn" id="copy-output">\uD83D\uDCCB Copy</button>' +
                    '</div>' +
                '</div>';
            document.getElementById('output-text').textContent = text;
            document.getElementById('copy-output').addEventListener('click', function() {
                UI.copyToClipboard(text);
                this.textContent = '\u2705 Copied!';
                var b = this;
                setTimeout(function() { b.textContent = '\uD83D\uDCCB Copy'; }, 1500);
            });
        }
    })();
    </script>
</Fragment>
</BaseLayout>
