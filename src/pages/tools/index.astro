---
---
<BaseLayout
  title="Free AI Tools — GroupsMix"
  description="11 powerful tools for group admins: 7 AI-powered creators and 4 essential utilities. Generate names, bios, rules, viral posts, covers, and more."
>
<style is:inline>
        .tools-hero {
            text-align: center;
            padding: var(--space-8) var(--space-4);
            background: linear-gradient(135deg, var(--accent-primary-light), transparent);
            border-radius: var(--radius-lg);
            margin-bottom: var(--space-8);
        }
        .tools-hero__count {
            display: inline-flex;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-1) var(--space-3);
            background: var(--accent-primary);
            color: #fff;
            border-radius: var(--radius-full);
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-3);
        }
        .tools-section {
            margin-bottom: var(--space-8);
        }
        .tools-section__title {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-4);
            padding-bottom: var(--space-2);
            border-bottom: 2px solid var(--accent-primary);
            display: inline-block;
        }
        .tool-card {
            text-align: center;
            padding: var(--space-5);
            transition: all 0.2s;
        }
        .tool-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }
        .tool-card__icon {
            font-size: var(--text-4xl);
            margin-bottom: var(--space-3);
            display: block;
        }
        .tool-card__badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: var(--font-bold);
            text-transform: uppercase;
            margin-top: var(--space-2);
        }
        .tool-card__badge--ai { background: linear-gradient(135deg, #6200ea, #9c47ff); color: #fff; }
        .tool-card__badge--new { background: var(--success); color: #fff; }
        .tool-card__badge--popular { background: var(--accent-primary); color: #fff; }
    </style>


        <div class="container" style="max-width:var(--container-lg);padding:var(--space-8) var(--space-4)">

            <div class="tools-hero">
                <span class="tools-hero__count">&#x1F9F0; 11 Elite Tools</span>
                <h1 style="margin-bottom:var(--space-2)">AI-Powered Tools for Group Admins</h1>
                <p style="color:var(--text-secondary);max-width:600px;margin:0 auto">Professional tools powered by AI to grow, protect, and manage your community — all free, no signup required.</p>
            </div>

            <!-- AI-Powered Tools -->
            <div class="tools-section">
                <div class="tools-section__title">&#x1F916; AI-Powered (7)</div>
                <div class="grid grid-3">
                    <a href="/tools/group-creator/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x2728;</span>
                            <h3>AI Group Creator</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Enter a topic and get 10 creative names + 3 professional bios in one shot</p>
                            <span class="tool-card__badge tool-card__badge--ai">AI</span>
                        </div>
                    </a>
                    <a href="/tools/group-rules-generator/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F4CB;</span>
                            <h3>AI Group Rules Generator</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Generate professional rules + welcome message tailored to your group type</p>
                            <span class="tool-card__badge tool-card__badge--popular">Popular</span>
                        </div>
                    </a>
                    <a href="/tools/privacy-auditor/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F6E1;&#xFE0F;</span>
                            <h3>AI Privacy Auditor</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Audit your group security settings per platform with score, vulnerabilities, and fixes</p>
                            <span class="tool-card__badge tool-card__badge--ai">AI</span>
                        </div>
                    </a>
                    <a href="/tools/viral-post/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F4E2;</span>
                            <h3>AI Viral Post Creator</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Generate 3 engagement posts: magnet, debate, and gift — ready to paste</p>
                            <span class="tool-card__badge tool-card__badge--ai">AI</span>
                        </div>
                    </a>
                    <a href="/tools/cover-designer/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F3A8;</span>
                            <h3>AI Cover Designer</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Generate a real downloadable cover image rendered on Canvas — not just text prompts</p>
                            <span class="tool-card__badge tool-card__badge--new">New</span>
                        </div>
                    </a>
                    <a href="/tools/group-scorecard/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F9EC;</span>
                            <h3>AI Group Score Card</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Get a personality card with radar chart, identity analysis, and actionable tips</p>
                            <span class="tool-card__badge tool-card__badge--ai">AI</span>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Utility Tools -->
            <div class="tools-section">
                <div class="tools-section__title">&#x26A1; Utility Tools (4)</div>
                <div class="grid grid-3">
                    <a href="/tools/whatsapp-direct/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F4AC;</span>
                            <h3>WhatsApp Direct Message</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Send a message to any number without saving it as a contact</p>
                            <span class="tool-card__badge tool-card__badge--popular">Popular</span>
                        </div>
                    </a>
                    <a href="/tools/link-generator/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F517;</span>
                            <h3>Link Shortener + QR Code</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Shorten invite links, generate QR codes, and view click analytics inline</p>
                            <span class="tool-card__badge tool-card__badge--popular">Popular</span>
                        </div>
                    </a>
                    <a href="/tools/invite-link-checker/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F50D;</span>
                            <h3>Group Invite Link Checker</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Paste any group invite link and check if it's still active and valid</p>
                            <span class="tool-card__badge tool-card__badge--new">New</span>
                        </div>
                    </a>
                    <a href="/tools/post-formatter/" class="card card--clickable tool-card">
                        <div class="card__body">
                            <span class="tool-card__icon">&#x1F4DD;</span>
                            <h3>Multi-Platform Post Formatter</h3>
                            <p style="color:var(--text-secondary);font-size:var(--text-sm);margin-top:var(--space-2)">Write once, get formatted versions for WhatsApp, Telegram, Discord, and Facebook</p>
                            <span class="tool-card__badge tool-card__badge--new">New</span>
                        </div>
                    </a>
                </div>
            </div>

        </div>
    
</BaseLayout>
