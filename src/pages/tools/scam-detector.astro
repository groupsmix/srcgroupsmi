---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="AI Scam &amp; Raid Detector — GroupsMix"
  description="Scan group descriptions and messages for scam red flags. AI-powered fraud detection with traffic light system."
  canonical="https://groupsmix.com/tools/scam-detector"
>
<style is:inline>
        .scam-container { max-width:var(--container-sm);margin:0 auto;padding:var(--space-8) var(--space-4); }
        .scam-hero { text-align:center;padding:var(--space-8) var(--space-4);background:linear-gradient(135deg,rgba(99,102,241,0.12),rgba(30,58,138,0.15),transparent);border-radius:var(--radius-xl);margin-bottom:var(--space-6);border:1px solid rgba(30,58,138,0.25); }
        .scam-hero__icon { font-size:56px;margin-bottom:var(--space-3);display:block; }
        .scam-hero h1 { background:linear-gradient(135deg,#6366F1,#1e3a8a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:var(--space-2); }
        .scam-input-wrap { background:rgba(30,58,138,0.08);border:1px solid rgba(30,58,138,0.2);border-radius:var(--radius-lg);padding:var(--space-5); }
        .scam-input-wrap textarea { width:100%;min-height:120px;background:rgba(255,255,255,0.05);border:2px solid rgba(30,58,138,0.3);border-radius:var(--radius-md);padding:var(--space-4);color:var(--text-primary);font-size:var(--text-base);resize:vertical;transition:all 0.3s;font-family:inherit; }
        .scam-input-wrap textarea::placeholder { color:var(--text-muted); }
        .scam-input-wrap textarea:focus { border-color:#6366F1;box-shadow:0 0 0 4px rgba(99,102,241,0.15);outline:none; }
        .scan-btn { width:100%;height:56px;margin-top:var(--space-4);border:none;border-radius:14px;cursor:pointer;font-size:var(--text-lg);font-weight:700;color:#fff;background:linear-gradient(135deg,#1e3a8a,#6366F1);box-shadow:0 4px 20px rgba(30,58,138,0.4);transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:var(--space-2); }
        .scan-btn:hover { transform:translateY(-2px);box-shadow:0 8px 30px rgba(30,58,138,0.5); }
        .scan-btn:disabled { opacity:0.6;cursor:not-allowed;transform:none; }

        .scan-loading { display:none;text-align:center;padding:var(--space-8);position:relative; }
        .scan-laser { width:100%;height:3px;background:linear-gradient(90deg,transparent,#6366F1,transparent);position:absolute;left:0;animation:laserScan 2s ease-in-out infinite; }
        @keyframes laserScan { 0%{top:0;} 50%{top:100%;} 100%{top:0;} }
        .scan-loading__text { font-size:var(--text-base);font-weight:600;color:#818cf8;min-height:24px;margin-top:var(--space-6); }

        .scam-result { display:none;animation:slideUp 0.6s ease; }
        @keyframes slideUp { from{opacity:0;transform:translateY(30px);} to{opacity:1;transform:translateY(0);} }

        .traffic-light { text-align:center;padding:var(--space-6);border-radius:var(--radius-xl);margin-bottom:var(--space-5); }
        .traffic-light--red { background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(220,38,38,0.1));border:2px solid rgba(239,68,68,0.3); }
        .traffic-light--yellow { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.1));border:2px solid rgba(245,158,11,0.3); }
        .traffic-light--green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(5,150,105,0.1));border:2px solid rgba(16,185,129,0.3); }
        .traffic-light__icon { font-size:64px;display:block;margin-bottom:var(--space-3); }
        .traffic-light__title { font-size:var(--text-2xl);font-weight:800;margin-bottom:var(--space-2); }
        .traffic-light--red .traffic-light__title { color:#ef4444; }
        .traffic-light--yellow .traffic-light__title { color:#f59e0b; }
        .traffic-light--green .traffic-light__title { color:#10b981; }
        .traffic-light__subtitle { color:var(--text-secondary);font-size:var(--text-sm); }

        .scam-flags { margin-bottom:var(--space-5); }
        .scam-flag { display:flex;align-items:flex-start;gap:var(--space-3);padding:var(--space-3) var(--space-4);border-radius:var(--radius-md);margin-bottom:var(--space-2);background:var(--bg-tertiary);border:1px solid var(--border-primary); }
        .scam-flag__icon { font-size:20px;flex-shrink:0;margin-top:2px; }
        .scam-flag__text { font-size:var(--text-sm);color:var(--text-secondary);line-height:1.5; }
        .scam-flag__text strong { color:var(--text-primary); }

        .scam-actions { display:flex;gap:var(--space-3);justify-content:center;flex-wrap:wrap;margin-top:var(--space-5); }
        .report-btn { height:44px;padding:0 20px;border-radius:12px;font-weight:600;font-size:var(--text-sm);background:var(--error);color:#fff;border:none;cursor:pointer;display:flex;align-items:center;gap:var(--space-2);transition:all 0.3s; }
        .report-btn:hover { opacity:0.9;transform:translateY(-2px); }
    </style>


        <div class="scam-container">
            <div class="scam-hero">
                <span class="scam-hero__icon">&#x1F6E1;&#xFE0F;</span>
                <h1>AI Scam &amp; Raid Detector</h1>
                <p style="color:var(--text-secondary)">Paste suspicious messages or group descriptions to detect scams instantly</p>
            </div>
            <div class="scam-input-wrap" id="input-section">
                <label style="font-weight:600;font-size:var(--text-sm);color:#818cf8;display:block;margin-bottom:var(--space-2)">Paste suspicious text here</label>
                <textarea id="scam-input" rows="5" placeholder="Paste the group description or suspicious messages you received, and I'll tell you if there's a scammer behind it..." maxlength="5000"></textarea>
                <div class="form-group" style="margin-top:var(--space-3)">
                    <label style="font-weight:600;font-size:var(--text-sm);color:#818cf8;display:block;margin-bottom:var(--space-2)">Output Language</label>
                    <select id="lang-select" style="width:100%;height:44px;padding:0 var(--space-3);background:var(--bg-input);border:2px solid var(--border-primary);border-radius:var(--radius-md);color:var(--text-primary);font-size:var(--text-sm);cursor:pointer;transition:border-color 0.3s;">
                        <option value="en">English</option>
                        <option value="ar">العربية (Arabic)</option>
                        <option value="fr">Français (French)</option>
                        <option value="es">Español (Spanish)</option>
                        <option value="tr">Türkçe (Turkish)</option>
                        <option value="pt">Português (Portuguese)</option>
                        <option value="de">Deutsch (German)</option>
                        <option value="id">Bahasa Indonesia</option>
                        <option value="hi">हिन्दी (Hindi)</option>
                        <option value="ur">اردو (Urdu)</option>
                        <option value="zh">中文 (Chinese)</option>
                        <option value="ru">Русский (Russian)</option>
                        <option value="ja">日本語 (Japanese)</option>
                        <option value="ko">한국어 (Korean)</option>
                        <option value="it">Italiano (Italian)</option>
                        <option value="nl">Nederlands (Dutch)</option>
                        <option value="pl">Polski (Polish)</option>
                        <option value="ms">Bahasa Melayu</option>
                        <option value="th">ไทย (Thai)</option>
                        <option value="vi">Tiếng Việt (Vietnamese)</option>
                        <option value="sw">Kiswahili (Swahili)</option>
                        <option value="bn">বাংলা (Bengali)</option>
                    </select>
                </div>
                <button class="scan-btn" id="scan-btn">&#x1F4E1; Start Security Scan</button>
            </div>
            <div class="scan-loading" id="scan-loading">
                <div class="scan-laser"></div>
                <div style="padding:var(--space-8)">
                    <div style="width:60px;height:60px;margin:0 auto var(--space-4);border:4px solid rgba(99,102,241,0.2);border-top-color:#6366F1;border-radius:50%;animation:spin 1s linear infinite;"></div>
                    <div class="scan-loading__text" id="scan-text">Scanning hidden links...</div>
                </div>
            </div>
            <div class="scam-result" id="scam-result">
                <div class="traffic-light" id="traffic-light">
                    <span class="traffic-light__icon" id="tl-icon"></span>
                    <div class="traffic-light__title" id="tl-title"></div>
                    <div class="traffic-light__subtitle" id="tl-subtitle"></div>
                </div>
                <div class="scam-flags" id="scam-flags"></div>
                <div class="scam-actions">
                    <button class="btn btn-secondary btn-sm" id="copy-report">&#x1F4CB; Copy Report</button>
                    <button class="report-btn" id="report-btn">&#x26A0;&#xFE0F; Report This Group</button>
                    <button class="btn btn-ghost btn-sm" id="scan-another">&#x1F504; Scan Another</button>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    (function() {
        'use strict';
        var scanMessages = ['Scanning hidden links...','Analyzing financial lure patterns...','Matching against fraud databases...','Checking deception techniques...','Evaluating risk level...'];

        // Rate limiting: max 5 requests per 5 minutes, 30s cooldown
        var requestLog = [];
        var RATE_COOLDOWN = 30000;
        var RATE_WINDOW = 300000;
        var RATE_MAX = 5;
        var lastRequestTime = 0;
        function checkRateLimit() {
            var now = Date.now();
            if (now - lastRequestTime < RATE_COOLDOWN) { UI.toast('Please wait ' + Math.ceil((RATE_COOLDOWN - (now - lastRequestTime)) / 1000) + ' seconds before trying again.', 'error'); return false; }
            requestLog = requestLog.filter(function(t) { return now - t < RATE_WINDOW; });
            if (requestLog.length >= RATE_MAX) { UI.toast('Too many requests. Please wait a few minutes.', 'error'); return false; }
            return true;
        }

        // Language persistence
        var langSel = document.getElementById('lang-select');
        var savedLang = localStorage.getItem('gm_tool_lang');
        if (savedLang && langSel.querySelector('option[value="' + savedLang + '"]')) langSel.value = savedLang;
        langSel.addEventListener('change', function() { localStorage.setItem('gm_tool_lang', this.value); });

        document.getElementById('scan-btn').addEventListener('click', startScan);
        document.getElementById('scan-another').addEventListener('click', function() {
            document.getElementById('scam-result').style.display = 'none';
            document.getElementById('input-section').style.display = '';
            document.getElementById('scam-input').value = '';
            document.getElementById('scam-input').focus();
            document.getElementById('input-section').scrollIntoView({behavior:'smooth', block:'start'});
        });
        document.getElementById('copy-report').addEventListener('click', function() {
            var title = document.getElementById('tl-title').textContent;
            var flags = document.getElementById('scam-flags').textContent;
            UI.copyToClipboard('Scam Scan Report:\n' + title + '\n\n' + flags + '\n\nScanned by GroupsMix AI - groupsmix.com/tools/scam-detector');
        });
        document.getElementById('report-btn').addEventListener('click', function() {
            UI.toast('Report submitted. Thank you for keeping the community safe!', 'success');
        });

        async function startScan() {
            var input = document.getElementById('scam-input').value.trim();
            if (!input) { UI.toast('Please paste some text to scan.', 'error'); return; }
            if (!checkRateLimit()) return;
            lastRequestTime = Date.now();
            requestLog.push(Date.now());
            var btn = document.getElementById('scan-btn');
            btn.disabled = true;
            document.getElementById('input-section').style.display = 'none';
            document.getElementById('scan-loading').style.display = 'block';
            document.getElementById('scam-result').style.display = 'none';
            document.getElementById('scan-loading').scrollIntoView({behavior:'smooth', block:'start'});

            var msgIdx = 0;
            var scanEl = document.getElementById('scan-text');
            var msgInterval = setInterval(function() {
                msgIdx = (msgIdx + 1) % scanMessages.length;
                scanEl.style.opacity = '0';
                setTimeout(function() { scanEl.textContent = scanMessages[msgIdx]; scanEl.style.opacity = '1'; }, 200);
            }, 1200);

            try {
                var res = await fetch('/api/groq', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        tool: 'scam-detector',
                        lang: document.getElementById('lang-select').value,
                        prompt: 'Scan this for scams:\n\n' + input
                    })
                });
                if (!res.ok) throw new Error('AI unavailable');
                var reader = res.body.getReader();
                var decoder = new TextDecoder();
                var fullText = '';
                var sseBuffer = '';
                while (true) {
                    var result = await reader.read();
                    if (result.done) break;
                    sseBuffer += decoder.decode(result.value, { stream: true });
                    var sseLines = sseBuffer.split('\n');
                    sseBuffer = sseLines.pop() || '';
                    for (var i = 0; i < sseLines.length; i++) {
                        var line = sseLines[i].trim();
                        if (!line.startsWith('data: ')) continue;
                        var data = line.slice(6).trim();
                        if (data === '[DONE]') continue;
                        try { var parsed = JSON.parse(data); if (parsed.text) fullText += parsed.text; } catch(e) {}
                    }
                }
                if (sseBuffer.trim()) { var lastLine = sseBuffer.trim(); if (lastLine.startsWith('data: ')) { var ld = lastLine.slice(6).trim(); if (ld !== '[DONE]') { try { var lp = JSON.parse(ld); if (lp.text) fullText += lp.text; } catch(e) {} } } }
                var cleaned = fullText.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();
                var jsonMatch = cleaned.match(/\{[\s\S]*\}/);
                if (jsonMatch) { renderResult(JSON.parse(jsonMatch[0])); }
                else { throw new Error('Parse failed'); }
            } catch (err) {
                console.error('Scan failed, using fallback:', err);
                renderResult(analyzeFallback(input));
                UI.toast('Scan complete (offline mode)', 'info');
            } finally {
                clearInterval(msgInterval);
                document.getElementById('scan-loading').style.display = 'none';
                btn.disabled = false;
            }
        }

        function analyzeFallback(input) {
            var lower = input.toLowerCase();
            var score = 0;
            var flags = [];
            var patterns = [
                { keywords: ['guaranteed profit','guaranteed income','100% profit','double your money'], weight: 30, text: 'Promises of guaranteed financial returns - classic fraud indicator' },
                { keywords: ['send money','pay first','deposit now','transfer funds','western union','bitcoin payment'], weight: 25, text: 'Requests for upfront payment or money transfer' },
                { keywords: ['click here','bit.ly','tinyurl','limited time','act now','urgent'], weight: 15, text: 'Urgency tactics and suspicious shortened links detected' },
                { keywords: ['personal info','password','credit card','bank account','social security','ssn'], weight: 30, text: 'Requesting sensitive personal or financial information' },
                { keywords: ['winner','congratulations','you won','lottery','prize','claim your'], weight: 20, text: 'Fake prize or lottery winning notification' },
                { keywords: ['work from home','easy money','passive income','get rich','millionaire'], weight: 15, text: 'Unrealistic income claims detected' },
                { keywords: ['invest now','forex signal','crypto signal','trading bot','binary option'], weight: 20, text: 'Suspicious investment or trading scheme' },
                { keywords: ['whatsapp.com/','t.me/','discord.gg/'], weight: -5, text: '' }
            ];
            patterns.forEach(function(p) {
                for (var i = 0; i < p.keywords.length; i++) {
                    if (lower.includes(p.keywords[i])) {
                        score += p.weight;
                        if (p.text) flags.push({ icon: score > 50 ? '\u{1F6A8}' : '\u{26A0}\u{FE0F}', text: p.text });
                        break;
                    }
                }
            });

            var level, title, subtitle;
            if (score >= 40) {
                level = 'red'; title = 'STOP! High Fraud Probability';
                subtitle = 'This text contains multiple scam indicators. Do not engage.';
            } else if (score >= 15) {
                level = 'yellow'; title = 'Be Careful! Suspicious Patterns';
                subtitle = 'Some elements are unclear. Proceed with caution.';
            } else {
                level = 'green'; title = 'Appears Safe';
                subtitle = 'No significant scam indicators found based on our analysis.';
                if (flags.length === 0) flags.push({ icon: '\u2705', text: 'No obvious red flags detected in the provided text.' });
            }
            return { level: level, title: title, subtitle: subtitle, flags: flags };
        }

        function renderResult(data) {
            var tl = document.getElementById('traffic-light');
            tl.className = 'traffic-light traffic-light--' + (data.level || 'green');
            var icons = { red: '\u{1F6D1}', yellow: '\u{26A0}\u{FE0F}', green: '\u2705' };
            document.getElementById('tl-icon').textContent = icons[data.level] || '\u2705';
            document.getElementById('tl-title').textContent = data.title || 'Analysis Complete';
            document.getElementById('tl-subtitle').textContent = data.subtitle || '';

            var flagsEl = document.getElementById('scam-flags');
            flagsEl.innerHTML = '';
            if (data.flags && data.flags.length) {
                data.flags.forEach(function(f) {
                    var div = document.createElement('div');
                    div.className = 'scam-flag';
                    div.innerHTML = '<span class="scam-flag__icon">' + Security.sanitize(f.icon || '\u{26A0}\u{FE0F}') + '</span><div class="scam-flag__text">' + Security.sanitize(f.text) + '</div>';
                    flagsEl.appendChild(div);
                });
            }
            document.getElementById('scam-result').style.display = 'block';
            document.getElementById('input-section').style.display = '';
            document.getElementById('scam-result').scrollIntoView({behavior:'smooth', block:'start'});
            UI.toast('Security scan complete!', 'success');
        }
    })();
    </script>
</Fragment>
</BaseLayout>
