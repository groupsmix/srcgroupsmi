---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Support Center &mdash; GroupsMix"
  description="GroupsMix Support Center - FAQ, contact, and help resources."
>
<style is:inline>
        .legal-hero{text-align:center;padding:var(--space-8) 0 var(--space-4)}
        .legal-hero__icon{font-size:var(--text-5xl);margin-bottom:var(--space-3)}
        .legal-hero__subtitle{color:var(--text-secondary);margin-top:var(--space-2);max-width:560px;margin-left:auto;margin-right:auto;font-size:var(--text-base)}
        .glass-card{background:rgba(22,22,31,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(42,42,62,0.6);border-radius:var(--radius-xl);padding:var(--space-6);box-shadow:0 8px 32px rgba(0,0,0,0.2);transition:transform .2s ease,box-shadow .2s ease}
        .glass-card:hover{box-shadow:0 12px 40px rgba(0,0,0,0.3)}
        .glass-card__body{line-height:var(--leading-relaxed);color:var(--text-secondary)}
        .glass-card__body h2{color:var(--text-primary);margin:var(--space-6) 0 var(--space-3);font-size:var(--text-lg);font-weight:var(--font-bold);display:flex;align-items:center;gap:var(--space-2)}
        .glass-card__body h2::before{content:'';width:3px;height:20px;background:var(--accent-primary);border-radius:var(--radius-full);flex-shrink:0}
        .glass-card__body p{margin-bottom:var(--space-3)}
        .glass-card__body ul{margin-bottom:var(--space-4);padding-left:var(--space-4)}
        .glass-card__body ul li{margin-bottom:var(--space-2);line-height:1.6}
        .glass-card__body a{color:var(--accent-primary);text-decoration:none;font-weight:var(--font-medium)}
        .glass-card__body a:hover{text-decoration:underline}
        .legal-meta{display:inline-flex;align-items:center;gap:var(--space-2);padding:var(--space-1) var(--space-3);background:rgba(108,92,231,0.1);border:1px solid rgba(108,92,231,0.2);border-radius:var(--radius-full);font-size:var(--text-xs);color:var(--accent-primary);font-weight:var(--font-semibold);margin-bottom:var(--space-6)}
        .legal-nav{display:flex;gap:var(--space-2);flex-wrap:wrap;justify-content:center;margin-bottom:var(--space-6)}
        .legal-nav a{padding:var(--space-2) var(--space-3);border-radius:var(--radius-full);border:1px solid var(--border-primary);background:var(--bg-card);color:var(--text-secondary);font-size:var(--text-sm);text-decoration:none;transition:all .15s ease}
        .legal-nav a:hover,.legal-nav a.active{background:var(--accent-primary);color:#fff;border-color:var(--accent-primary)}
        [data-theme="light"] .glass-card{background:rgba(255,255,255,0.75);border-color:rgba(200,200,220,0.5);box-shadow:0 8px 32px rgba(0,0,0,0.08)}
        .sc-tabs{display:flex;gap:var(--space-2);margin-bottom:var(--space-6);justify-content:center;flex-wrap:wrap}
        .sc-tab{padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);border:1px solid var(--border-primary);background:var(--bg-card);font-size:var(--text-sm);cursor:pointer;transition:all .15s ease;color:var(--text-secondary);display:inline-flex;align-items:center;gap:var(--space-2)}
        .sc-tab:hover{border-color:var(--accent-primary);color:var(--text-primary)}
        .sc-tab--active{background:var(--accent-primary);color:#fff;border-color:var(--accent-primary)}
        .sc-panel{display:none;animation:fadeIn .3s ease}
        .sc-panel--active{display:block}
        .faq-item{background:rgba(22,22,31,0.6);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(42,42,62,0.5);border-radius:var(--radius-lg);margin-bottom:var(--space-3);overflow:hidden;transition:border-color .2s ease}
        .faq-item:hover{border-color:rgba(108,92,231,0.3)}
        .faq-item.open{border-color:var(--accent-primary)}
        .faq-question{padding:var(--space-4);cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-weight:var(--font-semibold);color:var(--text-primary)}
        .faq-question:hover{background:rgba(108,92,231,0.05)}
        .faq-answer{padding:0 var(--space-4) var(--space-4);color:var(--text-secondary);line-height:var(--leading-relaxed);display:none}
        .faq-item.open .faq-answer{display:block;animation:fadeIn .2s ease}
        .faq-item.open .faq-arrow{transform:rotate(180deg)}
        .faq-arrow{transition:transform 0.2s ease;color:var(--accent-primary);font-size:var(--text-sm)}
        .sc-search{position:relative;margin-bottom:var(--space-6)}
        .sc-search input{padding-left:var(--space-10)}
        .sc-search__icon{position:absolute;left:var(--space-3);top:50%;transform:translateY(-50%);color:var(--text-tertiary);pointer-events:none}
        .sc-quick-links{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-4);margin-bottom:var(--space-8)}
        .sc-quick-link{background:rgba(22,22,31,0.6);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(42,42,62,0.5);border-radius:var(--radius-lg);padding:var(--space-5);text-align:center;text-decoration:none;color:var(--text-primary);transition:all .2s ease}
        .sc-quick-link:hover{border-color:var(--accent-primary);transform:translateY(-2px)}
        .sc-quick-link__icon{font-size:var(--text-3xl);margin-bottom:var(--space-2)}
        .sc-quick-link__title{font-weight:var(--font-semibold);font-size:var(--text-sm);margin-bottom:var(--space-1)}
        .sc-quick-link__desc{font-size:var(--text-xs);color:var(--text-tertiary)}
        .contact-form-card{background:rgba(22,22,31,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(42,42,62,0.6);border-radius:var(--radius-xl);padding:var(--space-8)}
        .contact-form-card .form-group{margin-bottom:var(--space-4)}
        .contact-form-card .form-label{margin-bottom:var(--space-2);display:block;font-weight:var(--font-medium);color:var(--text-primary);font-size:var(--text-sm)}
        .sc-status-item{display:flex;justify-content:space-between;align-items:center;padding:var(--space-3) var(--space-4);background:var(--bg-tertiary);border-radius:var(--radius-md);margin-bottom:var(--space-2)}
        .sc-status-item__name{font-size:var(--text-sm);color:var(--text-primary)}
        .sc-status-item__badge{font-size:var(--text-xs);font-weight:var(--font-semibold);color:var(--success);display:inline-flex;align-items:center;gap:var(--space-1)}
        .sc-response-note{text-align:center;margin-top:var(--space-4);font-size:var(--text-sm);color:var(--text-tertiary)}
        [data-theme="light"] .faq-item,[data-theme="light"] .sc-quick-link{background:rgba(255,255,255,0.6);border-color:rgba(200,200,220,0.4)}
        [data-theme="light"] .contact-form-card{background:rgba(255,255,255,0.75);border-color:rgba(200,200,220,0.5)}
        @media(max-width:599px){.sc-quick-links{grid-template-columns:1fr}}
    </style>


        <div class="container" style="max-width:var(--container-md);padding:var(--space-8) var(--space-4)">
            <section class="legal-hero">
                <div class="legal-hero__icon">&#127891;</div>
                <h1>Support Center</h1>
                <p class="legal-hero__subtitle">Find answers, get help, and connect with our team.</p>
            </section>

            <!-- Quick Links -->
            <div class="sc-quick-links">
                <a href="/faq" class="sc-quick-link">
                    <div class="sc-quick-link__icon">&#10067;</div>
                    <div class="sc-quick-link__title">FAQ</div>
                    <div class="sc-quick-link__desc">Browse common questions</div>
                </a>
                <a href="/terms" class="sc-quick-link">
                    <div class="sc-quick-link__icon">&#128220;</div>
                    <div class="sc-quick-link__title">Terms of Service</div>
                    <div class="sc-quick-link__desc">Usage rules &amp; policies</div>
                </a>
                <a href="/privacy" class="sc-quick-link">
                    <div class="sc-quick-link__icon">&#128274;</div>
                    <div class="sc-quick-link__title">Privacy Policy</div>
                    <div class="sc-quick-link__desc">How we handle your data</div>
                </a>
            </div>

            <!-- Tabs -->
            <div class="sc-tabs" id="sc-tabs">
                <button class="sc-tab sc-tab--active" data-panel="faq">&#10067; FAQ</button>
                <button class="sc-tab" data-panel="contact">&#128236; Contact Us</button>
                <button class="sc-tab" data-panel="status">&#128994; Status</button>
            </div>

            <!-- FAQ Panel -->
            <div class="sc-panel sc-panel--active" id="panel-faq">
                <div class="sc-search">
                    <span class="sc-search__icon">&#128269;</span>
                    <input type="text" class="form-input" id="faq-search" placeholder="Search FAQ..." style="padding-left:40px">
                </div>
                <div id="sc-faq-list"></div>
            </div>

            <!-- Contact Panel -->
            <div class="sc-panel" id="panel-contact">
                <div class="contact-form-card">
                    <h2 style="margin-bottom:var(--space-2);text-align:center;color:var(--text-primary)">Send Us a Message</h2>
                    <p style="text-align:center;color:var(--text-tertiary);font-size:var(--text-sm);margin-bottom:var(--space-6)">Fill out the form and we will respond within 24&ndash;48 hours.</p>

                    <div class="form-group">
                        <label class="form-label" for="sc-contact-name">Name</label>
                        <input type="text" class="form-input" id="sc-contact-name" placeholder="Your full name" maxlength="100">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="sc-contact-email">Email</label>
                        <input type="email" class="form-input" id="sc-contact-email" placeholder="your@email.com" maxlength="200">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="sc-contact-subject">Subject</label>
                        <select class="form-select" id="sc-contact-subject">
                            <option value="general">General Inquiry</option>
                            <option value="support">Technical Support</option>
                            <option value="report">Report an Issue</option>
                            <option value="partnership">Partnership / Advertising</option>
                            <option value="feature">Feature Request</option>
                            <option value="billing">Billing &amp; Payments</option>
                            <option value="account">Account &amp; Privacy</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="sc-contact-message">Message</label>
                        <textarea class="form-textarea" id="sc-contact-message" placeholder="Describe your question or issue in detail..." maxlength="2000" style="min-height:140px"></textarea>
                    </div>
                    <div class="form-group" id="sc-turnstile-wrapper" style="display:none"><div id="sc-turnstile-widget"></div></div>
                    <button class="btn btn-primary btn-full" id="sc-contact-submit">&#128232; Send Message</button>
                    <p class="sc-response-note">For urgent issues, please include &ldquo;URGENT&rdquo; in your message.</p>
                </div>
            </div>

            <!-- Status Panel -->
            <div class="sc-panel" id="panel-status">
                <div class="glass-card" style="text-align:center">
                    <div style="font-size:var(--text-5xl);margin-bottom:var(--space-3)">&#128994;</div>
                    <h2 style="color:var(--text-primary);margin-bottom:var(--space-2)">All Systems Operational</h2>
                    <p style="color:var(--text-secondary);margin-bottom:var(--space-6)">All GroupsMix services are running normally. No known issues.</p>
                    <div style="max-width:460px;margin:0 auto">
                        <div class="sc-status-item">
                            <span class="sc-status-item__name">Website &amp; Frontend</span>
                            <span class="sc-status-item__badge">&#9679; Operational</span>
                        </div>
                        <div class="sc-status-item">
                            <span class="sc-status-item__name">API &amp; Database</span>
                            <span class="sc-status-item__badge">&#9679; Operational</span>
                        </div>
                        <div class="sc-status-item">
                            <span class="sc-status-item__name">Search &amp; Discovery</span>
                            <span class="sc-status-item__badge">&#9679; Operational</span>
                        </div>
                        <div class="sc-status-item">
                            <span class="sc-status-item__name">Payments &amp; Billing</span>
                            <span class="sc-status-item__badge">&#9679; Operational</span>
                        </div>
                        <div class="sc-status-item">
                            <span class="sc-status-item__name">AI Tools &amp; Chatbot</span>
                            <span class="sc-status-item__badge">&#9679; Operational</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        var scFaqs = [
            { q: 'What is GroupsMix?', a: 'GroupsMix is the leading platform for discovering, sharing, and promoting trusted social media groups across platforms like WhatsApp, Telegram, Discord, Facebook, Viber, and more.' },
            { q: 'Do I need an account to browse groups?', a: 'No, you can browse and search groups without an account. However, creating a free account lets you save groups, write reviews, submit your own groups, and earn GXP rewards.' },
            { q: 'How do I submit a group?', a: 'Click "Submit" in the navigation bar, fill in your group details (name, description, category, platform, and invite link), and submit for review. Your group will be reviewed and approved within 24\u201372 hours.' },
            { q: 'Is it free to list my group?', a: 'Yes! Basic listing is completely free. We also offer premium VIP plans for enhanced visibility, badges, and priority placement.' },
            { q: 'How does the trust score work?', a: 'Trust scores are calculated based on multiple factors: verification status, review ratings, report history, account age, and community engagement. Higher scores indicate more trustworthy groups.' },
            { q: 'What are VIP plans?', a: 'VIP plans give your group enhanced visibility with badges, priority placement, and ranking multipliers. Plans range from Verified ($5/mo) to Diamond ($50/mo), each with increasing benefits.' },
            { q: 'What is GXP?', a: 'GXP (GroupsMix Experience Points) is our reputation and rewards system. You earn GXP by submitting groups (+50), writing reviews (+10), reporting scams, and other platform activities. Higher GXP unlocks levels, badges, and exclusive perks.' },
            { q: 'How do I report a suspicious group?', a: "Visit the group's profile page and click the \"Report\" button. Select a reason and provide details. Our team reviews all reports promptly and takes action within 24 hours." },
            { q: 'Are the group links safe to click?', a: 'All group invite links on GroupsMix are encrypted and only revealed after verification checks. Our Scam Wall and behavioral fraud detection systems actively protect users from phishing and malicious links.' },
            { q: 'What payment methods do you accept?', a: 'We accept cryptocurrency (Bitcoin, USDT, Solana) and card payments via LemonSqueezy for VIP plans and services.' },
            { q: 'Can I get a refund?', a: 'Cryptocurrency payments are non-refundable once confirmed on the blockchain. Card payments processed through LemonSqueezy follow their refund policy. VIP subscriptions can be cancelled anytime but prorated refunds are not provided.' },
            { q: 'Can I edit my group after submission?', a: "Currently, you'll need to contact us to make changes to an approved group. We're working on a self-service edit feature that will be available soon." },
            { q: 'How do I delete my account?', a: "Contact us through this Support Center and we'll process your account deletion request within 48 hours. All your personal data will be permanently removed." }
        ];

        document.addEventListener('DOMContentLoaded', function() {
            /* Render FAQ */
            renderFaqList(scFaqs);

            /* Tab switching */
            document.querySelectorAll('.sc-tab').forEach(function(tab) {
                tab.addEventListener('click', function() {
                    document.querySelectorAll('.sc-tab').forEach(function(t){ t.classList.remove('sc-tab--active'); });
                    document.querySelectorAll('.sc-panel').forEach(function(p){ p.classList.remove('sc-panel--active'); });
                    tab.classList.add('sc-tab--active');
                    var panel = document.getElementById('panel-' + tab.dataset.panel);
                    if (panel) panel.classList.add('sc-panel--active');
                });
            });

            /* FAQ search */
            document.getElementById('faq-search').addEventListener('input', function() {
                var q = this.value.toLowerCase().trim();
                if (!q) { renderFaqList(scFaqs); return; }
                var filtered = scFaqs.filter(function(f) {
                    return f.q.toLowerCase().indexOf(q) !== -1 || f.a.toLowerCase().indexOf(q) !== -1;
                });
                renderFaqList(filtered);
            });

            /* Pre-fill contact form */
            var user = Auth.getUser();
            if (user) {
                var nameEl = document.getElementById('sc-contact-name');
                var emailEl = document.getElementById('sc-contact-email');
                if (nameEl && user.display_name) nameEl.value = Security.sanitize(user.display_name);
                if (emailEl && user.email) emailEl.value = Security.sanitize(user.email);
            }

            /* Turnstile CAPTCHA: poll for SDK readiness */
            if (CONFIG.turnstileSiteKey) {
                var _tsAttempts = 0, _tsMaxAttempts = 50; // 50 × 200 ms = 10 s
                var _tsWrap = document.getElementById('sc-turnstile-wrapper');
                if (_tsWrap) _tsWrap.innerHTML = '<div style="text-align:center;padding:var(--space-2);color:var(--text-tertiary);font-size:var(--text-sm)">Loading CAPTCHA\u2026</div>';
                (function pollTurnstile() {
                    if (typeof turnstile !== 'undefined') {
                        document.getElementById('sc-turnstile-wrapper').style.display = '';
                        if (_tsWrap) _tsWrap.innerHTML = '<div id="sc-turnstile-widget"></div>';
                        turnstile.render('#sc-turnstile-widget', {
                            sitekey: CONFIG.turnstileSiteKey,
                            callback: function(token) { window._scTurnstileToken = token; }
                        });
                    } else if (++_tsAttempts < _tsMaxAttempts) {
                        if (_tsWrap) _tsWrap.style.display = '';
                        setTimeout(pollTurnstile, 200);
                    } else {
                        if (_tsWrap) _tsWrap.innerHTML = '<div style="color:var(--text-tertiary);font-size:var(--text-xs);text-align:center">CAPTCHA unavailable \u2014 you may continue</div>';
                        window._scTurnstileToken = 'bypass_sdk_unavailable';
                    }
                })();
            }

            /* Contact submit */
            document.getElementById('sc-contact-submit').addEventListener('click', submitSCContact);
        });

        function renderFaqList(items) {
            var el = document.getElementById('sc-faq-list');
            if (!items.length) {
                el.innerHTML = '<div style="text-align:center;color:var(--text-tertiary);padding:var(--space-6)">No matching questions found</div>';
                return;
            }
            el.innerHTML = items.map(function(f, i) {
                return '<div class="faq-item" data-index="' + i + '"><div class="faq-question">' + Security.sanitize(f.q) + '<span class="faq-arrow">&#9660;</span></div><div class="faq-answer">' + Security.sanitize(f.a) + '</div></div>';
            }).join('');
            el.querySelectorAll('.faq-item').forEach(function(item) {
                item.querySelector('.faq-question').addEventListener('click', function() {
                    item.classList.toggle('open');
                });
            });
        }

        async function submitSCContact() {
            var name = Security.sanitize(document.getElementById('sc-contact-name').value.trim());
            var email = document.getElementById('sc-contact-email').value.trim();
            var subject = document.getElementById('sc-contact-subject').value;
            var message = Security.sanitize(document.getElementById('sc-contact-message').value.trim());

            if (!name) { UI.toast('Please enter your name', 'error'); return; }
            if (!email || !Security.isValidEmail(email)) { UI.toast('Please enter a valid email', 'error'); return; }
            if (!message || message.length < 10) { UI.toast('Please enter a message (at least 10 characters)', 'error'); return; }
            if (CONFIG.turnstileSiteKey && !window._scTurnstileToken) { UI.toast('Please complete the CAPTCHA verification.', 'error'); return; }

            var btn = document.getElementById('sc-contact-submit');
            btn.disabled = true;
            btn.innerHTML = '<span class="btn-spinner"></span> Sending...';

            /* Server-side validation (rate limit + email + Turnstile) */
            var sv = await Security.serverValidate({ email: email, turnstileToken: window._scTurnstileToken || null, action: 'contact' });
            if (!sv.ok) { UI.toast(sv.errors?.[0] || 'Validation failed.', 'error'); btn.disabled = false; btn.innerHTML = '&#128232; Send Message'; return; }

            try {
                var result = await window.supabaseClient.from('contacts').insert({
                    name: name, email: email, subject: subject, message: message
                });
                if (result.error) throw result.error;
                UI.toast('Message sent! We will respond within 24-48 hours.', 'success');
                document.getElementById('sc-contact-message').value = '';
            } catch (err) {
                console.error('Support contact:', err);
                UI.toast('Failed to send. Please try again.', 'error');
            }
            btn.disabled = false;
            btn.innerHTML = '&#128232; Send Message';
        }
    </script>
</Fragment>
</BaseLayout>
