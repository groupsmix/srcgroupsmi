        // Scroll-based animations
        function initScrollAnimations() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.animate-on-scroll').forEach(el => {
                observer.observe(el);
            });
        }

        // Header scroll effect
        function initHeaderScroll() {
            const header = document.getElementById('site-header');
            if (!header) return;
            let ticking = false;
            window.addEventListener('scroll', () => {
                if (!ticking) {
                    window.requestAnimationFrame(() => {
                        if (window.scrollY > 50) {
                            header.classList.add('scrolled');
                        } else {
                            header.classList.remove('scrolled');
                        }
                        ticking = false;
                    });
                    ticking = true;
                }
            });
        }

        async function initPage() {
            renderPlatforms();
            renderCategories();
            renderCountryRibbon();
            renderPlatformRibbon();
            const timeout = setTimeout(() => {
                UI.timeoutState('trending-groups');
                UI.timeoutState('new-groups');
            }, CONFIG.timeoutDuration);
            // Use Promise.allSettled so one failure doesn't crash all sections
            const results = await Promise.allSettled([
                DB.groups.getFeatured(),
                DB.groups.getTrending(),
                DB.groups.getNew(),
                DB.stats.getGlobal()
            ]);
            clearTimeout(timeout);
            const featured = results[0].status === 'fulfilled' ? results[0].value : null;
            const trending = results[1].status === 'fulfilled' ? results[1].value : null;
            const newGroups = results[2].status === 'fulfilled' ? results[2].value : null;
            const stats = results[3].status === 'fulfilled' ? results[3].value : null;
            // Featured groups
            if (featured && featured.length > 0) {
                document.getElementById('featured-section').style.display = '';
                const fc = document.getElementById('featured-groups');
                if (fc) fc.innerHTML = featured.map(g => '<div>' + UI.groupCard(g) + '</div>').join('');
            }
            // Trending groups
            if (trending) {
                if (trending.length > 0) {
                    UI.groupGrid(trending, 'trending-groups');
                } else {
                    UI.emptyState('trending-groups', ICONS.inbox, 'No trending groups yet', 'Groups will appear here once they are approved.', 'Submit a Group', '/submit');
                }
            } else {
                UI.errorState('trending-groups', () => initPage());
            }
            // New groups
            if (newGroups) {
                if (newGroups.length > 0) {
                    UI.groupGrid(newGroups, 'new-groups');
                } else {
                    UI.emptyState('new-groups', ICONS.inbox, 'No groups added yet', 'Be the first to submit a group!', 'Submit a Group', '/submit');
                }
            } else {
                UI.errorState('new-groups', () => initPage());
            }
            // Stats
            renderStats(stats);
            // Articles
            renderArticles();
            // ── New Preview Sections (non-blocking, parallel) ──
            loadMarketplacePreview();
            loadJobsPreview();
            loadStorePreview();
            // ── Group of the Day (non-blocking) ──
            loadGroupOfTheDay();
        }

