const _recentIcon = '<svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>';
---
<BaseLayout
  title="GroupsMix — Discover Trusted Social Media Groups"
  description="Find, join, and promote the best WhatsApp, Telegram, Discord groups and more. Verified communities with trust scores."
  canonical="https://groupsmix.com/"
  ogTitle="GroupsMix — Discover Trusted Social Media Groups"
  ogDescription="Find, join, and promote the best WhatsApp, Telegram, Discord groups and more. Verified communities with trust scores."
  ogUrl="https://groupsmix.com/"
  twitterTitle="GroupsMix — Discover Trusted Social Media Groups"
  twitterDescription="Find, join, and promote the best WhatsApp, Telegram, Discord groups and more."
  cssFiles={["/assets/css/features.css", "/assets/css/home.css"]}
  includeFeatures={true}
  structuredData={`[{"@context":"https://schema.org","@type":"WebSite","name":"GroupsMix","url":"https://groupsmix.com","description":"Discover Trusted Social Media Groups","potentialAction":{"@type":"SearchAction","target":"https://groupsmix.com/search?q={search_term_string}","query-input":"required name=search_term_string"}},{"@context":"https://schema.org","@type":"Organization","name":"GroupsMix","url":"https://groupsmix.com","logo":"https://groupsmix.com/assets/img/og-default.png","description":"The #1 directory for discovering trusted social media groups across WhatsApp, Telegram, Discord and more.","sameAs":[]},{"@context":"https://schema.org","@type":"ItemList","name":"Trending Groups on GroupsMix","description":"Popular verified social media groups trending on GroupsMix","url":"https://groupsmix.com","numberOfItems":8,"itemListOrder":"https://schema.org/ItemListOrderDescending"}]`}
>


        <div class="container">

            <!-- ─── Hero ──────────────────────────── -->
            <Hero />

            <!-- ─── How It Works & Why GroupsMix (Combined) ────────── -->
            <HowItWorks />

            <!-- Why GroupsMix — trust badges -->
            <TrustFeatures />

            <!-- ─── Trending Groups ───────────────── -->
            <GroupSection id="trending-groups" title="Trending Now" icon={trendingIcon} linkHref="/search?sort=ranking" modifier="home-section--trending" />

            <div class="section-divider"></div>

            <!-- ─── Recently Added Groups ─────────── -->
            <GroupSection id="new-groups" title="Recently Added" icon={recentIcon} linkHref="/search?sort=newest" alt={true} modifier="home-section--recent" />

            <!-- ─── Browse Sections (Tabbed Progressive Disclosure) ────── -->
            <BrowseTabs />

            <!-- ─── AI Group Recommendations (Feature 8) ──── -->
            <div id="ai-recommendations"></div>


            <!-- ─── CTA Banner ────────────────────── -->
            <CtaBanner />

        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            initPage();
            initScrollAnimations();
            initHeaderScroll();
            initScrollArrows();
            initBrowseTabs();
        });

        // Scroll-based animations
        function initScrollAnimations() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.animate-on-scroll').forEach(el => {
                observer.observe(el);
            });
        }

        // Header scroll effect
        function initHeaderScroll() {
            const header = document.getElementById('site-header');
            if (!header) return;
            let ticking = false;
            window.addEventListener('scroll', () => {
                if (!ticking) {
                    window.requestAnimationFrame(() => {
                        if (window.scrollY > 50) {
                            header.classList.add('scrolled');
                        } else {
                            header.classList.remove('scrolled');
                        }
                        ticking = false;
                    });
                    ticking = true;
                }
            });
        }

        async function initPage() {
            renderPlatforms();
            renderCategories();
            renderCountryRibbon();
            renderPlatformRibbon();
            const timeout = setTimeout(() => {
                UI.timeoutState('trending-groups');
                UI.timeoutState('new-groups');
            }, CONFIG.timeoutDuration);
            // Use Promise.allSettled so one failure doesn't crash all sections
            const results = await Promise.allSettled([
                DB.groups.getTrending(),
                DB.groups.getNew()
            ]);
            clearTimeout(timeout);
            const trending = results[0].status === 'fulfilled' ? results[0].value : null;
            const newGroups = results[1].status === 'fulfilled' ? results[1].value : null;
            // Trending groups
            if (trending) {
                if (trending.length > 0) {
                    UI.groupGrid(trending, 'trending-groups');
                } else {
                    UI.emptyState('trending-groups', ICONS.inbox, 'No trending groups yet', 'Groups will appear here once they are approved.', 'Submit a Group', '/submit');
                }
            } else {
                UI.errorState('trending-groups', () => initPage());
            }
            // New groups
            if (newGroups) {
                if (newGroups.length > 0) {
                    UI.groupGrid(newGroups, 'new-groups');
                } else {
                    UI.emptyState('new-groups', ICONS.inbox, 'No groups added yet', 'Be the first to submit a group!', 'Submit a Group', '/submit');
                }
            } else {
                UI.errorState('new-groups', () => initPage());
            }
        }

        function renderPlatforms() {
            const el = document.getElementById('hero-platforms');
            if (!el) return;
            el.innerHTML = CONFIG.platforms.map(p =>
                '<a href="/browse?platform=' + p.id + '" class="hero__platform-btn">' + (p.svgIcon || p.emoji) + ' ' + p.name + '</a>'
            ).join('');
        }

        function renderCategories() {
            const el = document.getElementById('category-ribbon');
            if (!el) return;
            el.innerHTML = CONFIG.categories.map(c =>
                '<a href="/browse?cat=' + c.id + '" class="browse-ribbon__chip">' +
                    '<span class="browse-ribbon__chip-icon">' + c.emoji + '</span>' +
                    '<span class="browse-ribbon__chip-name">' + c.name + '</span>' +
                '</a>'
            ).join('') +
            '<a href="/browse" class="browse-ribbon__chip browse-ribbon__chip--view-all">View All &rarr;</a>';
        }

        function renderCountryRibbon() {
            const el = document.getElementById('country-ribbon');
            if (!el) return;
            el.innerHTML = CONFIG.countries.map(c =>
                '<a href="/browse?country=' + c.code + '" class="browse-ribbon__chip">' +
                    '<span class="browse-ribbon__chip-flag">' + c.flag + '</span>' +
                    '<span class="browse-ribbon__chip-name">' + c.name + '</span>' +
                '</a>'
            ).join('') +
            '<a href="/browse" class="browse-ribbon__chip browse-ribbon__chip--view-all">View All &rarr;</a>';
        }

        function renderPlatformRibbon() {
            const el = document.getElementById('platform-ribbon');
            if (!el) return;
            el.innerHTML = CONFIG.platforms.map(p =>
                '<a href="/browse?platform=' + p.id + '" class="browse-ribbon__chip">' +
                    '<span class="browse-ribbon__chip-icon">' + (p.svgIcon || p.emoji) + '</span>' +
                    '<span class="browse-ribbon__chip-name">' + p.name + '</span>' +
                '</a>'
            ).join('') +
            '<a href="/browse" class="browse-ribbon__chip browse-ribbon__chip--view-all">View All &rarr;</a>';
        }

        async function renderArticles() {
            try {
                var articles = null;
                if (typeof DB !== 'undefined' && DB.articles && DB.articles.getRecent) {
                    articles = await DB.articles.getRecent(3);
                }
                var section = document.getElementById('articles-section');
                var grid = document.getElementById('articles-grid');
                if (!section || !grid) return;
                if (!articles || articles.length === 0) {
                    // Hide section when no articles
                    section.style.display = 'none';
                    return;
                }
                section.style.display = '';
                grid.innerHTML = articles.map(function(a) {
                    var img = a.cover_image || '';
                    var tag = a.category || 'Article';
                    var title = Security.sanitize(a.title || 'Untitled');
                    var excerpt = Security.sanitize(a.excerpt || '');
                    var href = '/article/' + (a.slug || a.id);
                    return '<a href="' + href + '" class="article-card">' +
                        (img ? '<img class="article-card__img" src="' + img + '" alt="' + title + '" loading="lazy">' : '<div class="article-card__img" style="display:flex;align-items:center;justify-content:center;font-size:3rem;">' + ICONS.file_text + '</div>') +
                        '<div class="article-card__body">' +
                            '<span class="article-card__tag">' + tag + '</span>' +
                            '<h3 class="article-card__title">' + title + '</h3>' +
                            '<p class="article-card__excerpt">' + excerpt + '</p>' +
                            '<span class="article-card__btn">Read More <span>→</span></span>' +
                        '</div>' +
                    '</a>';
                }).join('');
            } catch (err) {
                console.error('renderArticles:', err);
                // Hide section on error
                if (section) section.style.display = 'none';
            }
        }

        function buildArticleCard(href, tag, title, excerpt) {
            return '<a href="' + href + '" class="article-card">' +
                '<div class="article-card__img" style="display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg, var(--accent-primary-light), var(--bg-tertiary));">' + ICONS.file_text + '</div>' +
                '<div class="article-card__body">' +
                    '<span class="article-card__tag">' + tag + '</span>' +
                    '<h3 class="article-card__title">' + title + '</h3>' +
                    '<p class="article-card__excerpt">' + excerpt + '</p>' +
                    '<span class="article-card__btn">Read More <span>→</span></span>' +
                '</div>' +
            '</a>';
        }

        // ─── Scroll Arrows Navigation ───
        function initScrollArrows() {
            document.querySelectorAll('.scroll-container').forEach(container => {
                const leftBtn = container.querySelector('.scroll-arrow--left');
                const rightBtn = container.querySelector('.scroll-arrow--right');
                const scrollEl = container.querySelector('.browse-ribbon, .articles-grid, .category-ribbon, .hero__platforms');
                if (!leftBtn || !rightBtn || !scrollEl) return;

                // Calculate scroll amount: width of ~3 items
                function getScrollAmount() {
                    var firstChild = scrollEl.firstElementChild;
                    if (!firstChild) return 300;
                    var itemWidth = firstChild.offsetWidth + 12; // item width + gap
                    return itemWidth * 3;
                }

                leftBtn.addEventListener('click', function() {
                    scrollEl.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
                });

                rightBtn.addEventListener('click', function() {
                    scrollEl.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                });

                // Native CSS scroll-snap handles touch/swipe
            });
        }

        // Removed complex drag-scroll JS — native CSS overflow-x: auto
        // with scroll-snap-type handles touch/swipe on iOS & Android.

        // ═══════════════════════════════════════
        // ── Marketplace Preview Section ────────
        // ═══════════════════════════════════════
        async function loadMarketplacePreview() {
            if (!CONFIG.features.marketplace) return;
            var section = document.getElementById('marketplace-preview-section');
            var grid = document.getElementById('marketplace-preview-grid');
            if (!section || !grid) return;
            try {
                var result = null;
                if (typeof Marketplace !== 'undefined' && Marketplace.getListings) {
                    result = await Marketplace.getListings({ limit: 4, sort: 'newest' });
                }
                if (!result || !result.data || result.data.length === 0) {
                    // Hide section when no live data
                    section.style.display = 'none';
                    return;
                }
                section.style.display = '';
                grid.innerHTML = result.data.map(function(item) {
                    var title = Security.sanitize(item.title || 'Untitled Listing');
                    var platform = Security.sanitize(item.platform || '');
                    var price = item.price ? '$' + parseFloat(item.price).toLocaleString() : 'Contact Seller';
                    var platformIcon = platform ? (getPlatformIcon(platform) || '') : '';
                    var imgUrl = item.image_url ? Security.sanitizeUrl(item.image_url) : '';
                    var imgHtml = imgUrl
                        ? '<img src="' + imgUrl + '" alt="' + title + '" loading="lazy">'
                        : '<span class="mp-card__image-placeholder">' + ICONS.store + '</span>';
                    var typeLabel = platform ? platform.charAt(0).toUpperCase() + platform.slice(1) : 'Listing';
                    return '<a href="/marketplace?id=' + (item.id || '') + '" class="mp-card">' +
                        '<div class="mp-card__image">' + imgHtml +
                            '<span class="mp-card__type-badge">' + platformIcon + ' ' + Security.sanitize(typeLabel) + '</span>' +
                        '</div>' +
                        '<div class="mp-card__body">' +
                            '<div class="mp-card__title">' + title + '</div>' +
                            '<div class="mp-card__price">' + Security.sanitize(price) + '</div>' +
                        '</div>' +
                    '</a>';
                }).join('');
            } catch (err) {
                console.error('loadMarketplacePreview:', err.message);
                // Hide section on error
                section.style.display = 'none';
            }
        }

        function buildMPPlaceholders() {
            var items = [
                { title: 'Social Media Accounts', type: 'Social Media', price: 'Browse Listings' },
                { title: 'YouTube Channels', type: 'Streaming', price: 'Browse Listings' },
                { title: 'Telegram Groups', type: 'Messaging', price: 'Browse Listings' },
                { title: 'Discord Servers', type: 'Messaging', price: 'Browse Listings' }
            ];
            return items.map(function(item) {
                return '<a href="/marketplace" class="mp-card">' +
                    '<div class="mp-card__image">' +
                        '<span class="mp-card__image-placeholder">' + ICONS.store + '</span>' +
                        '<span class="mp-card__type-badge">' + Security.sanitize(item.type) + '</span>' +
                    '</div>' +
                    '<div class="mp-card__body">' +
                        '<div class="mp-card__title">' + Security.sanitize(item.title) + '</div>' +
                        '<div class="mp-card__price">' + Security.sanitize(item.price) + '</div>' +
                    '</div>' +
                '</a>';
            }).join('');
        }

        // ═══════════════════════════════════════
        // ── Jobs Spotlight Section ─────────────
        // ═══════════════════════════════════════
        async function loadJobsPreview() {
            if (!CONFIG.features.jobs) return;
            var section = document.getElementById('jobs-preview-section');
            var grid = document.getElementById('jobs-preview-grid');
            if (!section || !grid) return;
            try {
                var jobs = null;
                // Jobs are fetched directly from Supabase (jobs table)
                if (typeof window.supabaseClient !== 'undefined') {
                    var { data, error } = await window.supabaseClient
                        .from('jobs')
                        .select('id, title, company_name, job_type, location_type, is_remote, salary_min, salary_max, salary_currency, category, ai_category, platform, created_at, is_promoted, region')
                        .eq('status', 'active')
                        .order('created_at', { ascending: false })
                        .limit(3);
                    if (!error && data) jobs = data;
                }
                if (!jobs || jobs.length === 0) {
                    // Hide section when no jobs
                    section.style.display = 'none';
                    return;
                }
                section.style.display = '';
                grid.innerHTML = jobs.map(function(job) {
                    var title = Security.sanitize(job.title || 'Untitled Job');
                    var company = Security.sanitize(job.company_name || 'Anonymous');
                    var cat = job.ai_category || job.category || 'other';
                    var typeLabel = { 'full-time': 'Full-Time', 'part-time': 'Part-Time', 'freelance': 'Freelance', 'contract': 'Contract', 'internship': 'Internship' }[job.job_type] || 'Full-Time';
                    // Location badge
                    var locBadge = '';
                    if (job.location_type === 'remote' || job.is_remote) {
                        locBadge = '<span class="job-prev__badge job-prev__badge--remote">Remote</span>';
                    } else if (job.location_type === 'hybrid') {
                        locBadge = '<span class="job-prev__badge job-prev__badge--hybrid">Hybrid</span>';
                    } else if (job.location_type === 'onsite') {
                        locBadge = '<span class="job-prev__badge job-prev__badge--onsite">On-Site</span>';
                    }
                    // Salary
                    var salary = '';
                    if (job.salary_min || job.salary_max) {
                        var sym = job.salary_currency === 'EUR' ? '\u20AC' : job.salary_currency === 'GBP' ? '\u00A3' : '$';
                        var min = job.salary_min ? sym + (job.salary_min >= 1000 ? Math.round(job.salary_min / 1000) + 'k' : job.salary_min) : '';
                        var max = job.salary_max ? sym + (job.salary_max >= 1000 ? Math.round(job.salary_max / 1000) + 'k' : job.salary_max) : '';
                        salary = min && max ? min + ' - ' + max : (min || max);
                    }
                    // Time ago
                    var timeStr = '';
                    if (job.created_at) {
                        var diff = Math.floor((Date.now() - new Date(job.created_at).getTime()) / 1000);
                        if (diff < 3600) timeStr = Math.max(1, Math.floor(diff / 60)) + 'm ago';
                        else if (diff < 86400) timeStr = Math.floor(diff / 3600) + 'h ago';
                        else if (diff < 604800) timeStr = Math.floor(diff / 86400) + 'd ago';
                        else timeStr = Math.floor(diff / 604800) + 'w ago';
                    }
                    var promoted = job.is_promoted ? '<span class="job-prev__featured">\u2B50 Featured</span>' : '';
                    return '<a href="/jobs?job=' + (job.id || '') + '" class="job-prev-card">' +
                        '<div class="job-prev-card__header">' +
                            '<span class="job-prev__cat job-prev__cat--' + Security.sanitize(cat) + '">' + Security.sanitize(typeLabel) + '</span>' +
                            locBadge + promoted +
                        '</div>' +
                        '<div class="job-prev-card__body">' +
                            '<div class="job-prev-card__title">' + title + '</div>' +
                            '<div class="job-prev-card__company">' + company + '</div>' +
                            (salary ? '<div class="job-prev-card__salary">' + salary + '</div>' : '') +
                        '</div>' +
                        '<div class="job-prev-card__footer">' +
                            (timeStr ? '<span class="job-prev__time">' + timeStr + '</span>' : '') +
                        '</div>' +
                    '</a>';
                }).join('');
            } catch (err) {
                console.error('loadJobsPreview:', err.message);
                // Hide section on error
                section.style.display = 'none';
            }
        }

        function buildJobPlaceholders() {
            var items = [
                { title: 'Community Manager', company: 'Explore Opportunities', type: 'Full-Time', loc: 'remote' },
                { title: 'Discord Moderator', company: 'Browse Open Roles', type: 'Part-Time', loc: 'remote' },
                { title: 'Content Creator', company: 'Find Your Next Role', type: 'Freelance', loc: 'hybrid' }
            ];
            return items.map(function(item) {
                var badgeClass = item.loc === 'remote' ? 'remote' : item.loc === 'hybrid' ? 'hybrid' : 'onsite';
                var badgeLabel = item.loc === 'remote' ? 'Remote' : item.loc === 'hybrid' ? 'Hybrid' : 'On-Site';
                return '<a href="/jobs" class="job-prev-card">' +
                    '<div class="job-prev-card__header">' +
                        '<span class="job-prev__cat">' + item.type + '</span>' +
                        '<span class="job-prev__badge job-prev__badge--' + badgeClass + '">' + badgeLabel + '</span>' +
                    '</div>' +
                    '<div class="job-prev-card__body">' +
                        '<div class="job-prev-card__title">' + item.title + '</div>' +
                        '<div class="job-prev-card__company">' + item.company + '</div>' +
                    '</div>' +
                    '<div class="job-prev-card__footer">' +
                        '<span class="job-prev__time">New</span>' +
                    '</div>' +
                '</a>';
            }).join('');
        }

        // ═══════════════════════════════════════
        // ── Store Highlights Section ───────────
        // ═══════════════════════════════════════
        async function loadStorePreview() {
            if (!CONFIG.features.store) return;
            var section = document.getElementById('store-preview-section');
            var grid = document.getElementById('store-preview-grid');
            if (!section || !grid) return;
            try {
                var products = null;
                // Try fetching from the store API endpoint
                var res = await fetch('/api/lemonsqueezy');
                if (res.ok) {
                    var json = await res.json();
                    if (json.ok && json.products && json.products.length > 0) {
                        products = json.products.slice(0, 4);
                    }
                }
                if (!products || products.length === 0) {
                    // Hide section when no products
                    section.style.display = 'none';
                    return;
                }
                section.style.display = '';
                grid.innerHTML = products.map(function(p) {
                    var name = Security.sanitize(p.name || 'Product');
                    var desc = Security.sanitize((p.description || '').replace(/<[^>]*>/g, '').substring(0, 100));
                    var priceText = (!p.price || p.price === 0) ? 'Free' : (p.price_formatted || ('$' + (p.price / 100).toFixed(2)));
                    var typeLabel = p.product_type || 'digital';
                    var typeName = { guide: 'Guide', template: 'Template', course: 'Course', tool: 'Tool', membership: 'Membership', bundle: 'Bundle', service: 'Service', digital: 'Digital' }[typeLabel] || 'Digital';
                    var imgHtml = '';
                    if (p.large_thumb_url || p.thumb_url) {
                        imgHtml = '<img src="' + Security.sanitizeUrl(p.large_thumb_url || p.thumb_url) + '" alt="' + name + '" loading="lazy">';
                    } else {
                        var iconMap = { guide: '\uD83D\uDCD6', template: '\uD83D\uDCC4', course: '\uD83C\uDF93', tool: '\uD83D\uDEE0', membership: '\u2B50', bundle: '\uD83C\uDF81', service: '\uD83D\uDCBC', digital: '\uD83D\uDCE6' };
                        imgHtml = '<span class="store-prev__placeholder">' + (iconMap[typeLabel] || '\uD83D\uDCE6') + '</span>';
                    }
                    return '<a href="/store" class="store-prev-card">' +
                        '<div class="store-prev-card__image">' + imgHtml +
                            '<span class="store-prev__badge store-prev__badge--' + Security.sanitize(typeLabel) + '">' + Security.sanitize(typeName) + '</span>' +
                        '</div>' +
                        '<div class="store-prev-card__body">' +
                            '<div class="store-prev-card__title">' + name + '</div>' +
                            (desc ? '<div class="store-prev-card__desc">' + desc + '</div>' : '') +
                        '</div>' +
                        '<div class="store-prev-card__footer">' +
                            '<span class="store-prev__price">' + Security.sanitize(priceText) + '</span>' +
                            '<span class="store-prev__buy">' + ICONS.shopping_cart + ' View</span>' +
                        '</div>' +
                    '</a>';
                }).join('');
            } catch (err) {
                console.error('loadStorePreview:', err.message);
                // Hide section on error
                section.style.display = 'none';
            }
        }

        function buildStorePlaceholders() {
            var items = [
                { name: 'Community Growth Guide', type: 'guide', price: 'Browse Products' },
                { name: 'Moderation Templates', type: 'template', price: 'Browse Products' },
                { name: 'Group Management Course', type: 'course', price: 'Browse Products' },
                { name: 'Analytics Toolkit', type: 'tool', price: 'Browse Products' }
            ];
            var iconMap = { guide: '\uD83D\uDCD6', template: '\uD83D\uDCC4', course: '\uD83C\uDF93', tool: '\uD83D\uDEE0' };
            var nameMap = { guide: 'Guide', template: 'Template', course: 'Course', tool: 'Tool' };
            return items.map(function(item) {
                return '<a href="/store" class="store-prev-card">' +
                    '<div class="store-prev-card__image">' +
                        '<span class="store-prev__placeholder">' + (iconMap[item.type] || '\uD83D\uDCE6') + '</span>' +
                        '<span class="store-prev__badge store-prev__badge--' + item.type + '">' + (nameMap[item.type] || 'Digital') + '</span>' +
                    '</div>' +
                    '<div class="store-prev-card__body">' +
                        '<div class="store-prev-card__title">' + item.name + '</div>' +
                    '</div>' +
                    '<div class="store-prev-card__footer">' +
                        '<span class="store-prev__price">' + item.price + '</span>' +
                        '<span class="store-prev__buy">' + ICONS.shopping_cart + ' View</span>' +
                    '</div>' +
                '</a>';
            }).join('');
        }

        // ═══════════════════════════════════════
        // ── Group of the Day Section ─────────
        // ═══════════════════════════════════════
        async function loadGroupOfTheDay() {
            var section = document.getElementById('gotd-section');
            var card = document.getElementById('gotd-card');
            if (!section || !card) return;
            try {
                // Try to get today's featured group from group_of_the_day table
                var today = new Date().toISOString().split('T')[0];
                var { data: gotdData } = await window.supabaseClient
                    .from('group_of_the_day')
                    .select('group_id')
                    .eq('featured_date', today)
                    .limit(1);

                var groupId = null;
                if (gotdData && gotdData.length > 0) {
                    groupId = gotdData[0].group_id;
                }

                // If no GOTD selected, pick the top trending group
                var group = null;
                if (groupId) {
                    group = await DB.groups.getOne(groupId);
                }
                if (!group) {
                    // Fallback: use the top trending group
                    var trending = await DB.groups.getTrending(1);
                    if (trending && trending.length > 0) group = trending[0];
                }

                if (!group) { section.style.display = 'none'; return; }

                section.style.display = '';
                var trustScore = typeof Algorithms !== 'undefined' ? Algorithms.calculateTrustScore(group) : 0;
                var platform = CONFIG.platforms.find(function(p) { return p.id === group.platform; });
                card.innerHTML =
                    '<a href="/group?id=' + group.id + '" style="text-decoration:none;color:inherit;display:block">' +
                    '<div style="background:linear-gradient(135deg,var(--accent-primary),#9c27b0);border-radius:var(--radius-xl);padding:var(--space-6);color:#fff;position:relative;overflow:hidden">' +
                    '<div style="position:absolute;top:0;right:0;width:120px;height:120px;background:rgba(255,255,255,0.1);border-radius:0 0 0 100%;pointer-events:none"></div>' +
                    '<div style="display:flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-3)">' +
                    '<span style="font-size:var(--text-2xl)">&#127942;</span>' +
                    '<span style="font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.1em;opacity:0.9">Group of the Day</span>' +
                    '</div>' +
                    '<div style="font-size:var(--text-xl);font-weight:var(--font-bold);margin-bottom:var(--space-2)">' + Security.sanitize(group.name || 'Group') + '</div>' +
                    '<div style="font-size:var(--text-sm);opacity:0.85;margin-bottom:var(--space-3);max-width:500px">' + Security.sanitize((group.description || '').slice(0, 120)) + '</div>' +
                    '<div style="display:flex;gap:var(--space-4);font-size:var(--text-xs);opacity:0.8">' +
                    '<span>' + (platform ? Security.sanitize(platform.name) : Security.sanitize(group.platform || '')) + '</span>' +
                    '<span>&#128101; ' + UI.formatNumber(group.members_count || 0) + ' members</span>' +
                    '<span>&#128737; ' + trustScore + '% trust</span>' +
                    '<span>&#11088; ' + (parseFloat(group.avg_rating) || 0).toFixed(1) + ' rating</span>' +
                    '</div>' +
                    '</div></a>';
            } catch (err) {
                console.error('loadGroupOfTheDay:', err.message);
                section.style.display = 'none';
            }
        }

        // ─── Browse Tabs (Progressive Disclosure) ───
        function initBrowseTabs() {
            var tabContainer = document.getElementById('browse-tabs');
            if (!tabContainer) return;
            var buttons = tabContainer.querySelectorAll('.browse-tabs__btn');
            buttons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var tab = btn.getAttribute('data-tab');
                    // Update active button
                    buttons.forEach(function(b) {
                        b.classList.remove('browse-tabs__btn--active');
                        b.setAttribute('aria-selected', 'false');
                    });
                    btn.classList.add('browse-tabs__btn--active');
                    btn.setAttribute('aria-selected', 'true');
                    // Update active panel
                    document.querySelectorAll('.browse-tab-panel').forEach(function(panel) {
                        panel.classList.remove('browse-tab-panel--active');
                    });
                    var activePanel = document.getElementById('panel-' + tab);
                    if (activePanel) activePanel.classList.add('browse-tab-panel--active');
                    // Re-initialize scroll arrows for newly visible panel
                    initScrollArrows();
                });
            });
        }

        function renderStats(stats) {
            const el = document.getElementById('hero-stats');
            if (!el) return;
            var groups = (stats && stats.total_groups) || 0;
            var users = (stats && stats.total_users) || 0;

            // Build display values — show engaging placeholders for zero/empty
            var groupsDisplay = (groups && groups > 0) ? groups : '<span class="stats-bar__placeholder">Growing...</span>';
            var usersDisplay = (users && users > 0) ? users : '<span class="stats-bar__placeholder">Join us!</span>';
            var groupsLabel = (groups && groups > 0) ? 'Groups' : 'Groups &middot; <a href="/submit" style="color:var(--accent-primary);text-decoration:none;font-weight:600">Be first!</a>';
            var usersLabel = (users && users > 0) ? 'Users' : 'Users &middot; <a href="/submit" style="color:var(--accent-primary);text-decoration:none;font-weight:600">Sign up</a>';

            el.innerHTML =
                '<div class="stats-bar__item">' +
                    '<div class="stats-bar__icon stats-bar__icon--groups"><svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>' +
                    '<div class="stats-bar__info">' +
                        '<div class="stats-bar__value" id="stat-groups">' + groupsDisplay + '</div>' +
                        '<div class="stats-bar__label">' + groupsLabel + '</div>' +
                    '</div>' +
                '</div>' +
                '<div class="stats-bar__item">' +
                    '<div class="stats-bar__icon stats-bar__icon--users"><svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></div>' +
                    '<div class="stats-bar__info">' +
                        '<div class="stats-bar__value" id="stat-users">' + usersDisplay + '</div>' +
                        '<div class="stats-bar__label">' + usersLabel + '</div>' +
                    '</div>' +
                '</div>';

            // Only animate count-up when there are actual numbers
            if (groups > 0 || users > 0) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            if (groups > 0) UI.countUp(document.getElementById('stat-groups'), groups);
                            if (users > 0) UI.countUp(document.getElementById('stat-users'), users);
                            observer.disconnect();
                        }
                    });
                }, { threshold: 0.3 });
                observer.observe(el);
            }
        }
    </script>
</Fragment>
</BaseLayout>
