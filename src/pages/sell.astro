---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Sell a Product — GroupsMix Digital Products Marketplace"
  description="List your digital product for sale on GroupsMix Marketplace. Telegram bot templates, group management scripts, design assets, automation workflows, and community growth guides."
>
<style is:inline>
        .sell-page {
            max-width: var(--container-md);
            margin: 0 auto;
            padding: var(--space-8) var(--space-4);
        }
        .sell-card {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-xl);
            padding: var(--space-8);
        }
        .sell-steps {
            display: flex;
            gap: var(--space-4);
            margin-bottom: var(--space-8);
        }
        .sell-steps > * + * { margin-left: var(--space-4); }
        @supports (gap: 1px) { .sell-steps > * + * { margin-left: 0; } }
        .sell-step {
            flex: 1;
            text-align: center;
            padding: var(--space-3);
            border-radius: var(--radius-md);
            background: var(--bg-tertiary);
            color: var(--text-tertiary);
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
        }
        .sell-step--active {
            background: var(--accent-primary);
            color: #fff;
        }
        .sell-step--done {
            background: var(--success-light);
            color: var(--success);
        }
        .sell-preview {
            background: var(--bg-tertiary);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            margin-top: var(--space-6);
        }
        .sell-preview__row {
            display: flex;
            justify-content: space-between;
            padding: var(--space-2) 0;
            border-bottom: 1px solid var(--border-primary);
            font-size: var(--text-sm);
        }
        .sell-preview__row:last-child { border-bottom: none; }
        .sell-preview__label { color: var(--text-tertiary); }
        .sell-preview__value { color: var(--text-primary); font-weight: var(--font-semibold); }
        /* Category selector */
        .category-selector {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-2);
            margin-bottom: var(--space-4);
        }
        .category-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-4) var(--space-2);
            border: 2px solid var(--border-primary);
            border-radius: var(--radius-lg);
            background: var(--bg-tertiary);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
            transition: all 0.2s ease;
        }
        .category-btn:hover {
            border-color: var(--accent-primary);
            color: var(--text-primary);
            transform: translateY(-1px);
        }
        .category-btn--active {
            border-color: var(--accent-primary);
            background: var(--accent-primary-light, rgba(99,102,241,0.08));
            color: var(--accent-primary);
        }
        .category-btn svg {
            width: 32px;
            height: 32px;
        }
        .sell-verification-banner {
            padding: var(--space-4);
            border-radius: var(--radius-lg);
            margin-bottom: var(--space-6);
            font-size: var(--text-sm);
            line-height: 1.6;
        }
        .sell-verification-banner--ok {
            background: var(--success-light);
            color: var(--success);
            border: 1px solid var(--success);
        }
        .sell-verification-banner--error {
            background: var(--error-light);
            color: var(--error);
            border: 1px solid var(--error);
        }
        .sell-trust-info {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            margin-bottom: var(--space-6);
            font-size: var(--text-sm);
            color: var(--text-secondary);
            line-height: 1.6;
        }
        .sell-trust-info strong {
            color: var(--text-primary);
        }
        .ai-checking {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-3);
            background: var(--info-light);
            color: var(--info);
            border-radius: var(--radius-md);
            font-size: var(--text-sm);
            margin-bottom: var(--space-4);
        }
        .ai-checking .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid currentColor;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        @media (max-width: 640px) {
            .sell-steps { flex-direction: column; }
            .sell-card { padding: var(--space-4); }
            .category-selector { grid-template-columns: repeat(2, 1fr); }
            .platform-selector { grid-template-columns: repeat(3, 1fr); }
        }
        /* ─── Smart Pricing Suggestion ─── */
        .sell-pricing-hint {
            background: var(--info-light);
            border: 1px solid var(--info);
            border-radius: var(--radius-md);
            padding: var(--space-3);
            margin-top: var(--space-2);
            font-size: var(--text-sm);
            color: var(--info);
            display: flex;
            align-items: center;
            gap: var(--space-2);
            transition: opacity 0.3s;
        }
        .sell-pricing-hint svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }
        /* ─── Listing Quality Score ─── */
        .sell-quality {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            margin-bottom: var(--space-4);
        }
        .sell-quality__header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: var(--space-3);
        }
        .sell-quality__label {
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
        }
        .sell-quality__grade {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: var(--radius-full);
            font-size: var(--text-sm);
            font-weight: var(--font-bold);
            color: #fff;
        }
        .sell-quality__bar {
            height: 8px;
            background: var(--bg-secondary);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: var(--space-3);
        }
        .sell-quality__fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s ease, background-color 0.5s ease;
        }
        .sell-quality__tips {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .sell-quality__tip {
            display: flex;
            align-items: flex-start;
            gap: var(--space-2);
            font-size: var(--text-xs);
            color: var(--text-secondary);
            padding: var(--space-1) 0;
        }
        .sell-quality__tip svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
            color: var(--warning);
            margin-top: 1px;
        }
    </style>


        <div class="sell-page">
            <h1 style="text-align:center;margin-bottom:var(--space-2)">
                <svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1.2em;height:1.2em;vertical-align:-0.125em"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
                Sell a Product
            </h1>
            <p style="text-align:center;color:var(--text-secondary);margin-bottom:var(--space-8)">List your digital product — Telegram bot templates, group management scripts, design assets, automation workflows, premium rule packs &amp; community growth guides</p>

            <div class="sell-steps" id="sell-steps">
                <div class="sell-step sell-step--active" id="sell-step-1">1. Details</div>
                <div class="sell-step" id="sell-step-2">2. Preview</div>
                <div class="sell-step" id="sell-step-3">3. Done</div>
            </div>

            <div class="sell-card">
                <form id="sell-form" novalidate>
                    <!-- Step 1: Details -->
                    <div id="sell-s1">
                        <div id="sell-verification-status"></div>
                        <div class="sell-trust-info">
                            <strong>Trusted Marketplace</strong><br>
                            All listings are scanned by AI before going live. Payments use escrow (buyer confirms delivery before seller gets coins). Buyers can dispute within 24h if product doesn't match description.
                        </div>
                        <div class="form-group">
                            <label class="form-label">Product Category *</label>
                            <div class="category-selector" id="category-selector"></div>
                            <input type="hidden" id="sell-category" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="sell-title">Title *</label>
                            <input type="text" class="form-input" id="sell-title" placeholder="e.g. Telegram Bot Template — Auto-Welcome & Moderation" required minlength="5" maxlength="100">
                            <div class="form-help">5–100 characters. Describe your digital product.</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="sell-description">Description *</label>
                            <textarea class="form-textarea" id="sell-description" placeholder="Describe your product in detail — features, what's included, how to use it, etc." required minlength="20" maxlength="1000" rows="4"></textarea>
                            <div class="form-help"><span id="sell-desc-count">0</span>/1000 characters</div>
                        </div>
                        <!-- Listing Quality Score -->
                        <div class="sell-quality" id="sell-quality" style="display:none">
                            <div class="sell-quality__header">
                                <span class="sell-quality__label">Listing Quality</span>
                                <span class="sell-quality__grade" id="sell-quality-grade">--</span>
                            </div>
                            <div class="sell-quality__bar">
                                <div class="sell-quality__fill" id="sell-quality-fill" style="width:0%"></div>
                            </div>
                            <ul class="sell-quality__tips" id="sell-quality-tips"></ul>
                        </div>

                        <div class="form-row">
                            <div class="form-group" style="flex:1">
                                <label class="form-label" for="sell-price">Price (GMX Coins) *</label>
                                <input type="number" class="form-input" id="sell-price" placeholder="50" min="1" step="1" required>
                                <div class="form-help">Set price in GMX Coins. Buyers pay with coins, you receive earned coins (cashout-able with manual review).</div>
                                <div id="sell-pricing-hint"></div>
                            </div>
                            <div class="form-group" style="flex:1">
                                <label class="form-label" for="sell-contact">Contact Link *</label>
                                <input type="url" class="form-input" id="sell-contact" placeholder="https://t.me/yourusername" required>
                                <div class="form-help">How buyers can reach you for delivery</div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="sell-delivery-url">Digital Delivery</label>
                            <input type="url" class="form-input" id="sell-delivery-url" placeholder="https://drive.google.com/file/d/... or download link">
                            <div class="form-help">Provide a download link (Google Drive, Dropbox, etc.) for the file buyers receive after purchase. You can also upload a file (zip, pdf, etc.) after listing.</div>
                        </div>
                        <div id="sell-ai-status"></div>
                        <button type="button" class="btn btn-primary btn-full" id="sell-next-btn">Preview Listing</button>
                    </div>

                    <!-- Step 2: Preview -->
                    <div id="sell-s2" class="hidden">
                        <h3 style="margin-bottom:var(--space-4)">Preview Your Listing</h3>
                        <div class="sell-preview" id="sell-preview-content"></div>
                        <div style="display:flex;gap:var(--space-3);margin-top:var(--space-6)">
                            <button type="button" class="btn btn-secondary" id="sell-back-btn" style="flex:1">Back</button>
                            <button type="submit" class="btn btn-primary" id="sell-submit-btn" style="flex:2">Publish Listing</button>
                        </div>
                    </div>

                    <!-- Step 3: Done -->
                    <div id="sell-s3" class="hidden">
                        <div style="text-align:center;padding:var(--space-8) 0">
                            <div style="font-size:var(--text-4xl);margin-bottom:var(--space-4)">
                                <svg class="svg-icon svg-icon--xl" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:2em;height:2em;color:var(--success)"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            </div>
                            <h2>Listing Submitted!</h2>
                            <p style="color:var(--text-secondary);margin:var(--space-4) 0">Your product listing is being reviewed by our AI trust system. It will go live once approved.</p>
                            <div style="display:flex;gap:var(--space-3);justify-content:center;margin-top:var(--space-6)">
                                <a href="/sell" class="btn btn-secondary">List Another Product</a>
                                <a href="/marketplace" class="btn btn-primary">View Marketplace</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    document.addEventListener('DOMContentLoaded', initSellPage);

    var sellData = { platform: '', category: '', title: '', description: '', price: 0, contact_link: '', delivery_url: '', currency: 'coins' };

    async function initSellPage() {
        // Require authentication
        await Auth.waitForAuth();
        if (!Auth.requireAuth()) return;

        // Feature 1: Check seller verification status
        await checkAndShowVerification();

        renderCategorySelector();
        document.getElementById('sell-description').addEventListener('input', function() {
            document.getElementById('sell-desc-count').textContent = this.value.length;
            updateQualityScore();
        });
        document.getElementById('sell-title').addEventListener('input', updateQualityScore);
        document.getElementById('sell-price').addEventListener('input', updateQualityScore);
        var deliveryEl = document.getElementById('sell-delivery-url');
        if (deliveryEl) deliveryEl.addEventListener('input', updateQualityScore);
        document.getElementById('sell-next-btn').addEventListener('click', goToPreview);
        document.getElementById('sell-back-btn').addEventListener('click', goBack);
        document.getElementById('sell-form').addEventListener('submit', submitListing);
    }

    async function checkAndShowVerification() {
        var statusEl = document.getElementById('sell-verification-status');
        if (!statusEl) return;
        var result = await Marketplace.checkSellerVerification();
        if (result.verified) {
            statusEl.innerHTML = '<div class="sell-verification-banner sell-verification-banner--ok">' +
                '<svg style="width:16px;height:16px;vertical-align:-2px;margin-right:4px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>' +
                '<strong>Verified Seller</strong> &mdash; Your email and phone are verified. You can list products.</div>';
        } else {
            statusEl.innerHTML = '<div class="sell-verification-banner sell-verification-banner--error">' +
                '<svg style="width:16px;height:16px;vertical-align:-2px;margin-right:4px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>' +
                '<strong>Verification Required</strong> &mdash; ' + Security.sanitize(result.reason) +
                ' <a href="/settings" style="color:inherit;text-decoration:underline;font-weight:600">Go to Settings</a></div>';
            // Disable the submit button
            var nextBtn = document.getElementById('sell-next-btn');
            if (nextBtn) { nextBtn.disabled = true; nextBtn.style.opacity = '0.5'; }
        }
    }

    // ─── Smart Pricing Suggestions ───
    async function loadPricingSuggestion(category) {
        var hintEl = document.getElementById('sell-pricing-hint');
        if (!hintEl) return;
        if (!category) { hintEl.innerHTML = ''; return; }
        var pricing = await Marketplace.getSimilarPricing(category);
        if (!pricing || !pricing.count || pricing.count < 2) {
            hintEl.innerHTML = '';
            return;
        }
        hintEl.innerHTML = '<div class="sell-pricing-hint">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>' +
            '<span>' + Security.sanitize(pricing.suggestion) + ' (median: ' + pricing.median + ' GMX)</span>' +
            '</div>';
    }

    // ─── Listing Quality Score ───
    function updateQualityScore() {
        var title = (document.getElementById('sell-title').value || '').trim();
        var description = (document.getElementById('sell-description').value || '').trim();
        var price = parseInt(document.getElementById('sell-price').value) || 0;
        var category = (document.getElementById('sell-category').value || '');
        var deliveryUrl = '';
        var delEl = document.getElementById('sell-delivery-url');
        if (delEl) deliveryUrl = delEl.value.trim();

        // Only show after some input
        if (!title && !description) {
            document.getElementById('sell-quality').style.display = 'none';
            return;
        }

        var result = Marketplace.getListingQualityScore({
            title: title, description: description, price: price,
            category: category, delivery_url: deliveryUrl
        });

        var qualityEl = document.getElementById('sell-quality');
        qualityEl.style.display = '';

        // Grade badge color
        var gradeEl = document.getElementById('sell-quality-grade');
        var gradeColors = { 'A+': '#10b981', 'A': '#10b981', 'B': '#3b82f6', 'C': '#f59e0b', 'D': '#f97316', 'F': '#ef4444' };
        gradeEl.textContent = result.grade;
        gradeEl.style.background = gradeColors[result.grade] || '#9ca3af';

        // Progress bar
        var fillEl = document.getElementById('sell-quality-fill');
        fillEl.style.width = result.score + '%';
        fillEl.style.background = gradeColors[result.grade] || '#9ca3af';

        // Tips
        var tipsEl = document.getElementById('sell-quality-tips');
        if (result.tips.length > 0) {
            tipsEl.innerHTML = result.tips.map(function(tip) {
                return '<li class="sell-quality__tip">' +
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' +
                    '<span>' + Security.sanitize(tip) + '</span></li>';
            }).join('');
        } else {
            tipsEl.innerHTML = '<li class="sell-quality__tip" style="color:var(--success)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Great listing! All quality checks passed.</span></li>';
        }
    }

    function renderCategorySelector() {
        var container = document.getElementById('category-selector');
        if (!container) return;
        var categories = Marketplace.getCategories();
        container.innerHTML = categories.map(function(cat) {
            return '<button type="button" class="category-btn" data-category="' + cat.id + '">' +
                cat.icon +
                '<span>' + cat.name + '</span>' +
                '</button>';
        }).join('');
        container.querySelectorAll('.category-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                container.querySelectorAll('.category-btn').forEach(function(b) { b.classList.remove('category-btn--active'); });
                btn.classList.add('category-btn--active');
                var catId = btn.dataset.category;
                document.getElementById('sell-category').value = catId;
                sellData.category = catId;
                loadPricingSuggestion(catId);
                updateQualityScore();
            });
        });
    }

    async function goToPreview() {
        // Validate fields
        var category = document.getElementById('sell-category').value;
        var title = document.getElementById('sell-title').value.trim();
        var description = document.getElementById('sell-description').value.trim();
        var price = document.getElementById('sell-price').value;
        var contact = document.getElementById('sell-contact').value.trim();

        if (!category) { UI.toast('Please select a product category', 'error'); return; }
        if (!Marketplace.isValidCategory(category)) { UI.toast('Please select a valid product category', 'error'); return; }
        if (!title || title.length < 5) { UI.toast('Title must be at least 5 characters', 'error'); return; }
        if (!description || description.length < 20) { UI.toast('Description must be at least 20 characters', 'error'); return; }
        if (!contact) { UI.toast('Please provide a contact link', 'error'); return; }

        // Feature 5: Client-side banned keywords check
        var titleBanned = Marketplace.checkBannedKeywords(title);
        if (titleBanned.banned) {
            UI.toast('Title contains banned keyword "' + titleBanned.keyword + '". Please remove it.', 'error');
            return;
        }
        var descBanned = Marketplace.checkBannedKeywords(description);
        if (descBanned.banned) {
            UI.toast('Description contains banned keyword "' + descBanned.keyword + '". Please remove it.', 'error');
            return;
        }

        var aiStatus = document.getElementById('sell-ai-status');

        // Feature 3: AI auto-scan on listing
        aiStatus.innerHTML = '<div class="ai-checking"><div class="spinner"></div> Scanning listing with AI trust filter...</div>';

        var validation = await Marketplace.validateWithAI(title, description);
        if (!validation.valid) {
            aiStatus.innerHTML = '';
            UI.toast(validation.message || 'Listing did not pass AI review. Please revise your content.', 'error');
            return;
        }
        aiStatus.innerHTML = '';

        // Store data
        sellData.category = category;
        sellData.title = title;
        sellData.description = description;
        sellData.price = parseInt(price) || 0;
        sellData.contact_link = contact;
        sellData.delivery_url = (document.getElementById('sell-delivery-url') || {}).value.trim();
        sellData.currency = 'coins';

        // Render preview
        var preview = document.getElementById('sell-preview-content');
        var categoryName = category.charAt(0).toUpperCase() + category.slice(1).replace('_', ' ');
        preview.innerHTML =
            '<div class="sell-preview__row"><span class="sell-preview__label">Category</span><span class="sell-preview__value">' + Security.sanitize(categoryName) + '</span></div>' +
            '<div class="sell-preview__row"><span class="sell-preview__label">Title</span><span class="sell-preview__value">' + Security.sanitize(title) + '</span></div>' +
            '<div class="sell-preview__row"><span class="sell-preview__label">Description</span><span class="sell-preview__value">' + Security.sanitize(description) + '</span></div>' +
            '<div class="sell-preview__row"><span class="sell-preview__label">Price</span><span class="sell-preview__value">' + sellData.price + ' GMX Coins</span></div>' +
            '<div class="sell-preview__row"><span class="sell-preview__label">Contact</span><span class="sell-preview__value">' + Security.sanitize(contact) + '</span></div>' +
            (sellData.delivery_url ? '<div class="sell-preview__row"><span class="sell-preview__label">Delivery</span><span class="sell-preview__value">Digital download link provided</span></div>' : '');

        // Switch steps
        setStep(2);
    }

    function goBack() {
        setStep(1);
    }

    async function submitListing(e) {
        e.preventDefault();
        var btn = document.getElementById('sell-submit-btn');
        if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span> Submitting for review...'; }

        var result = await Marketplace.submit(sellData);
        if (result) {
            setStep(3);
        } else if (btn) {
            btn.disabled = false;
            btn.textContent = 'Submit Listing';
        }
    }

    function setStep(step) {
        document.getElementById('sell-s1').classList.toggle('hidden', step !== 1);
        document.getElementById('sell-s2').classList.toggle('hidden', step !== 2);
        document.getElementById('sell-s3').classList.toggle('hidden', step !== 3);
        for (var i = 1; i <= 3; i++) {
            var el = document.getElementById('sell-step-' + i);
            if (!el) continue;
            el.className = 'sell-step';
            if (i < step) el.classList.add('sell-step--done');
            else if (i === step) el.classList.add('sell-step--active');
        }
    }
    </script>
</Fragment>
</BaseLayout>
