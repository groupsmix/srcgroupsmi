---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Referral Program — GroupsMix"
  description="Invite friends to GroupsMix and both earn 50 GMX coins. Share your referral link and grow the community together."
  cssFiles={["/assets/css/features.css"]}
  includeFeatures={true}
>
<style is:inline>
    .referral-page {
        max-width: var(--container-lg);
        margin: 0 auto;
        padding: var(--space-8) var(--space-4);
    }
    .referral-hero {
        text-align: center;
        background: linear-gradient(135deg, var(--accent-primary), #9c27b0);
        border-radius: var(--radius-xl);
        padding: var(--space-10) var(--space-6);
        color: #fff;
        margin-bottom: var(--space-8);
        position: relative;
        overflow: hidden;
    }
    .referral-hero::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 200px;
        height: 200px;
        background: rgba(255,255,255,0.08);
        border-radius: 0 0 0 100%;
    }
    .referral-hero__icon {
        font-size: 3rem;
        margin-bottom: var(--space-3);
    }
    .referral-hero__title {
        font-size: var(--text-3xl);
        font-weight: var(--font-bold);
        margin-bottom: var(--space-3);
    }
    .referral-hero__subtitle {
        font-size: var(--text-base);
        opacity: 0.9;
        max-width: 500px;
        margin: 0 auto var(--space-4);
    }
    .referral-hero__reward {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        background: rgba(255,255,255,0.2);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-full);
        font-size: var(--text-lg);
        font-weight: var(--font-bold);
    }
    .referral-link-section {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        margin-bottom: var(--space-6);
        text-align: center;
    }
    .referral-link-section__title {
        font-size: var(--text-lg);
        font-weight: var(--font-semibold);
        margin-bottom: var(--space-4);
    }
    .referral-link-box {
        display: flex;
        gap: var(--space-2);
        max-width: 500px;
        margin: 0 auto var(--space-4);
    }
    .referral-link-input {
        flex: 1;
        font-family: monospace;
        font-size: var(--text-sm);
    }
    .referral-share-buttons {
        display: flex;
        gap: var(--space-3);
        justify-content: center;
        flex-wrap: wrap;
    }
    .referral-share-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-lg);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        text-decoration: none;
        color: #fff;
        cursor: pointer;
        border: none;
        transition: opacity 0.15s;
    }
    .referral-share-btn:hover { opacity: 0.85; }
    .referral-share-btn--whatsapp { background: #25d366; }
    .referral-share-btn--telegram { background: #0088cc; }
    .referral-share-btn--twitter { background: #1da1f2; }
    .referral-share-btn--copy { background: var(--bg-tertiary); color: var(--text-primary); border: 1px solid var(--border-primary); }
    .referral-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-4);
        margin-bottom: var(--space-6);
    }
    .referral-stat {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        text-align: center;
    }
    .referral-stat__value {
        font-size: var(--text-3xl);
        font-weight: var(--font-bold);
        color: var(--accent-primary);
    }
    .referral-stat__label {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        margin-top: var(--space-1);
    }
    .referral-how-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-6);
        margin-bottom: var(--space-8);
    }
    .referral-how-step {
        text-align: center;
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
    }
    .referral-how-step__num {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-full);
        background: var(--accent-primary);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: var(--font-bold);
        font-size: var(--text-lg);
        margin: 0 auto var(--space-3);
    }
    .referral-how-step__title {
        font-weight: var(--font-semibold);
        margin-bottom: var(--space-2);
    }
    .referral-how-step__desc {
        font-size: var(--text-sm);
        color: var(--text-secondary);
    }
    .referral-history {
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-xl);
        padding: var(--space-6);
        display: none;
    }
    .referral-history__title {
        font-size: var(--text-lg);
        font-weight: var(--font-semibold);
        margin-bottom: var(--space-4);
    }
    .referral-event {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-3) 0;
        border-bottom: 1px solid var(--border-primary);
        font-size: var(--text-sm);
    }
    .referral-event:last-child { border-bottom: none; }
    .referral-event__icon {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .referral-event__icon--signup { background: rgba(76,175,80,0.15); }
    .referral-event__icon--click { background: rgba(33,150,243,0.15); }
    .referral-event__info { flex: 1; }
    .referral-event__coins {
        font-weight: var(--font-bold);
        color: var(--accent-primary);
    }
    .referral-login-prompt {
        text-align: center;
        padding: var(--space-8);
        background: var(--bg-card);
        border: 1px solid var(--border-primary);
        border-radius: var(--radius-xl);
        margin-bottom: var(--space-6);
    }
    @media (max-width: 767px) {
        .referral-hero__title { font-size: var(--text-2xl); }
        .referral-stats-grid { grid-template-columns: repeat(2, 1fr); }
        .referral-how-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="referral-page">
    <div class="referral-hero">
        <div class="referral-hero__icon">&#127873;</div>
        <h1 class="referral-hero__title">Invite Friends, Earn Coins</h1>
        <p class="referral-hero__subtitle">Share GroupsMix with your friends. When they sign up using your link, you both earn GMX coins!</p>
        <div class="referral-hero__reward">&#129689; 50 GMX Coins Each</div>
    </div>

    <div id="referral-login-prompt" class="referral-login-prompt" style="display:none">
        <div style="font-size:var(--text-2xl);margin-bottom:var(--space-3)">&#128274;</div>
        <h2 style="margin-bottom:var(--space-2)">Sign In to Get Your Referral Link</h2>
        <p style="color:var(--text-secondary);margin-bottom:var(--space-4)">Create an account or sign in to start earning coins.</p>
        <button class="btn btn-primary" onclick="Auth.showLoginModal()">Sign In</button>
    </div>

    <div id="referral-authenticated" style="display:none">
        <div class="referral-link-section">
            <h2 class="referral-link-section__title">Your Referral Link</h2>
            <div class="referral-link-box">
                <input type="text" class="form-input referral-link-input" id="referral-link" readonly>
                <button class="btn btn-primary" id="copy-referral-btn">Copy</button>
            </div>
            <div class="referral-share-buttons">
                <a class="referral-share-btn referral-share-btn--whatsapp" id="share-whatsapp" target="_blank" rel="noopener">&#128172; WhatsApp</a>
                <a class="referral-share-btn referral-share-btn--telegram" id="share-telegram" target="_blank" rel="noopener">&#9992; Telegram</a>
                <a class="referral-share-btn referral-share-btn--twitter" id="share-twitter" target="_blank" rel="noopener">&#128038; Twitter</a>
            </div>
        </div>

        <div class="referral-stats-grid">
            <div class="referral-stat">
                <div class="referral-stat__value" id="ref-total-clicks">0</div>
                <div class="referral-stat__label">Link Clicks</div>
            </div>
            <div class="referral-stat">
                <div class="referral-stat__value" id="ref-total-signups">0</div>
                <div class="referral-stat__label">Sign-ups</div>
            </div>
            <div class="referral-stat">
                <div class="referral-stat__value" id="ref-total-earned">0</div>
                <div class="referral-stat__label">Coins Earned</div>
            </div>
            <div class="referral-stat">
                <div class="referral-stat__value" id="ref-conversion">0%</div>
                <div class="referral-stat__label">Conversion Rate</div>
            </div>
        </div>

        <div class="referral-history" id="referral-history">
            <h2 class="referral-history__title">Recent Referrals</h2>
            <div id="referral-events-list"></div>
        </div>
    </div>

    <div class="referral-how-grid">
        <div class="referral-how-step">
            <div class="referral-how-step__num">1</div>
            <div class="referral-how-step__title">Share Your Link</div>
            <div class="referral-how-step__desc">Copy your unique referral link and share it on social media, in groups, or directly with friends.</div>
        </div>
        <div class="referral-how-step">
            <div class="referral-how-step__num">2</div>
            <div class="referral-how-step__title">Friends Sign Up</div>
            <div class="referral-how-step__desc">When someone clicks your link and creates an account on GroupsMix, the referral is tracked automatically.</div>
        </div>
        <div class="referral-how-step">
            <div class="referral-how-step__num">3</div>
            <div class="referral-how-step__title">Both Earn Coins</div>
            <div class="referral-how-step__desc">You get 50 GMX coins and your friend gets 50 GMX coins. Use them across GroupsMix!</div>
        </div>
    </div>
</div>

<Fragment slot="scripts">
<script is:inline>
document.addEventListener('DOMContentLoaded', async function() {
    await Auth.waitForAuth();

    if (!Auth.isLoggedIn()) {
        document.getElementById('referral-login-prompt').style.display = 'block';
        return;
    }

    document.getElementById('referral-authenticated').style.display = 'block';
    initReferralProgram();

    async function initReferralProgram() {
        try {
            var uid = Auth.getUserId();

            // Get or create referral code
            var { data: existingCode } = await window.supabaseClient
                .from('referral_codes')
                .select('*')
                .eq('owner_uid', uid)
                .limit(1);

            var refCode;
            if (existingCode && existingCode.length > 0) {
                refCode = existingCode[0];
            } else {
                // Generate a new referral code using crypto.getRandomValues so
                // the code is unpredictable and cannot be enumerated.
                var code = 'gmx-' + window.SecureRandom.string(6);
                var { data: newCode, error } = await window.supabaseClient
                    .from('referral_codes')
                    .insert({ owner_uid: uid, code: code })
                    .select()
                    .single();
                if (error) throw error;
                refCode = newCode;
            }

            var refLink = 'https://groupsmix.com/?ref=' + refCode.code;
            document.getElementById('referral-link').value = refLink;

            // Share buttons
            var shareText = 'Discover the best WhatsApp, Telegram & Discord groups on GroupsMix! Join using my link and we both earn 50 GMX coins: ';
            document.getElementById('share-whatsapp').href = 'https://wa.me/?text=' + encodeURIComponent(shareText + refLink);
            document.getElementById('share-telegram').href = 'https://t.me/share/url?url=' + encodeURIComponent(refLink) + '&text=' + encodeURIComponent(shareText);
            document.getElementById('share-twitter').href = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText + refLink);

            // Copy button
            document.getElementById('copy-referral-btn').addEventListener('click', function() {
                navigator.clipboard.writeText(refLink).then(function() {
                    UI.toast('Referral link copied!', 'success');
                });
            });

            // Load referral stats
            var { data: events } = await window.supabaseClient
                .from('referral_events')
                .select('*')
                .eq('referrer_uid', uid)
                .order('created_at', { ascending: false });

            if (events && events.length > 0) {
                var clicks = 0;
                var signups = 0;
                var earned = 0;
                events.forEach(function(e) {
                    if (e.event_type === 'click') clicks++;
                    if (e.event_type === 'signup') { signups++; earned += e.coins_awarded || 0; }
                });

                document.getElementById('ref-total-clicks').textContent = clicks;
                document.getElementById('ref-total-signups').textContent = signups;
                document.getElementById('ref-total-earned').textContent = earned;
                document.getElementById('ref-conversion').textContent = clicks > 0 ? ((signups / clicks) * 100).toFixed(1) + '%' : '0%';

                // Show events
                var historyEl = document.getElementById('referral-history');
                historyEl.style.display = 'block';
                document.getElementById('referral-events-list').innerHTML = events.slice(0, 20).map(function(e) {
                    var isSignup = e.event_type === 'signup';
                    var iconClass = isSignup ? 'referral-event__icon--signup' : 'referral-event__icon--click';
                    var icon = isSignup ? '&#128100;' : '&#128065;';
                    var label = isSignup ? 'New sign-up from your referral' : 'Someone clicked your link';
                    var date = e.created_at ? new Date(e.created_at).toLocaleDateString() : '';
                    return '<div class="referral-event">' +
                        '<div class="referral-event__icon ' + iconClass + '">' + icon + '</div>' +
                        '<div class="referral-event__info">' +
                        '<div>' + label + '</div>' +
                        '<div style="font-size:var(--text-xs);color:var(--text-tertiary)">' + date + '</div>' +
                        '</div>' +
                        (isSignup && e.coins_awarded ? '<div class="referral-event__coins">+' + e.coins_awarded + ' GMX</div>' : '') +
                        '</div>';
                }).join('');
            }
        } catch (err) {
            console.error('initReferralProgram:', err);
            UI.toast('Failed to load referral data', 'error');
        }
    }
});
</script>
</Fragment>
</BaseLayout>
