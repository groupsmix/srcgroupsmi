            </section>

            <!-- Comparison Table -->
            <section class="comparison-section">
                <div class="section-header">
                    <h2 class="section-header__title">Compare Plans</h2>
                    <p class="section-header__subtitle">See exactly what you get with each plan</p>
                </div>
