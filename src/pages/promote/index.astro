                        <tr><td>Diamond Animation</td><td class="check-no">&#10007;</td><td class="check-no">&#10007;</td><td class="check-yes">&#10003;</td></tr>
                        <tr><td>Dedicated Support</td><td class="check-no">&#10007;</td><td>Priority</td><td>Personal Manager</td></tr>
                    </tbody>
