<Fragment slot="scripts">
<script is:inline>
    (function() {
        'use strict';

        var currentPeriod = 'monthly';
        var prices = {
            standard: { monthly: 5, yearly: 42 },
            silver: { monthly: 30, yearly: 252 },
            diamond: { monthly: 50, yearly: 420 }
        };

        var billingSwitch = document.getElementById('billing-switch');
        var labels = document.querySelectorAll('.billing-toggle__label');

        function updatePrices() {
            var isYearly = currentPeriod === 'yearly';
            document.getElementById('standard-price').textContent = '$' + prices.standard[currentPeriod];
            document.getElementById('standard-period').textContent = isYearly ? 'per year' : 'per month';
            var stdOrig = document.getElementById('standard-original');
            if (isYearly) { stdOrig.style.visibility = 'visible'; stdOrig.textContent = '$' + (prices.standard.monthly * 12); }
            else { stdOrig.style.visibility = 'hidden'; stdOrig.innerHTML = '&nbsp;'; }

            document.getElementById('silver-price').textContent = '$' + prices.silver[currentPeriod];
            document.getElementById('silver-period').textContent = isYearly ? 'per year' : 'per month';
            var silOrig = document.getElementById('silver-original');
            if (isYearly) { silOrig.style.visibility = 'visible'; silOrig.textContent = '$' + (prices.silver.monthly * 12); }
            else { silOrig.style.visibility = 'hidden'; silOrig.innerHTML = '&nbsp;'; }

            document.getElementById('diamond-price').textContent = '$' + prices.diamond[currentPeriod];
            document.getElementById('diamond-period').textContent = isYearly ? 'per year' : 'per month';
            var diaOrig = document.getElementById('diamond-original');
            if (isYearly) { diaOrig.style.visibility = 'visible'; diaOrig.textContent = '$' + (prices.diamond.monthly * 12); }
            else { diaOrig.style.visibility = 'hidden'; diaOrig.innerHTML = '&nbsp;'; }
        }

        if (billingSwitch) {
            billingSwitch.addEventListener('click', function() {
                currentPeriod = currentPeriod === 'monthly' ? 'yearly' : 'monthly';
                billingSwitch.classList.toggle('active', currentPeriod === 'yearly');
                labels.forEach(function(l) { l.classList.toggle('active', l.dataset.period === currentPeriod); });
                updatePrices();
            });
        }
        labels.forEach(function(l) {
            l.addEventListener('click', function() {
                currentPeriod = l.dataset.period;
                billingSwitch.classList.toggle('active', currentPeriod === 'yearly');
                labels.forEach(function(lb) { lb.classList.toggle('active', lb.dataset.period === currentPeriod); });
                updatePrices();
            });
        });

        function startPayment(service, period) {
            if (!Auth.requireAuth()) return;
            var amount = getPrice(service, { period: period });
            UI.modal({
                title: '&#128179; Complete Your Purchase',
                content:
                    '<div style="text-align:center;margin-bottom:var(--space-4)">' +
                        '<div style="font-size:var(--text-2xl);font-weight:var(--font-bold);color:var(--accent-primary);margin-bottom:var(--space-1)">$' + amount + '</div>' +
                        '<div style="font-size:var(--text-sm);color:var(--text-tertiary)">' + service.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) + ' &middot; ' + period + '</div>' +
                    '</div>' +
                    '<div class="form-group"><label class="form-label">Payment Method</label>' +
                    '<select class="form-select" id="pay-method"><option value="crypto">Cryptocurrency</option>' +
                    (typeof CONFIG !== 'undefined' && CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.storeUrl ? '<option value="lemon">LemonSqueezy (Card)</option>' : '') +
                    '</select></div>' +
                    '<div id="crypto-fields">' +
                    '<div class="form-group"><label class="form-label">Currency</label><select class="form-select" id="pay-currency"><option value="btc">Bitcoin (BTC)</option><option value="usdt">USDT (ERC-20)</option><option value="sol">Solana (SOL)</option></select></div>' +
                    '<div class="form-group"><label class="form-label">Send to:</label><div class="form-input" id="wallet-address" style="word-break:break-all;height:auto;padding:10px 14px;cursor:pointer;font-size:var(--text-sm)" title="Click to copy">Loading...</div></div>' +
                    '<div class="form-group"><label class="form-label">Transaction Hash *</label><input type="text" class="form-input" id="pay-tx-hash" placeholder="Paste your transaction hash"></div>' +
                    '</div>',
                footer: '<button class="btn btn-secondary" id="pay-cancel">Cancel</button><button class="btn btn-primary" id="pay-submit">Submit Payment</button>'
            });

            document.getElementById('pay-cancel')?.addEventListener('click', UI.closeModal);
            updateWallet();
            document.getElementById('pay-currency')?.addEventListener('change', updateWallet);
            document.getElementById('pay-method')?.addEventListener('change', function() {
                var m = document.getElementById('pay-method').value;
                document.getElementById('crypto-fields').style.display = m === 'crypto' ? '' : 'none';
            });
            document.getElementById('wallet-address')?.addEventListener('click', function() { UI.copyToClipboard(this.textContent); });
            document.getElementById('pay-submit')?.addEventListener('click', async function() {
                var method = document.getElementById('pay-method')?.value;
                if (method === 'lemon' && typeof CONFIG !== 'undefined' && CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.storeUrl) { window.open(CONFIG.lemonSqueezy.storeUrl, '_blank'); UI.closeModal(); return; }
                var txHash = document.getElementById('pay-tx-hash')?.value?.trim();
                var currency = document.getElementById('pay-currency')?.value;
                if (!txHash) { UI.toast('Please enter the transaction hash', 'error'); return; }
                if (!Security.isValidTxHash(txHash, currency)) { UI.toast('Invalid transaction hash format', 'error'); return; }
                var btn = document.getElementById('pay-submit');
                if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>'; }
                var result = await DB.payments.submit({
                    type: service.startsWith('vip') ? 'vip' : service.startsWith('boost') ? 'boost' : 'service',
                    service: service,
                    currency: currency,
                    amount: amount,
                    tx_hash: txHash,
                    wallet_address: typeof CONFIG !== 'undefined' && CONFIG.cryptoWallets ? CONFIG.cryptoWallets[currency] || '' : '',
                    billing_period: period
                });
                if (result) { UI.toast('Payment submitted! We will verify it shortly.', 'success'); UI.closeModal(); }
                else if (btn) { btn.disabled = false; btn.textContent = 'Submit Payment'; }
            });
        }

        function updateWallet() {
            var currency = document.getElementById('pay-currency')?.value || 'btc';
            var el = document.getElementById('wallet-address');
            if (el) el.textContent = (typeof CONFIG !== 'undefined' && CONFIG.cryptoWallets && CONFIG.cryptoWallets[currency]) ? CONFIG.cryptoWallets[currency] : 'Not configured — contact admin';
        }

        document.querySelectorAll('[data-payment]').forEach(function(btn) {
            btn.addEventListener('click', function() {
                startPayment(btn.dataset.payment, currentPeriod);
            });
        });
    })();
    </script>
</Fragment>
</BaseLayout>
