                            <li><span class="check">&#10003;</span> Priority support (24h response)</li>
                            <li class="disabled"><span class="cross">&#10007;</span> Diamond animation effects</li>
                        </ul>
                        <div class="pricing-card__cta">
                            <button class="btn btn-primary btn-full btn-lg" data-payment="vip_global" id="btn-silver">Choose VIP Silver</button>
                        </div>
                    </div>

                    <!-- VIP Diamond -->
                    <div class="pricing-card" data-plan="diamond">
                        <div class="pricing-card__icon pricing-card__icon--diamond">&#128142;</div>
                        <div class="pricing-card__name">VIP Diamond</div>
                        <div class="pricing-card__tagline">Ultimate prestige &amp; domination</div>
