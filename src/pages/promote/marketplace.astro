---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Group Marketplace &mdash; GroupsMix"
  description="Discover service-based groups and promoted listings on the GroupsMix Marketplace."
>
<style is:inline>
        .mk-hero {
            text-align: center;
            padding: var(--space-8) 0 var(--space-6);
        }
        .mk-hero__badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary, #6366f1));
            color: #fff;
            padding: var(--space-1) var(--space-3);
            border-radius: var(--radius-full);
            font-size: var(--text-xs);
            font-weight: var(--font-bold);
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: var(--space-3);
        }
        .mk-hero__subtitle {
            color: var(--text-secondary);
            margin-top: var(--space-2);
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        .mk-stats {
            display: flex;
            justify-content: center;
            gap: var(--space-8);
            margin: var(--space-6) 0;
            flex-wrap: wrap;
        }
        .mk-stat {
            text-align: center;
        }
        .mk-stat__value {
            font-size: var(--text-2xl);
            font-weight: var(--font-bold);
            color: var(--accent-primary);
        }
        .mk-stat__label {
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: .05em;
        }
        .mk-section {
            margin-bottom: var(--space-8);
        }
        .mk-section__title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-4);
        }
        .mk-ads-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-4);
        }
        .mk-ad-item {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .mk-ad-item:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }
        .mk-ad-item__label {
            display: inline-block;
            background: var(--accent-primary);
            color: #fff;
            font-size: 10px;
            font-weight: var(--font-bold);
            padding: 2px 8px;
            border-radius: var(--radius-full);
            text-transform: uppercase;
            letter-spacing: .03em;
        }
        .mk-ad-item__header {
            padding: var(--space-3) var(--space-4);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mk-ad-item__img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }
        .mk-ad-item__body {
            padding: var(--space-3) var(--space-4) var(--space-4);
        }
        .mk-ad-item__title {
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-1);
        }
        .mk-ad-item__desc {
            color: var(--text-secondary);
            font-size: var(--text-sm);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .mk-ad-item__footer {
            padding: var(--space-3) var(--space-4);
            border-top: 1px solid var(--border-primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mk-cta {
            margin-top: var(--space-8);
            padding: var(--space-8);
            background: var(--bg-tertiary);
            border-radius: var(--radius-lg);
            text-align: center;
        }
        .mk-cta__title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-2);
        }
        .mk-cta__text {
            color: var(--text-secondary);
            margin-bottom: var(--space-4);
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }
        .mk-cta__actions {
            display: flex;
            gap: var(--space-3);
            justify-content: center;
            flex-wrap: wrap;
        }
        @media (max-width: 899px) {
            .mk-ads-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 599px) {
            .mk-ads-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>


        <div class="container" style="max-width:var(--container-lg);padding:0 var(--space-4)">
            <section class="mk-hero" aria-labelledby="mk-heading">
                <span class="mk-hero__badge">Marketplace</span>
                <h1 id="mk-heading">Group Marketplace</h1>
                <p class="mk-hero__subtitle">Discover service-based groups and promoted listings. Find trusted communities offering real value.</p>
            </section>
            <div class="mk-stats" id="mk-stats" aria-label="Marketplace statistics">
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-ads">--</div>
                    <div class="mk-stat__label">Featured Ads</div>
                </div>
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-services">--</div>
                    <div class="mk-stat__label">Service Groups</div>
                </div>
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-all">--</div>
                    <div class="mk-stat__label">Total Listings</div>
                </div>
            </div>
            <section class="mk-section" aria-labelledby="mk-ads-title">
                <h2 id="mk-ads-title" class="mk-section__title">Featured Listings</h2>
                <div id="mk-ads-container" class="mk-ads-grid">
                    <div class="skeleton" style="height:220px;border-radius:var(--radius-lg)"></div>
                    <div class="skeleton" style="height:220px;border-radius:var(--radius-lg)"></div>
                    <div class="skeleton" style="height:220px;border-radius:var(--radius-lg)"></div>
                </div>
            </section>
            <section class="mk-section" aria-labelledby="mk-services-title">
                <h2 id="mk-services-title" class="mk-section__title">Service Groups</h2>
                <div id="mk-services-container">
                    <div class="grid grid-4">
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                    </div>
                </div>
            </section>
            <section class="mk-cta" aria-labelledby="mk-cta-title">
                <h2 id="mk-cta-title" class="mk-cta__title">Promote Your Service</h2>
                <p class="mk-cta__text">Get featured placement in the GroupsMix Marketplace. Reach thousands of users actively searching for communities and services.</p>
                <div class="mk-cta__actions">
                    <button class="btn btn-primary" id="mk-promote-card-btn" type="button">Pay with Card</button>
                    <button class="btn btn-secondary" id="mk-promote-crypto-btn" type="button">Pay with Crypto</button>
                </div>
            </section>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    document.addEventListener('DOMContentLoaded', initMarketplace);

    var marketplaceAds = [];
    var serviceGroups = [];
    var mkTimeout = null;

    async function initMarketplace() {
        if (!CONFIG.features.marketplace) {
            document.getElementById('main-content').innerHTML =
                '<div style="text-align:center;padding:var(--space-16) var(--space-4)">' +
                '<div style="font-size:var(--text-5xl);margin-bottom:var(--space-4)">&#128679;</div>' +
                '<h1 style="margin-bottom:var(--space-3)">Marketplace &mdash; Coming Soon</h1>' +
                '<p style="color:var(--text-secondary);max-width:500px;margin:0 auto var(--space-6)">We are working on this feature. Stay tuned!</p>' +
                '<a href="/" class="btn btn-primary">Back to Home</a></div>';
            return;
        }
        mkTimeout = setTimeout(function() {
            var adsEl = document.getElementById('mk-ads-container');
            var svcEl = document.getElementById('mk-services-container');
            if (adsEl && adsEl.querySelector('.skeleton')) UI.timeoutState('mk-ads-container');
            if (svcEl && svcEl.querySelector('.skeleton')) UI.timeoutState('mk-services-container');
        }, CONFIG.timeoutDuration);
        await loadMarketplace();
        initPromoteButtons();
    }

    async function loadMarketplace() {
        try {
            await Promise.allSettled([loadAds(), loadServiceGroups()]);
            clearTimeout(mkTimeout);
            updateStats();
        } catch (err) {
            clearTimeout(mkTimeout);
        }
    }

    async function loadAds() {
        try {
            var ads = await DB.ads.getActive('marketplace');
            marketplaceAds = Array.isArray(ads) ? ads : [];
            renderAds();
        } catch (err) {
            UI.errorState('mk-ads-container', loadAds);
        }
    }

    async function loadServiceGroups() {
        try {
            var result = await DB.groups.getApproved({ sort: 'ranking', limit: 24, offset: 0 });
            var all = Array.isArray(result.data) ? result.data : [];
            serviceGroups = all.filter(function(g) {
                var tags = Array.isArray(g.tags) ? g.tags : [];
                var hasServiceTag = tags.some(function(t) {
                    return t.toLowerCase() === 'service' || t.toLowerCase() === 'services';
                });
                var isServiceCategory = g.category === 'business' || g.category === 'jobs' || g.category === 'marketing';
                return hasServiceTag || isServiceCategory;
            });
            if (!serviceGroups.length) {
                serviceGroups = all.slice(0, 12);
            }
            renderServices();
        } catch (err) {
            UI.errorState('mk-services-container', loadServiceGroups);
        }
    }

    function renderAds() {
        var container = document.getElementById('mk-ads-container');
        if (!container) return;
        if (!marketplaceAds.length) {
            container.innerHTML =
                '<div style="text-align:center;grid-column:1/-1;padding:var(--space-8)">' +
                '<div style="font-size:var(--text-3xl);margin-bottom:var(--space-3)">&#128230;</div>' +
                '<h3 style="margin-bottom:var(--space-2);color:var(--text-primary)">No Featured Listings Yet</h3>' +
                '<p style="color:var(--text-secondary);max-width:400px;margin:0 auto">Be the first to feature your service in the Marketplace.</p>' +
                '</div>';
            return;
        }
        container.innerHTML = marketplaceAds.map(function(ad) {
            var safeTitle = Security.sanitize(ad.title || 'Untitled');
            var safeDesc = Security.sanitize(ad.description || '');
            var safeImg = ad.image_url ? Security.sanitize(ad.image_url) : '';
            var safeLink = ad.link ? Security.sanitize(ad.link) : '';
            var safeAlt = Security.sanitize(ad.title || 'Listing');
            return '<article class="mk-ad-item" data-ad-id="' + ad.id + '">' +
                '<div class="mk-ad-item__header">' +
                '<span class="mk-ad-item__label">Featured</span>' +
                '<span style="color:var(--text-tertiary);font-size:var(--text-xs)">' + UI.formatDate(ad.created_at) + '</span>' +
                '</div>' +
                (safeImg ? '<img class="mk-ad-item__img" src="' + safeImg + '" alt="' + safeAlt + '" loading="lazy">' : '') +
                '<div class="mk-ad-item__body">' +
                '<div class="mk-ad-item__title">' + safeTitle + '</div>' +
                '<div class="mk-ad-item__desc">' + safeDesc + '</div>' +
                '</div>' +
                '<div class="mk-ad-item__footer">' +
                '<span style="color:var(--text-tertiary);font-size:var(--text-xs)">' + UI.formatNumber(ad.impressions || 0) + ' views</span>' +
                (safeLink ? '<a href="' + safeLink + '" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm" style="padding:2px 12px;font-size:11px">Visit</a>' : '') +
                '</div>' +
                '</article>';
        }).join('');
        container.style.animation = 'fadeIn 0.3s ease';
        marketplaceAds.forEach(function(ad) { DB.ads.incrementImpressions(ad.id); });
    }

    function renderServices() {
        UI.groupGrid(serviceGroups, 'mk-services-container');
    }

    function updateStats() {
        var adsEl = document.getElementById('mk-total-ads');
        var svcEl = document.getElementById('mk-total-services');
        var allEl = document.getElementById('mk-total-all');
        if (adsEl) UI.countUp(adsEl, marketplaceAds.length);
        if (svcEl) UI.countUp(svcEl, serviceGroups.length);
        if (allEl) UI.countUp(allEl, marketplaceAds.length + serviceGroups.length);
    }

    function initPromoteButtons() {
        var cardBtn = document.getElementById('mk-promote-card-btn');
        var cryptoBtn = document.getElementById('mk-promote-crypto-btn');
        if (cardBtn) {
            cardBtn.addEventListener('click', function() {
                if (!Auth.requireAuth()) return;
                if (CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.products && CONFIG.lemonSqueezy.products.ad_featured_weekly) {
                    window.open(CONFIG.lemonSqueezy.products.ad_featured_weekly, '_blank');
                } else if (CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.storeUrl) {
                    window.open(CONFIG.lemonSqueezy.storeUrl, '_blank');
                } else {
                    UI.toast('Card payments are being set up. Please use crypto or contact support.', 'info');
                }
            });
        }
        if (cryptoBtn) {
            cryptoBtn.addEventListener('click', function() {
                if (!Auth.requireAuth()) return;
                openCryptoPayment();
            });
        }
    }

    function openCryptoPayment() {
        var price = getPrice('ad_featured_weekly');
        UI.modal({
            title: 'Pay with Crypto',
            content:
                '<p style="color:var(--text-secondary);margin-bottom:var(--space-4)">Marketplace Featured Listing: <strong>' + UI.formatCurrency(price) + '/week</strong></p>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-currency">Currency</label>' +
                '<select class="form-select" id="mk-currency">' +
                '<option value="btc">Bitcoin (BTC)</option>' +
                '<option value="usdt">USDT (TRC-20)</option>' +
                '<option value="sol">Solana (SOL)</option>' +
                '</select></div>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-wallet-display">Send to:</label>' +
                '<div class="form-input" id="mk-wallet" style="word-break:break-all;height:auto;padding:10px 14px;cursor:pointer" role="button" tabindex="0" aria-label="Click to copy wallet address">Loading...</div>' +
                '</div>' +
                '<p style="color:var(--warning);font-size:var(--text-xs);margin-bottom:var(--space-3)">Send ONLY via the correct network. Other networks will lose funds.</p>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-tx-hash">Transaction Hash *</label>' +
                '<input type="text" class="form-input" id="mk-tx-hash" placeholder="Paste your transaction hash" required>' +
                '</div>',
            footer: '<button class="btn btn-secondary" id="mk-pay-cancel" type="button">Cancel</button>' +
                '<button class="btn btn-primary" id="mk-pay-submit" type="button">Submit Payment</button>'
        });
        updateMkWallet();
        var currencyEl = document.getElementById('mk-currency');
        if (currencyEl) currencyEl.addEventListener('change', updateMkWallet);
        var walletEl = document.getElementById('mk-wallet');
        if (walletEl) {
            walletEl.addEventListener('click', function() { UI.copyToClipboard(this.textContent); });
            walletEl.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    UI.copyToClipboard(this.textContent);
                }
            });
        }
        var cancelBtn = document.getElementById('mk-pay-cancel');
        if (cancelBtn) cancelBtn.addEventListener('click', UI.closeModal);
        var submitBtn = document.getElementById('mk-pay-submit');
        if (submitBtn) {
            submitBtn.addEventListener('click', async function() {
                var txHashEl = document.getElementById('mk-tx-hash');
                var currEl = document.getElementById('mk-currency');
                var txHash = txHashEl ? txHashEl.value.trim() : '';
                var currency = currEl ? currEl.value : 'btc';
                if (!txHash) { UI.toast('Please enter the transaction hash', 'error'); return; }
                if (!Security.isValidTxHash(txHash, currency)) { UI.toast('Invalid transaction hash format', 'error'); return; }
                var btn = document.getElementById('mk-pay-submit');
                if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>'; }
                var result = await DB.payments.submit({
                    type: 'ad',
                    service: 'ad_featured_weekly',
                    currency: currency,
                    amount: price,
                    tx_hash: txHash,
                    wallet_address: CONFIG.cryptoWallets ? CONFIG.cryptoWallets[currency] || '' : ''
                });
                if (result) {
                    UI.toast('Payment submitted! We will verify within 24 hours.', 'success');
                    UI.closeModal();
                } else if (btn) {
                    btn.disabled = false;
                    btn.textContent = 'Submit Payment';
                }
            });
        }
    }

    function updateMkWallet() {
        var currEl = document.getElementById('mk-currency');
        var currency = currEl ? currEl.value : 'btc';
        var el = document.getElementById('mk-wallet');
        if (el) el.textContent = (CONFIG.cryptoWallets && CONFIG.cryptoWallets[currency]) ? CONFIG.cryptoWallets[currency] : 'Not configured - contact admin';
    }
    </script>
</Fragment>
</BaseLayout>
