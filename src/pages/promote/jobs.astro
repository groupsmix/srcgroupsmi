---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Community Jobs | GroupsMix"
  description="Find community management jobs, moderators, and social media roles."
  mainClass="page-container"
>
<style is:inline>
        .job-card {
            display: flex;
            align-items: center;
            gap: var(--space-4);
            padding: var(--space-4);
            border-bottom: 1px solid var(--border-primary);
            transition: background 0.2s ease;
            text-decoration: none;
            color: inherit;
        }

        .job-card:hover {
            background: var(--bg-card-hover);
        }

        .job-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-md);
            background: var(--bg-tertiary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--text-2xl);
            flex-shrink: 0;
        }

        @media (max-width: 640px) {
            .job-card {
                flex-direction: column;
                align-items: flex-start;
                text-align: left;
            }

            .job-card__action {
                width: 100%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-top: var(--space-2);
            }
        }
    </style>


        <div class="content-wrapper">
            <div class="section__header"
                style="flex-direction:column;align-items:center;text-align:center;margin-bottom:var(--space-8)">
                <div style="font-size:var(--text-4xl);margin-bottom:var(--space-3)">💼</div>
                <h1 class="page-title">Community Jobs</h1>
                <p style="color:var(--text-secondary);max-width:600px">Find paid roles for community managers, discord
                    moderators, admins, and content creators.</p>
            </div>

            <div style="display:flex;gap:var(--space-4);margin-bottom:var(--space-6);flex-wrap:wrap">
                <input type="search" class="form-input" placeholder="Search roles (e.g., Discord Mod)"
                    style="flex:1;min-width:250px">
                <select class="form-select" style="width:auto">
                    <option value="">Any Role Type</option>
                    <option value="moderator">Moderator</option>
                    <option value="manager">Manager</option>
                    <option value="admin">Administrator</option>
                </select>
                <button class="btn btn-primary" id="btn-post-job">+ Post a
                    Job</button>
            </div>

            <div class="card">
                <div class="card__body" style="padding:0">
                    <!-- Job 1 -->
                    <a href="#" class="job-card" data-toast="Job details coming soon.">
                        <div class="job-icon">🎮</div>
                        <div style="flex:1">
                            <h3 style="margin-bottom:var(--space-1);font-size:var(--text-md)">Senior Discord Moderator
                            </h3>
                            <div style="font-size:var(--text-sm);color:var(--text-secondary)">
                                <strong>Apex Gaming Hub</strong> · Remote · Part-Time
                            </div>
                        </div>
                        <div class="job-card__action" style="text-align:right">
                            <div style="font-weight:var(--font-bold);margin-bottom:var(--space-1);color:var(--success)">
                                $15 - $20 / hr</div>
                            <span class="tag" style="background:var(--accent-primary);color:#fff">Apply Now</span>
                        </div>
                    </a>

                    <!-- Job 2 -->
                    <a href="#" class="job-card" data-toast="Job details coming soon.">
                        <div class="job-icon">📈</div>
                        <div style="flex:1">
                            <h3 style="margin-bottom:var(--space-1);font-size:var(--text-md)">Community Manager</h3>
                            <div style="font-size:var(--text-sm);color:var(--text-secondary)">
                                <strong>DeFi Traders Network</strong> · Remote · Full-Time
                            </div>
                        </div>
                        <div class="job-card__action" style="text-align:right">
                            <div style="font-weight:var(--font-bold);margin-bottom:var(--space-1);color:var(--success)">
                                $3,000 / mo</div>
                            <span class="tag" style="background:var(--accent-primary);color:#fff">Apply Now</span>
                        </div>
                    </a>

                    <!-- Job 3 -->
                    <a href="#" class="job-card" data-toast="Job details coming soon.">
                        <div class="job-icon">🎨</div>
                        <div style="flex:1">
                            <h3 style="margin-bottom:var(--space-1);font-size:var(--text-md)">Telegram Group Admin</h3>
                            <div style="font-size:var(--text-sm);color:var(--text-secondary)">
                                <strong>Designers Hub</strong> · Remote · Contract
                            </div>
                        </div>
                        <div class="job-card__action" style="text-align:right">
                            <div style="font-weight:var(--font-bold);margin-bottom:var(--space-1);color:var(--success)">
                                $500 / mo</div>
                            <span class="tag" style="background:var(--accent-primary);color:#fff">Apply Now</span>
                        </div>
                    </a>
                </div>
            </div>

            <div style="text-align:center;margin-top:var(--space-6)">
                <button class="btn btn-secondary">Load Older Jobs</button>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            if (!CONFIG.features.jobs) {
                var main = document.getElementById('main-content');
                if (main) {
                    main.innerHTML = '<div class="content-wrapper" style="text-align:center;padding:var(--space-16) var(--space-4)">' +
                        '<div style="font-size:var(--text-5xl);margin-bottom:var(--space-4)">💼</div>' +
                        '<h1 style="margin-bottom:var(--space-3)">Community Jobs Coming Soon</h1>' +
                        '<p style="color:var(--text-secondary);max-width:500px;margin:0 auto var(--space-6)">Find paid roles for community managers, discord moderators, admins, and content creators. Launching soon!</p>' +
                        '<a href="/" class="btn btn-primary">Back to Home</a>' +
                        '</div>';
                }
                return;
            }
            document.getElementById('btn-post-job')?.addEventListener('click', () => {
                UI.toast('Please sign in to post a job.', 'info');
            });
            document.querySelectorAll('[data-toast]').forEach(el => {
                el.addEventListener('click', (e) => {
                    e.preventDefault();
                    UI.toast(el.dataset.toast, 'info');
                });
            });
        });
    </script>
</Fragment>
</BaseLayout>
