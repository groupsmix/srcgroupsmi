---
---
<BaseLayout
  title="My Wishlist — GroupsMix"
  description="Your saved wishlist items on GroupsMix."
  noIndex={true}
  cssFiles={["/assets/css/features.css"]}
  includeFeatures={true}
>
<style is:inline>
        .wishlist-page { max-width: var(--container-lg); margin: 0 auto; padding: var(--space-8) var(--space-4); }
        .wishlist-page__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3); }
        .wishlist-page__title { font-size: var(--text-2xl); font-weight: 800; display: flex; align-items: center; gap: var(--space-2); }
        .wishlist-page__count { font-size: var(--text-sm); color: var(--text-secondary); font-weight: 400; }
    </style>


        <div class="wishlist-page" id="wishlist-page">
            <div class="skeleton" style="height:300px;border-radius:var(--radius-lg)"></div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
        await Auth.waitForAuth();
        renderWishlist();
    });

    async function renderWishlist() {
        var page = document.getElementById('wishlist-page');
        var items = await Wishlist.getAll();
        var count = items ? items.length : 0;

        page.innerHTML =
            '<div class="wishlist-page__header">' +
            '<div class="wishlist-page__title">' + ICONS.heart + ' My Wishlist <span class="wishlist-page__count">(' + count + ' items)</span></div>' +
            (count > 0 ? '<button class="btn btn-ghost btn-sm" id="clear-wishlist">Clear All</button>' : '') +
            '</div>' +
            '<div class="feature-tabs" id="wl-tabs">' +
            '<button class="feature-tab feature-tab--active" data-type="">All</button>' +
            '<button class="feature-tab" data-type="group">Groups</button>' +
            '<button class="feature-tab" data-type="product">Products</button>' +
            '</div>' +
            '<div id="wishlist-items"></div>';

        renderItems(items, '');

        // Tab filtering
        document.querySelectorAll('#wl-tabs .feature-tab').forEach(function(tab) {
            tab.addEventListener('click', async function() {
                document.querySelectorAll('#wl-tabs .feature-tab').forEach(function(t) { t.classList.remove('feature-tab--active'); });
                tab.classList.add('feature-tab--active');
                var type = tab.dataset.type;
                var filtered = type ? items.filter(function(i) { return i.content_type === type; }) : items;
                renderItems(filtered, type);
            });
        });

        // Clear all
        var clearBtn = document.getElementById('clear-wishlist');
        if (clearBtn) {
            clearBtn.addEventListener('click', async function() {
                if (!confirm('Remove all items from your wishlist?')) return;
                for (var i = 0; i < items.length; i++) {
                    await Wishlist.remove(items[i].content_id, items[i].content_type);
                }
                UI.toast('Wishlist cleared', 'info');
                renderWishlist();
            });
        }
    }

    function renderItems(items, typeFilter) {
        var el = document.getElementById('wishlist-items');
        if (!items || !items.length) {
            el.innerHTML =
                '<div class="feature-empty">' +
                '<div class="feature-empty__icon">' + ICONS.heart + '</div>' +
                '<div class="feature-empty__title">Your Wishlist is Empty</div>' +
                '<div class="feature-empty__text">Save groups and products you like by clicking the heart icon. They\'ll appear here for easy access.</div>' +
                '<a href="/browse" class="btn btn-primary">Browse Groups</a>' +
                '</div>';
            return;
        }

        el.innerHTML = '<div class="wishlist-grid">' + items.map(function(item) {
            var title = item.title || item.content_id;
            var img = item.image_url || '';
            var type = item.content_type || 'group';
            var date = item.created_at ? UI.formatDate(item.created_at) : '';
            var href = type === 'group' ? '/group?id=' + encodeURIComponent(item.content_id) :
                       type === 'product' ? '/store?id=' + encodeURIComponent(item.content_id) : '#';

            return '<div class="wishlist-card">' +
                (img ? '<img class="wishlist-card__image" src="' + Security.sanitize(img) + '" alt="" loading="lazy">' :
                '<div class="wishlist-card__image" style="display:flex;align-items:center;justify-content:center;color:var(--primary)">' + ICONS.heart + '</div>') +
                '<div class="wishlist-card__info">' +
                '<a href="' + href + '" class="wishlist-card__title">' + Security.sanitize(title) + '</a>' +
                '<div class="wishlist-card__type">' + Security.sanitize(type) + '</div>' +
                (date ? '<div class="wishlist-card__date">Saved ' + date + '</div>' : '') +
                '</div>' +
                '<button class="wishlist-card__remove" data-id="' + Security.sanitize(item.content_id) + '" data-type="' + Security.sanitize(type) + '" title="Remove">&times;</button>' +
                '</div>';
        }).join('') + '</div>';

        // Remove buttons
        el.querySelectorAll('.wishlist-card__remove').forEach(function(btn) {
            btn.addEventListener('click', async function() {
                await Wishlist.remove(btn.dataset.id, btn.dataset.type);
                UI.toast('Removed from wishlist', 'info');
                renderWishlist();
            });
        });
    }
    </script>
</Fragment>
</BaseLayout>
