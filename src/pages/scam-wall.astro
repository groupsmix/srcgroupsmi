---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Scam Wall — GroupsMix"
  description="Reported and flagged groups. Stay safe from scams and suspicious communities."
>

        <div class="container" style="max-width:var(--container-lg);padding:var(--space-8) var(--space-4)">
            <div style="text-align:center;margin-bottom:var(--space-8)">
                <h1>🛡️ Scam Wall</h1>
                <p style="color:var(--text-secondary);margin-top:var(--space-2)">Groups with high report counts. Stay
                    safe!</p>
            </div>
            <div id="scam-list">
                <div class="skeleton" style="height:400px"></div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', load);
        async function load() {
            const el = document.getElementById('scam-list');
            try {
                const data = await DB.groups.getHighReports({ limit: 20 });
                if (!data?.length) { el.innerHTML = '<div class="empty-state"><div class="empty-state__icon">✅</div><div class="empty-state__title">Clean Record!</div><div class="empty-state__text">No suspicious groups have been flagged.</div></div>'; return; }
                el.innerHTML = '<div class="grid grid-3">' + data.map(g => {
                    const platform = CONFIG.platforms.find(p => p.id === g.platform);
                    return '<div class="card" style="border-color:var(--error)"><div class="card__body">' +
                        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-2)">' +
                        '<span style="font-size:var(--text-sm)">' + (platform?.emoji || '') + ' ' + Security.sanitize(platform?.name || '') + '</span>' +
                        '<span style="background:var(--error-light);color:var(--error);font-size:var(--text-xs);padding:2px 8px;border-radius:var(--radius-full);font-weight:var(--font-bold)">🚩 ' + g.reports + ' reports</span>' +
                        '</div>' +
                        '<div style="font-weight:var(--font-semibold);margin-bottom:var(--space-1)">' + Security.sanitize(g.name) + '</div>' +
                        '<div style="color:var(--text-secondary);font-size:var(--text-sm)">' + Security.sanitize((g.description || '').slice(0, 100)) + '</div>' +
                        '</div></div>';
                }).join('') + '</div>';
            } catch { el.innerHTML = '<div style="text-align:center;color:var(--text-tertiary)">Unable to load</div>'; }
        }
    </script>
</Fragment>
</BaseLayout>
