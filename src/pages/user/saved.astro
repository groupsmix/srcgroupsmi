---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="My Library — GroupsMix"
  description="Your saved content — groups, articles, store items, and marketplace listings."
  noIndex={true}
>

        <div class="container" style="max-width:var(--container-lg);padding:var(--space-8) var(--space-4)">
            <h1 style="margin-bottom:var(--space-4)">My Library</h1>
            <p style="color:var(--text-secondary);margin-bottom:var(--space-6)">All your saved content in one place.</p>
            <div class="saved-tabs" id="saved-tabs">
                <button class="saved-tab saved-tab--active" data-type="">All</button>
                <button class="saved-tab" data-type="group">Groups</button>
                <button class="saved-tab" data-type="article">Articles</button>
                <button class="saved-tab" data-type="store">Store</button>
                <button class="saved-tab" data-type="marketplace">Marketplace</button>
            </div>
            <div id="saved-content">
                <div style="text-align:center;padding:var(--space-8)"><span class="btn-spinner"></span> Loading saved items...</div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', async () => {
            await Auth.waitForAuth();
            if (!Auth.isLoggedIn()) {
                UI.emptyState('saved-content', '&#128274;', 'Sign In Required', 'Please sign in to view your saved content.', 'Sign In', '#');
                var signInBtn = document.querySelector('#saved-content .btn');
                if (signInBtn) signInBtn.addEventListener('click', function(e) { e.preventDefault(); UI.authModal(); });
                return;
            }
            var currentType = '';
            document.getElementById('saved-tabs').addEventListener('click', function(e) {
                var tab = e.target.closest('.saved-tab');
                if (!tab) return;
                document.querySelectorAll('.saved-tab').forEach(function(t) { t.classList.remove('saved-tab--active'); });
                tab.classList.add('saved-tab--active');
                currentType = tab.dataset.type || '';
                loadSaved(currentType);
            });
            async function loadSaved(contentType) {
                var container = document.getElementById('saved-content');
                container.innerHTML = '<div style="text-align:center;padding:var(--space-8)"><span class="btn-spinner"></span> Loading...</div>';
                var items = await Interactions.getSavedItems(contentType || null);
                if (!items || !items.length) {
                    var typeLabel = contentType ? contentType + 's' : 'items';
                    UI.emptyState('saved-content', '&#128278;', 'No Saved ' + typeLabel.charAt(0).toUpperCase() + typeLabel.slice(1), 'Items you save will appear here.', 'Browse', '/');
                    return;
                }
                container.innerHTML = '<div class="grid grid-3" id="saved-grid"></div>';
                var grid = document.getElementById('saved-grid');
                grid.innerHTML = items.map(function(item) {
                    return '<div class="card" style="padding:var(--space-4)">' +
                        '<div style="display:flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-2)">' +
                        '<span style="font-size:var(--text-xs);padding:2px 8px;border-radius:var(--radius-full);background:var(--accent-primary-light);color:var(--accent-primary);text-transform:capitalize">' + Security.sanitize(item.content_type || 'group') + '</span>' +
                        '<span style="color:var(--text-muted);font-size:var(--text-xs)">' + UI.formatDate(item.created_at) + '</span>' +
                        '</div>' +
                        '<div style="font-weight:600;margin-bottom:var(--space-2)">' + Security.sanitize(item.content_id || '') + '</div>' +
                        '<div style="display:flex;gap:var(--space-2)">' +
                        '<button class="btn btn-ghost btn-sm saved-item__remove" data-content-id="' + item.content_id + '" data-content-type="' + item.content_type + '">Remove</button>' +
                        '</div>' +
                        '</div>';
                }).join('');
                grid.querySelectorAll('.saved-item__remove').forEach(function(btn) {
                    btn.addEventListener('click', async function(e) {
                        e.preventDefault();
                        var cid = btn.dataset.contentId;
                        var ctype = btn.dataset.contentType;
                        btn.disabled = true;
                        btn.textContent = '...';
                        await Interactions.toggle(cid, ctype, 'save');
                        btn.closest('.card').style.opacity = '0.3';
                        setTimeout(function() { loadSaved(currentType); }, 500);
                    });
                });
            }
            loadSaved('');
        });
    </script>
</Fragment>
</BaseLayout>
