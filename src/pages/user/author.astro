---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Author Profile — GroupsMix"
  description="Author profile and articles on GroupsMix."
  cssFiles={["/assets/css/articles.css","/assets/css/fuel-community.css"]}
  includeFuel={true}
  includeFuelComponents={true}
>

        <div class="author-profile" id="author-profile">
            <!-- Loading skeleton -->
            <div class="author-profile__hero">
                <div class="skeleton" style="width:96px;height:96px;border-radius:50%;flex-shrink:0"></div>
                <div style="flex:1">
                    <div class="skeleton" style="height:28px;width:200px;margin-bottom:var(--space-2)"></div>
                    <div class="skeleton" style="height:16px;width:120px;margin-bottom:var(--space-2)"></div>
                    <div class="skeleton" style="height:14px;width:80%;margin-bottom:var(--space-3)"></div>
                    <div style="display:flex;gap:var(--space-6)">
                        <div class="skeleton" style="height:40px;width:60px"></div>
                        <div class="skeleton" style="height:40px;width:60px"></div>
                        <div class="skeleton" style="height:40px;width:60px"></div>
                    </div>
                </div>
            </div>
            <div id="author-analytics" class="author-analytics"></div>
            <!-- Fuel the Community: Writer Level & Badges -->
            <div id="author-fuel-section"></div>
            <h2 style="font-size:var(--text-xl);font-weight:var(--font-bold);margin-bottom:var(--space-4)">Articles</h2>
            <div id="author-articles" class="articles-grid">
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div></div></div>
                <div class="article-skeleton"><div class="article-skeleton__image"></div><div class="article-skeleton__body"><div class="article-skeleton__line article-skeleton__line--title"></div><div class="article-skeleton__line article-skeleton__line--text"></div></div></div>
            </div>
            <div id="author-empty" class="articles-empty" style="display:none">
                <div class="articles-empty__icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <div class="articles-empty__title">No Articles Yet</div>
                <div class="articles-empty__text">This author hasn't published any articles yet.</div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', async () => {
            const params = new URLSearchParams(window.location.search);
            const authorId = params.get('id');
            if (!authorId) { window.location.href = '/articles'; return; }

            // Wait for auth to be ready before checking user state
            await Auth.waitForAuth();

            try {
                // Load author profile
                const { data: author, error } = await window.supabaseClient
                    .from('users')
                    .select('*')
                    .eq('id', authorId)
                    .single();

                if (error || !author) {
                    document.getElementById('author-profile').innerHTML =
                        '<div class="articles-empty"><div class="articles-empty__title">Author Not Found</div>' +
                        '<a href="/articles" class="btn btn-primary btn-sm">Back to Articles</a></div>';
                    return;
                }

                document.title = Security.sanitize(author.display_name || 'Author') + ' — GroupsMix';

                // Check if current user follows this author
                let isFollowing = false;
                const currentUser = Auth.getUser();
                if (currentUser) {
                    const { data: followCheck } = await window.supabaseClient
                        .from('user_follows')
                        .select('follower_id')
                        .eq('follower_id', currentUser.id)
                        .eq('following_id', authorId)
                        .maybeSingle();
                    isFollowing = !!followCheck;
                }

                const initial = (author.display_name || 'A').charAt(0).toUpperCase();
                const isOwnProfile = currentUser && currentUser.id === authorId;

                // Badge rendering (legacy badges from writer_badges array)
                const badges = (author.writer_badges || []);
                const badgeLabels = {
                    first_article: 'First Article',
                    prolific_writer: 'Prolific Writer',
                    popular_writer: 'Popular Writer',
                    viral_author: 'Viral Author',
                    rising_star: 'Rising Star',
                    trusted_author: 'Trusted Author'
                };

                const badgeHtml = badges.map(b =>
                    '<span class="writer-badge writer-badge--' + b + '">' + (badgeLabels[b] || b) + '</span>'
                ).join('');

                // Render hero with Fuel button
                const heroEl = document.querySelector('.author-profile__hero');
                heroEl.innerHTML =
                    '<div class="author-profile__avatar">' +
                        (author.photo_url
                            ? '<img src="' + Security.sanitize(author.photo_url) + '" alt="' + Security.sanitize(author.display_name || '').replace(/"/g, '&quot;') + '">'
                            : initial) +
                    '</div>' +
                    '<div class="author-profile__info">' +
                        '<div class="author-profile__name">' + Security.sanitize(author.display_name || 'Anonymous') +
                            ' ' + UI.fuelLevelBadge(author.writer_level, author.writer_xp) +
                        '</div>' +
                        '<div class="author-profile__username">@' + Security.sanitize(author.username || author.id.slice(0, 8)) + '</div>' +
                        (author.bio ? '<div class="author-profile__bio">' + Security.sanitize(author.bio) + '</div>' : '') +
                        '<div class="author-profile__stats">' +
                            '<div class="author-profile__stat"><div class="author-profile__stat-value">' + UI.formatNumber(author.article_count || 0) + '</div><div class="author-profile__stat-label">Articles</div></div>' +
                            '<div class="author-profile__stat"><div class="author-profile__stat-value">' + UI.formatNumber(author.follower_count || 0) + '</div><div class="author-profile__stat-label">Followers</div></div>' +
                            '<div class="author-profile__stat"><div class="author-profile__stat-value">' + UI.formatNumber(author.following_count || 0) + '</div><div class="author-profile__stat-label">Following</div></div>' +
                            '<div class="author-profile__stat"><div class="author-profile__stat-value">' + UI.formatNumber(author.writer_xp || author.writer_points || 0) + '</div><div class="author-profile__stat-label">XP</div></div>' +
                        '</div>' +
                        (badgeHtml ? '<div class="author-profile__badges" style="margin-top:var(--space-3)">' + badgeHtml + '</div>' : '') +
                    '</div>' +
                    '<div class="author-profile__actions">' +
                        (!isOwnProfile && currentUser
                            ? '<button id="btn-follow-author" class="btn ' + (isFollowing ? 'btn-secondary' : 'btn-primary') + ' btn-sm">' +
                                (isFollowing ? 'Following' : 'Follow') +
                              '</button> '
                            : '') +
                        (!isOwnProfile
                            ? UI.fuelButton(authorId, author.display_name)
                            : '<a href="/write-article" class="btn btn-primary btn-sm">Write Article</a> ' +
                              '<a href="/pages/user/wallet.html" class="btn btn-secondary btn-sm">My Wallet</a>') +
                    '</div>';

                // Initialize Fuel button
                UI.initFuelButtons(heroEl);

                // Follow button handler
                const followBtn = document.getElementById('btn-follow-author');
                if (followBtn && currentUser) {
                    followBtn.addEventListener('click', async () => {
                        followBtn.disabled = true;
                        try {
                            const result = await window.supabaseClient.rpc('toggle_follow', {
                                p_follower_id: currentUser.id,
                                p_following_id: authorId
                            });
                            if (result.data && result.data.action === 'followed') {
                                followBtn.textContent = 'Following';
                                followBtn.className = 'btn btn-secondary btn-sm';
                                UI.toast('Following ' + Security.sanitize(author.display_name), 'success');
                            } else {
                                followBtn.textContent = 'Follow';
                                followBtn.className = 'btn btn-primary btn-sm';
                            }
                        } catch (err) {
                            console.error('Follow toggle:', err.message);
                            UI.toast('Failed to update follow status', 'error');
                        }
                        followBtn.disabled = false;
                    });
                }

                // Load author stats (analytics)
                try {
                    const { data: stats } = await window.supabaseClient.rpc('get_author_stats', { p_user_id: author.auth_id || authorId });
                    if (stats) {
                        const analyticsEl = document.getElementById('author-analytics');
                        analyticsEl.innerHTML =
                            '<div class="analytics-card"><div class="analytics-card__value">' + UI.formatNumber(stats.total_views || 0) + '</div><div class="analytics-card__label">Total Views</div></div>' +
                            '<div class="analytics-card"><div class="analytics-card__value">' + UI.formatNumber(stats.total_likes || 0) + '</div><div class="analytics-card__label">Total Likes</div></div>' +
                            '<div class="analytics-card"><div class="analytics-card__value">' + UI.formatNumber(stats.total_comments || 0) + '</div><div class="analytics-card__label">Total Comments</div></div>' +
                            '<div class="analytics-card"><div class="analytics-card__value">' + UI.formatNumber(stats.total_shares || 0) + '</div><div class="analytics-card__label">Total Shares</div></div>' +
                            '<div class="analytics-card"><div class="analytics-card__value">' + (stats.avg_reading_time || 0) + ' min</div><div class="analytics-card__label">Avg Reading Time</div></div>';
                    }
                } catch (e) { /* ok */ }

                // ═══════════════════════════════════════
                // FUEL THE COMMUNITY: Writer Level, Badges, Tip stats
                // ═══════════════════════════════════════
                try {
                    var fuelSection = document.getElementById('author-fuel-section');
                    var [userBadges, badgeDefs] = await Promise.all([
                        WriterBadges.getUserBadges(authorId),
                        WriterBadges.getDefinitions()
                    ]);

                    var fuelHtml = '';

                    // Writer Level Card
                    fuelHtml += UI.fuelLevelCard(author.writer_level, author.writer_xp);

                    // Badge Showcase
                    fuelHtml += UI.fuelBadgeShowcase(userBadges, badgeDefs);

                    fuelSection.innerHTML = fuelHtml;
                } catch (e) {
                    console.error('Fuel section error:', e.message);
                }

                // Load author articles
                const { data: articles } = await window.supabaseClient
                    .from('articles')
                    .select('*')
                    .eq('user_id', author.auth_id || authorId)
                    .eq('status', 'published')
                    .eq('moderation_status', 'approved')
                    .order('published_at', { ascending: false })
                    .limit(20);

                const articlesEl = document.getElementById('author-articles');
                const emptyEl = document.getElementById('author-empty');

                if (!articles || articles.length === 0) {
                    articlesEl.style.display = 'none';
                    emptyEl.style.display = 'block';
                } else {
                    articlesEl.innerHTML = articles.map(a => UI.articleCardEnhanced(a)).join('');
                    // Init interaction toolbars
                    if (typeof UI.initInteractionToolbar === 'function') {
                        UI.initInteractionToolbar();
                    }
                }
            } catch (err) {
                console.error('Author profile error:', err.message);
                document.getElementById('author-profile').innerHTML =
                    '<div style="text-align:center;color:var(--text-tertiary);padding:var(--space-8)">Unable to load author profile</div>';
            }
        });
    </script>
</Fragment>
</BaseLayout>
