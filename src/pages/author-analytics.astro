---
---
<BaseLayout
  title="Author Analytics — GroupsMix"
  description="Track your article performance — views, read completion, traffic sources, and earnings."
  noIndex={true}
  cssFiles={["/assets/css/articles.css"]}
>
<style is:inline>
        .analytics {
            max-width: var(--container-lg);
            margin: 0 auto;
            padding: var(--space-8) var(--space-4);
        }

        .analytics__header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: var(--space-6);
            flex-wrap: wrap;
            gap: var(--space-3);
        }

        .analytics__title {
            font-size: var(--text-2xl);
            font-weight: var(--font-bold);
        }

        .analytics__period {
            display: flex;
            gap: var(--space-2);
        }

        .analytics__period-btn {
            padding: var(--space-1) var(--space-3);
            border-radius: var(--radius-full);
            border: 1px solid var(--border-primary);
            background: var(--bg-card);
            color: var(--text-secondary);
            font-size: var(--text-sm);
            cursor: pointer;
            transition: all 0.15s ease;
        }

        .analytics__period-btn--active {
            background: var(--accent-primary);
            color: #fff;
            border-color: var(--accent-primary);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: var(--space-4);
            margin-bottom: var(--space-6);
        }

        .stat-box {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-5);
            text-align: center;
        }

        .stat-box__value {
            font-size: var(--text-2xl);
            font-weight: var(--font-bold);
            color: var(--text-primary);
        }

        .stat-box__label {
            font-size: var(--text-sm);
            color: var(--text-secondary);
            margin-top: var(--space-1);
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-5);
            margin-bottom: var(--space-5);
        }

        .chart-card__title {
            font-size: var(--text-lg);
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-4);
        }

        .bar-chart {
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 160px;
            padding-top: var(--space-2);
        }

        .bar-chart__bar {
            flex: 1;
            min-width: 6px;
            background: var(--accent-primary);
            border-radius: var(--radius-sm) var(--radius-sm) 0 0;
            transition: height 0.3s ease;
            position: relative;
            cursor: pointer;
        }

        .bar-chart__bar:hover {
            opacity: 0.8;
        }

        .bar-chart__bar:hover::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-primary);
            color: var(--text-primary);
            padding: 2px 6px;
            border-radius: var(--radius-sm);
            font-size: 10px;
            white-space: nowrap;
            border: 1px solid var(--border-primary);
            z-index: 10;
        }

        .chart-labels {
            display: flex;
            gap: 2px;
            margin-top: var(--space-1);
        }

        .chart-labels span {
            flex: 1;
            text-align: center;
            font-size: 9px;
            color: var(--text-tertiary);
            overflow: hidden;
        }

        .source-list {
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
        }

        .source-item {
            display: flex;
            align-items: center;
            gap: var(--space-3);
        }

        .source-item__bar-bg {
            flex: 1;
            height: 8px;
            background: var(--bg-tertiary);
            border-radius: var(--radius-full);
            overflow: hidden;
        }

        .source-item__bar-fill {
            height: 100%;
            background: var(--accent-primary);
            border-radius: var(--radius-full);
            transition: width 0.5s ease;
        }

        .source-item__name {
            font-size: var(--text-sm);
            min-width: 100px;
        }

        .source-item__count {
            font-size: var(--text-sm);
            color: var(--text-secondary);
            min-width: 50px;
            text-align: right;
        }

        .top-articles-list {
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
        }

        .top-article {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-3) var(--space-4);
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-md);
            text-decoration: none;
            color: inherit;
            transition: background 0.15s ease;
        }

        .top-article:hover {
            background: var(--bg-card-hover);
        }

        .top-article__title {
            font-size: var(--text-sm);
            font-weight: var(--font-medium);
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .top-article__stats {
            display: flex;
            gap: var(--space-4);
            font-size: var(--text-xs);
            color: var(--text-secondary);
            flex-shrink: 0;
            margin-left: var(--space-4);
        }

        .analytics-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-5);
        }

        @media (max-width: 768px) {
            .analytics-grid-2 {
                grid-template-columns: 1fr;
            }
        }
    </style>

        <div class="analytics" id="analytics-page">
            <div class="analytics__header">
                <div style="display:flex;align-items:center;gap:var(--space-3)">
                    <a href="/articles" class="btn btn-ghost btn-sm" title="Back to Articles">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    </a>
                    <h1 class="analytics__title">Author Analytics</h1>
                </div>
                <div class="analytics__period">
                    <button class="analytics__period-btn" data-days="7">7 days</button>
                    <button class="analytics__period-btn analytics__period-btn--active" data-days="30">30 days</button>
                    <button class="analytics__period-btn" data-days="90">90 days</button>
                </div>
            </div>

            <!-- Stats summary -->
            <div class="stats-grid" id="analytics-stats">
                <div class="stat-box"><div class="stat-box__value skeleton" style="height:32px;width:60px;margin:0 auto"></div><div class="stat-box__label">Total Views</div></div>
                <div class="stat-box"><div class="stat-box__value skeleton" style="height:32px;width:60px;margin:0 auto"></div><div class="stat-box__label">Avg Read %</div></div>
                <div class="stat-box"><div class="stat-box__value skeleton" style="height:32px;width:60px;margin:0 auto"></div><div class="stat-box__label">Articles</div></div>
                <div class="stat-box"><div class="stat-box__value skeleton" style="height:32px;width:60px;margin:0 auto"></div><div class="stat-box__label">Earnings</div></div>
            </div>

            <!-- Charts -->
            <div id="analytics-charts">
                <div class="chart-card">
                    <div class="chart-card__title">Views Over Time</div>
                    <div class="skeleton" style="height:160px;border-radius:var(--radius-md)"></div>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', async () => {
            await Auth.waitForAuth();
            if (!Auth.isLoggedIn()) {
                UI.toast('Please sign in to view analytics.', 'warning');
                UI.authModal('signin');
                return;
            }
            AuthorAnalytics.init();
        });
    </script>
</Fragment>
</BaseLayout>
