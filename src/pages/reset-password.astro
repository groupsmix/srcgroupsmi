---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Reset Password — GroupsMix"
  noIndex={true}
  mainStyle="min-height:100vh;display:flex;align-items:center;justify-content:center"
>

        <div class="card" style="max-width:400px;width:100%;margin:var(--space-4)">
            <div class="card__body" style="padding:var(--space-6)">
                <h1 style="text-align:center;margin-bottom:var(--space-6)">🔑 Reset Password</h1>
                <form id="reset-form">
                    <div class="form-group"><label class="form-label" for="new-password">New Password</label><input
                            type="password" class="form-input" id="new-password" placeholder="Min 8 characters (Aa1!@)"
                            minlength="8" required>
                        <!-- Security: real-time password strength meter -->
                        <div id="reset-pw-strength"></div>
                    </div>
                    <div class="form-group"><label class="form-label" for="confirm-password">Confirm
                            Password</label><input type="password" class="form-input" id="confirm-password"
                            placeholder="Confirm" required></div>
                    <button type="submit" class="btn btn-primary btn-full">Update Password</button>
                </form>
                <div style="text-align:center;margin-top:var(--space-4)"><a href="/" style="font-size:var(--text-sm)">←
                        Back to Home</a></div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        // Security: real-time password strength meter on input
        document.getElementById('new-password')?.addEventListener('input', function() {
            var container = document.getElementById('reset-pw-strength');
            if (container) {
                container.innerHTML = this.value ? UI._passwordStrengthMeter(this.value) : '';
            }
        });
        document.getElementById('reset-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const pw = document.getElementById('new-password').value;
            const confirm = document.getElementById('confirm-password').value;
            // Security: enforce strong password requirements
            var pwCheck = Security.validatePassword(pw);
            if (!pwCheck.valid) { UI.toast(pwCheck.errors[0], 'error'); return; }
            if (pw !== confirm) { UI.toast('Passwords do not match', 'error'); return; }
            // Bug fix: use Auth.updatePassword() instead of direct Supabase call
            // This ensures centralized error handling and password validation
            var btn = e.target.querySelector('button[type="submit"]');
            if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span> Updating...'; }
            const success = await Auth.updatePassword(pw);
            if (!success) {
                if (btn) { btn.disabled = false; btn.textContent = 'Update Password'; }
                return;
            }
            UI.toast('Password updated successfully!', 'success');
            setTimeout(() => { window.location.href = '/'; }, 2000);
        });
    </script>
</Fragment>
</BaseLayout>
