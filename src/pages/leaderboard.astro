---
---
<BaseLayout
  title="Leaderboard — GroupsMix"
  description="See the top contributors on GroupsMix. Earn GXP by submitting groups, leaving reviews, and more."
  cssFiles={["/assets/css/fuel-community.css"]}
  includeFuel={true}
  includeFuelComponents={true}
>

        <div class="container s-c8ac4d">
            <h1 class="s-7bfe81">Leaderboard</h1>
            <p class="s-8e0887">Top contributors
                ranked by GXP</p>

            <!-- Leaderboard Type Tabs -->
            <div class="s-f80c56">
                <button class="btn btn-sm btn-primary lb-tab" data-type="xp">By XP</button>
                <button class="btn btn-sm btn-ghost lb-tab" data-type="tips">Top Fueled</button>
                <button class="btn btn-sm btn-ghost lb-tab" data-type="articles">Most Articles</button>
            </div>

            <div class="card">
                <div class="card__body s-a2e94d">
                    <div id="leaderboard-list">
                        <div class="skeleton s-932ea1"></div>
                    </div>
                </div>
            </div>

            <!-- Top Fueled Authors Section -->
            <div class="s-d16db5">
                <h2 class="s-e72fac">Top Fueled Authors</h2>
                <p class="s-548e0c">Writers who received the most tips from the community</p>
                <div id="top-fueled-list">
                    <div class="skeleton s-61356f"></div>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            loadLeaderboard('xp');
            loadTopFueled();

            // Tab switching
            document.querySelectorAll('.lb-tab').forEach(function (tab) {
                tab.addEventListener('click', function () {
                    document.querySelectorAll('.lb-tab').forEach(function (t) { t.className = 'btn btn-sm btn-ghost lb-tab'; });
                    tab.className = 'btn btn-sm btn-primary lb-tab';
                    loadLeaderboard(tab.dataset.type);
                });
            });
        });

        async function loadLeaderboard(type) {
            var el = document.getElementById('leaderboard-list');
            el.innerHTML = '<div class="skeleton" style="height:400px"></div>';
            try {
                // Try Fuel leaderboard first, fall back to legacy
                var data = null;
                try {
                    data = await OwnerDashboard.getLeaderboard(type, 50);
                } catch (e) { /* fallback */ }

                if (!data || !data.length) {
                    // Fallback to legacy leaderboard
                    data = await DB.user.getLeaderboard({ limit: 50 });
                }

                if (!data || !data.length) {
                    el.innerHTML = '<div style="padding:var(--space-8);text-align:center;color:var(--text-tertiary)">No users yet</div>';
                    return;
                }

                var currentUserId = Auth.getUserId();
                el.innerHTML = '<div style="padding:var(--space-2)">' +
                    data.map(function (u, i) {
                        return UI.fuelLeaderboardRow(u, i + 1);
                    }).join('') +
                    '</div>';

            } catch (err) {
                console.error('Leaderboard error:', err);
                el.innerHTML = '<div style="padding:var(--space-4);text-align:center;color:var(--text-tertiary)">Unable to load</div>';
            }
        }

        async function loadTopFueled() {
            var el = document.getElementById('top-fueled-list');
            try {
                var authors = await Tips.getTopFueledAuthors(10);
                if (!authors || !authors.length) {
                    el.innerHTML = '<div style="text-align:center;padding:var(--space-6);color:var(--text-tertiary);background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--border-primary)">No tips yet. Be the first to fuel a writer!</div>';
                    return;
                }
                el.innerHTML = '<div class="card"><div class="card__body" style="padding:var(--space-2)">' +
                    authors.map(function (a, i) {
                        var user = a.users || {};
                        return '<div class="fuel-lb-row">' +
                            '<div class="fuel-lb-row__rank"><span class="fuel-lb-rank">#' + (i + 1) + '</span></div>' +
                            '<div class="fuel-lb-row__avatar">' +
                            (user.photo_url ? '<img src="' + Security.sanitize(user.photo_url) + '" class="fuel-lb-row__img" loading="lazy">' : '<div class="fuel-lb-row__placeholder">' + (user.display_name || '?').charAt(0).toUpperCase() + '</div>') +
                            '</div>' +
                            '<div class="fuel-lb-row__info">' +
                            '<a href="/author?id=' + user.id + '" class="fuel-lb-row__name">' + Security.sanitize(user.display_name || 'Anonymous') + '</a>' +
                            (user.writer_level ? UI.fuelLevelBadge(user.writer_level, user.writer_xp) : '') +
                            '</div>' +
                            '<div class="fuel-lb-row__xp">' + Wallet.formatCoins(a.total_received) + ' GMX</div>' +
                            '</div>';
                    }).join('') +
                    '</div></div>';
            } catch (err) {
                el.innerHTML = '<div style="text-align:center;padding:var(--space-4);color:var(--text-tertiary)">Unable to load</div>';
            }
        }
    </script>
</Fragment>
</BaseLayout>

<style>
/* inline-styles: migrated */
.s-548e0c { text-align:center;color:var(--text-secondary);margin-bottom:var(--space-6);font-size:var(--text-sm); }
.s-61356f { height:200px;border-radius:var(--radius-lg); }
.s-7bfe81 { text-align:center;margin-bottom:var(--space-2); }
.s-8e0887 { text-align:center;color:var(--text-secondary);margin-bottom:var(--space-6); }
.s-932ea1 { height:400px; }
.s-a2e94d { padding:0; }
.s-c8ac4d { max-width:var(--container-md);padding:var(--space-8) var(--space-4); }
.s-d16db5 { margin-top:var(--space-8); }
.s-e72fac { text-align:center;margin-bottom:var(--space-4);font-size:var(--text-lg); }
.s-f80c56 { display:flex;justify-content:center;gap:var(--space-2);margin-bottom:var(--space-6);flex-wrap:wrap; }
</style>
