---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Browse by Category — GroupsMix"
  description="Browse social media groups by category. Find groups about crypto, gaming, education, and more."
>
<style is:inline>
        .browse-hero {
            padding: var(--space-8) 0;
            text-align: center;
        }

        .browse-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-3);
            margin-bottom: var(--space-8);
        }

        .browse-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: var(--space-4);
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .browse-card:hover {
            border-color: var(--accent-primary);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: var(--text-primary);
        }

        .browse-card--active {
            border-color: var(--accent-primary);
            background: var(--accent-primary-light);
        }

        .browse-card__emoji {
            font-size: var(--text-3xl);
            margin-bottom: var(--space-2);
        }

        .browse-card__name {
            font-weight: var(--font-semibold);
            font-size: var(--text-sm);
        }

        @media (max-width: 767px) {
            .browse-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>


        <div class="container">
            <section class="browse-hero">
                <h1>📂 Browse by Category</h1>
                <p style="color:var(--text-secondary);margin-top:var(--space-2)">Discover groups organized by interest
                </p>
            </section>
            <div class="browse-grid" id="category-grid"></div>
            <div id="filter-container" style="display:none;margin-bottom:var(--space-6)"></div>
            <div id="results-header" style="display:none;margin-bottom:var(--space-4)">
                <h2 id="results-title" style="font-size:var(--text-xl)"></h2>
                <span id="results-count" style="color:var(--text-secondary);font-size:var(--text-sm)"></span>
            </div>
            <div id="results-container"></div>
            <div id="pagination-container"></div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', initPage);
        let currentCategory = '', currentPage = 1;
        let currentFilters = { platform: '', country: '', sort: 'ranking' };

        function initPage() {
            const params = new URLSearchParams(window.location.search);
            currentCategory = params.get('cat') || '';
            currentFilters.platform = params.get('platform') || '';
            currentFilters.country = params.get('country') || '';
            currentFilters.sort = params.get('sort') || 'ranking';

            renderGrid();
            if (currentCategory) {
                renderFilters();
                loadGroups();
            }
        }

        function renderGrid() {
            document.getElementById('category-grid').innerHTML = CONFIG.categories.map(c =>
                '<div class="browse-card' + (currentCategory === c.id ? ' browse-card--active' : '') + '" data-id="' + c.id + '">' +
                '<span class="browse-card__emoji">' + c.emoji + '</span><span class="browse-card__name">' + c.name + '</span></div>'
            ).join('');
            document.querySelectorAll('.browse-card').forEach(card => {
                card.addEventListener('click', () => {
                    currentCategory = card.dataset.id;
                    currentPage = 1;
                    updateUrl();
                    document.querySelectorAll('.browse-card').forEach(c => c.classList.remove('browse-card--active'));
                    card.classList.add('browse-card--active');
                    renderFilters();
                    loadGroups();
                });
            });
        }

        function renderFilters() {
            const fc = document.getElementById('filter-container');
            fc.style.display = 'block';
            fc.innerHTML = UI.searchFilters({ category: currentCategory, ...currentFilters });
            UI.initFilters(onFilterChange);
        }

        function onFilterChange(filters) {
            currentCategory = filters.category || '';
            Object.assign(currentFilters, filters);
            currentPage = 1;
            updateUrl();
            document.querySelectorAll('.browse-card').forEach(c => c.classList.remove('browse-card--active'));
            if (currentCategory) {
                const card = document.querySelector('.browse-card[data-id="' + currentCategory + '"]');
                if (card) card.classList.add('browse-card--active');
            } else {
                document.getElementById('filter-container').style.display = 'none';
                document.getElementById('results-header').style.display = 'none';
                document.getElementById('results-container').innerHTML = '';
                document.getElementById('pagination-container').innerHTML = '';
                return; // if they cleared category
            }
            renderFilters();
            loadGroups();
        }

        function updateUrl() {
            const params = new URLSearchParams();
            if (currentCategory) params.set('cat', currentCategory);
            if (currentFilters.platform) params.set('platform', currentFilters.platform);
            if (currentFilters.country) params.set('country', currentFilters.country);
            if (currentFilters.sort && currentFilters.sort !== 'ranking') params.set('sort', currentFilters.sort);
            const qs = params.toString();
            history.replaceState(null, '', window.location.pathname + (qs ? '?' + qs : ''));
        }

        async function loadGroups() {
            const cat = CONFIG.categories.find(c => c.id === currentCategory);
            document.getElementById('results-header').style.display = '';
            document.getElementById('results-title').textContent = (cat?.emoji || '') + ' ' + (cat?.name || currentCategory);
            UI.groupGridSkeleton(12, 'results-container');
            const offset = (currentPage - 1) * CONFIG.perPage;
            try {
                const { data, count } = await DB.groups.getByCategory(currentCategory, { ...currentFilters, limit: CONFIG.perPage, offset });
                document.getElementById('results-count').textContent = (count || 0) + ' groups';
                if (!data?.length) { UI.emptyState('results-container', '📭', 'No Groups Yet', 'Be the first to submit a group in this category!', 'Submit Group', '/submit'); return; }
                UI.groupGrid(data, 'results-container');
                const totalPages = Math.ceil((count || 0) / CONFIG.perPage);
                if (totalPages > 1) {
                    document.getElementById('pagination-container').innerHTML = UI.pagination(currentPage, totalPages);
                    UI.initPagination('pagination-container', (p) => { currentPage = p; loadGroups(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
                }
            } catch { UI.errorState('results-container', loadGroups); }
        }
    </script>
</Fragment>
</BaseLayout>
