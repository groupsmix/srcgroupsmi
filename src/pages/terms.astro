---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Terms of Service — GroupsMix"
  description="GroupsMix terms of service and usage agreement."
  canonical="https://groupsmix.com/terms"
  cssFiles={["/assets/css/legal.css"]}
>

        <div class="legal-container">
            <section class="legal-hero">
                <span class="legal-hero__icon">&#128220;</span>
                <h1>Terms of Service</h1>
                <p class="legal-hero__subtitle">Please read these terms carefully before using GroupsMix.</p>
            </section>

            <nav class="legal-nav">
                <a href="/terms" class="active">Terms</a>
                <a href="/privacy">Privacy</a>
                <a href="/about">About</a>
                <a href="/faq">FAQ</a>
                <a href="/contact">Contact</a>
                <a href="/support">Support Center</a>
            </nav>

            <span class="legal-meta">&#128197; Last updated: March 2026</span>

            <div class="accordion" id="accordion">

                <div class="accordion__item open">
                    <button class="accordion__trigger" aria-expanded="true">
                        1. Acceptance of Terms
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel" style="max-height:800px">
                        <div class="accordion__content">
                            <p>By accessing or using GroupsMix (the "Platform"), you agree to be bound by these Terms of Service. If you do not agree to any part of these terms, you must discontinue use of the Platform immediately.</p>
                            <p>These terms apply to all visitors, registered users, and anyone who accesses or uses our services in any way.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        2. Eligibility &amp; User Accounts
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>To use GroupsMix, you must meet the following requirements:</p>
                            <ul>
                                <li>You must be at least <strong>13 years of age</strong> (or the minimum age required in your country).</li>
                                <li>You are responsible for maintaining the security of your account credentials.</li>
                                <li>You must not share your password or grant access to your account to others.</li>
                                <li>You must not use disposable or temporary email addresses for registration.</li>
                                <li>You must not create multiple accounts for the purpose of manipulating ratings, reviews, or GXP.</li>
                            </ul>
                            <p>We reserve the right to suspend or terminate accounts that violate these requirements without prior notice.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        3. Group Submissions &amp; Content Guidelines
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>When submitting a group to GroupsMix, you confirm that the group is active and that you have the authority to list it. Submitted groups must not contain or promote:</p>
                            <ul>
                                <li>Violence, threats, or incitement of harm against individuals or groups.</li>
                                <li>Hate speech, discrimination, or harassment based on race, gender, religion, nationality, or any protected characteristic.</li>
                                <li>Illegal activities, including but not limited to drug trafficking, fraud, or money laundering.</li>
                                <li>Scams, phishing, pyramid schemes, or deceptive financial offers.</li>
                                <li>Spam, excessive self-promotion, or misleading information.</li>
                                <li>Adult, sexually explicit, or NSFW content.</li>
                                <li>Copyright-infringing or pirated material.</li>
                            </ul>
                            <p>We reserve the right to reject, remove, or delist any group at our sole discretion, with or without notice.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        4. Reviews, Ratings &amp; Reports
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>GroupsMix relies on honest community feedback to maintain trust. When leaving reviews or submitting reports:</p>
                            <ul>
                                <li>Reviews must be based on genuine, first-hand experience with the group.</li>
                                <li>Fabricated, misleading, or incentivized reviews are strictly prohibited.</li>
                                <li>Submitting false or malicious reports against legitimate groups may result in account suspension.</li>
                                <li>Repeated abuse of the review or report system will result in permanent account termination.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        5. GXP (GroupsMix Experience Points)
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>GXP is our reputation and rewards system. Points are earned through legitimate platform activity such as submitting groups, writing reviews, and engaging with the community. The following rules apply:</p>
                            <ul>
                                <li>GXP has no monetary value and cannot be exchanged, transferred, or sold.</li>
                                <li>Any attempt to manipulate or artificially inflate GXP (e.g., using bots, fake accounts, or coordinated actions) will result in GXP reset and potential account suspension.</li>
                                <li>We reserve the right to adjust GXP values, levels, and associated perks at any time.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        6. Payments, Subscriptions &amp; Refunds
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>GroupsMix offers premium VIP plans and services that require payment:</p>
                            <ul>
                                <li><strong>Cryptocurrency payments</strong> (Bitcoin, USDT, Solana) are non-refundable once the transaction has been confirmed on the blockchain.</li>
                                <li><strong>Card payments</strong> processed through LemonSqueezy follow their respective refund and dispute resolution policies.</li>
                                <li>VIP subscriptions can be cancelled at any time, but no prorated refunds will be issued for the remaining billing period.</li>
                                <li>Promotional credits or discounts are non-transferable and may have expiration dates.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        7. Intellectual Property
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>All GroupsMix design, source code, logos, branding, and proprietary algorithms (including the Trust Score system) are the exclusive property of GroupsMix and are protected by applicable intellectual property laws.</p>
                            <p>Content you submit (group listings, reviews, etc.) remains yours. However, by submitting content to the Platform, you grant GroupsMix a worldwide, non-exclusive, royalty-free license to display, distribute, and promote that content within the Platform.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        8. Prohibited Conduct
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>While using GroupsMix, you agree not to:</p>
                            <ul>
                                <li>Attempt to gain unauthorized access to any part of the Platform, other accounts, or our systems.</li>
                                <li>Use automated tools (bots, scrapers, crawlers) to access or collect data from the Platform without prior written consent.</li>
                                <li>Interfere with or disrupt the Platform's operation, servers, or networks.</li>
                                <li>Impersonate any person or entity, or misrepresent your affiliation with any person or entity.</li>
                                <li>Use the Platform for any purpose that is unlawful or prohibited by these terms.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        9. Limitation of Liability
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>GroupsMix is a directory and discovery service. We do not own, operate, or control any of the groups listed on the Platform. Therefore:</p>
                            <ul>
                                <li>We are not responsible for the content, conduct, or safety of any listed group.</li>
                                <li>You join groups at your own discretion and assume all associated risks.</li>
                                <li>GroupsMix is provided "as is" without warranties of any kind, express or implied.</li>
                                <li>In no event shall GroupsMix be liable for any indirect, incidental, special, or consequential damages arising from your use of the Platform.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        10. Account Termination
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>We may suspend or terminate your account at any time if we determine, in our sole discretion, that you have violated these Terms of Service. Upon termination:</p>
                            <ul>
                                <li>Your access to the Platform will be revoked.</li>
                                <li>Any accumulated GXP, badges, or perks will be forfeited.</li>
                                <li>Paid subscriptions will not be refunded for the remaining period.</li>
                            </ul>
                            <p>You may also request account deletion at any time by contacting us through the <a href="/support">Support Center</a>.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        11. Changes to These Terms
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>We may update these Terms of Service from time to time. When changes are made, the "Last updated" date at the top of this page will be revised. Your continued use of GroupsMix after changes are posted constitutes your acceptance of the updated terms.</p>
                            <p>For significant changes, we may notify you via email or a prominent notice on the Platform.</p>
                        </div>
                    </div>
                </div>
                <div class="accordion__item">
                    <button class="accordion__trigger" aria-expanded="false">
                        12. Contact
                        <svg class="accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="accordion__panel">
                        <div class="accordion__content">
                            <p>If you have questions about these Terms of Service, please reach out to us through our <a href="/contact">Contact page</a> or visit the <a href="/support">Support Center</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    (function() {
        var theme = localStorage.getItem('gm_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        document.getElementById('theme-toggle').addEventListener('click', function() {
            theme = theme === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('gm_theme', theme);
        });
        var items = document.querySelectorAll('.accordion__item');
        items.forEach(function(item) {
            var trigger = item.querySelector('.accordion__trigger');
            var panel = item.querySelector('.accordion__panel');
            trigger.addEventListener('click', function() {
                var isOpen = item.classList.contains('open');
                items.forEach(function(other) {
                    other.classList.remove('open');
                    other.querySelector('.accordion__trigger').setAttribute('aria-expanded', 'false');
                    other.querySelector('.accordion__panel').style.maxHeight = null;
                });
                if (!isOpen) {
                    item.classList.add('open');
                    trigger.setAttribute('aria-expanded', 'true');
                    panel.style.maxHeight = panel.scrollHeight + 'px';
                }
            });
        });
    })();
    </script>
</Fragment>
</BaseLayout>
