---
---
<BaseLayout
  title="Redirecting... — GroupsMix"
>
<style is:inline>
        .go-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: var(--space-6);
        }

        .go-card {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-xl);
            padding: var(--space-8);
            max-width: 520px;
            width: 100%;
            text-align: center;
            box-shadow: var(--shadow-lg);
            animation: scaleUp 0.3s ease;
        }

        .go-card__icon {
            font-size: 48px;
            margin-bottom: var(--space-4);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.85; }
        }

        .go-card__title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-2);
        }

        .go-card__message {
            color: var(--text-secondary);
            font-size: var(--text-sm);
            margin-bottom: var(--space-6);
        }

        .countdown-ring {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto var(--space-6);
        }

        .countdown-ring svg {
            transform: rotate(-90deg);
            width: 100px;
            height: 100px;
        }

        .countdown-ring__bg {
            fill: none;
            stroke: var(--bg-tertiary);
            stroke-width: 6;
        }

        .countdown-ring__progress {
            fill: none;
            stroke: var(--accent-primary);
            stroke-width: 6;
            stroke-linecap: round;
            stroke-dasharray: 283;
            stroke-dashoffset: 0;
            transition: stroke-dashoffset 1s linear;
        }

        .countdown-ring__number {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: var(--text-3xl);
            font-weight: var(--font-bold);
            color: var(--accent-primary);
        }

        .go-progress {
            width: 100%;
            height: 6px;
            background: var(--bg-tertiary);
            border-radius: var(--radius-full);
            overflow: hidden;
            margin-bottom: var(--space-6);
        }

        .go-progress__bar {
            height: 100%;
            background: var(--accent-primary);
            border-radius: var(--radius-full);
            width: 0%;
            transition: width 1s linear;
        }

        .go-link-section {
            opacity: 0;
            transform: translateY(8px);
            transition: opacity 0.4s ease, transform 0.4s ease;
            pointer-events: none;
        }

        .go-link-section--visible {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .go-link-section .btn {
            width: 100%;
            font-size: var(--text-base);
            padding: var(--space-3) var(--space-6);
        }

        .go-badges {
            display: flex;
            gap: var(--space-3);
            justify-content: center;
            margin-bottom: var(--space-6);
            flex-wrap: wrap;
        }

        .go-badge {
            display: inline-flex;
            align-items: center;
            gap: var(--space-1);
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            background: var(--bg-tertiary);
            padding: 4px 10px;
            border-radius: var(--radius-full);
        }

        .go-ad-section {
            max-width: 520px;
            width: 100%;
            margin-top: var(--space-6);
        }

        .go-ad-placeholder {
            background: var(--bg-card);
            border: 1px dashed var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-6) var(--space-4);
            text-align: center;
            color: var(--text-tertiary);
            font-size: var(--text-sm);
            margin-bottom: var(--space-4);
        }

        .go-ad-placeholder__label {
            font-size: var(--text-xs);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: var(--space-2);
            color: var(--text-tertiary);
        }

        .go-donate {
            max-width: 520px;
            width: 100%;
            margin-top: var(--space-6);
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-xl);
            padding: var(--space-6);
            text-align: center;
            animation: fadeIn 0.5s ease 2s both;
        }

        .go-donate__title {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-2);
        }

        .go-donate__subtitle {
            color: var(--text-secondary);
            font-size: var(--text-sm);
            margin-bottom: var(--space-4);
        }

        .go-donate__wallets {
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
        }

        .go-donate__wallet {
            display: flex;
            align-items: center;
            gap: var(--space-3);
            background: var(--bg-tertiary);
            padding: var(--space-3) var(--space-4);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: background 0.2s ease;
            text-align: left;
        }

        .go-donate__wallet:hover {
            background: var(--bg-card-hover);
        }

        .go-donate__wallet-icon {
            font-size: var(--text-xl);
            flex-shrink: 0;
        }

        .go-donate__wallet-info {
            flex: 1;
            min-width: 0;
        }

        .go-donate__wallet-name {
            font-weight: var(--font-semibold);
            font-size: var(--text-sm);
        }

        .go-donate__wallet-addr {
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .go-donate__wallet-copy {
            font-size: var(--text-xs);
            color: var(--accent-primary);
            font-weight: var(--font-semibold);
            flex-shrink: 0;
        }

        .go-back {
            margin-top: var(--space-4);
        }

        .go-back a {
            font-size: var(--text-sm);
            color: var(--text-tertiary);
            text-decoration: none;
        }

        .go-back a:hover {
            color: var(--text-primary);
        }

        .go-trust-score {
            display: none;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            margin-bottom: var(--space-4);
            text-align: center;
        }
        .go-trust-score--visible { display: block; }
        .go-trust-score__group-name {
            font-size: var(--text-base);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-2);
            color: var(--text-primary);
        }
        .go-trust-score__meter {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-3);
            margin-top: var(--space-2);
        }
        .go-trust-score__bar {
            flex: 1;
            max-width: 200px;
            height: 10px;
            background: var(--bg-secondary);
            border-radius: 5px;
            overflow: hidden;
        }
        .go-trust-score__fill {
            height: 100%;
            border-radius: 5px;
            transition: width 0.8s ease;
        }
        .go-trust-score__value {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            min-width: 60px;
        }
        .go-trust-score__label {
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            margin-top: var(--space-1);
        }

        @media (max-width: 767px) {
            .go-card { padding: var(--space-6); }
            .go-card__title { font-size: var(--text-lg); }
            .countdown-ring { width: 80px; height: 80px; }
            .countdown-ring svg { width: 80px; height: 80px; }
        }
    </style>


        <div class="go-page">
            <div class="go-card">
                <div class="go-card__icon" id="go-icon">&#128274;</div>
                <div id="go-platform-badge" style="display:none;margin-bottom:var(--space-3)"></div>
                <h1 class="go-card__title" id="go-title">Securing your connection...</h1>
                <p class="go-card__message" id="go-message">We're verifying the group link for your safety. Please wait.</p>
                <div id="go-trust-info" style="display:none;background:var(--bg-tertiary);border:1px solid var(--border-primary);border-radius:var(--radius-lg);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);text-align:left">
                    <div style="display:flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-2)">
                        <span id="go-trust-icon" style="font-size:var(--text-lg)"></span>
                        <strong id="go-group-label" style="font-size:var(--text-sm)"></strong>
                    </div>
                    <div style="font-size:var(--text-xs);color:var(--text-tertiary)">
                        <span>Platform: <strong id="go-platform-name"></strong></span>
                        <span style="margin-left:var(--space-3)">Verified by GroupsMix</span>
                    </div>
                </div>

                <!-- Trust Score + Group Name Section -->
                <div class="go-trust-score" id="go-trust-score">
                    <div class="go-trust-score__group-name" id="go-group-name"></div>
                    <div class="go-trust-score__meter">
                        <div class="go-trust-score__bar">
                            <div class="go-trust-score__fill" id="go-trust-fill" style="width:0%"></div>
                        </div>
                        <div class="go-trust-score__value" id="go-trust-value"></div>
                    </div>
                    <div class="go-trust-score__label">Trust Score &mdash; verified by GroupsMix</div>
                </div>

                <div class="countdown-ring" id="countdown-ring">
                    <svg viewBox="0 0 100 100">
                        <circle class="countdown-ring__bg" cx="50" cy="50" r="45"></circle>
                        <circle class="countdown-ring__progress" id="countdown-progress" cx="50" cy="50" r="45"></circle>
                    </svg>
                    <div class="countdown-ring__number" id="countdown-number">5</div>
                </div>

                <div class="go-progress">
                    <div class="go-progress__bar" id="go-progress-bar"></div>
                </div>

                <div class="go-badges">
                    <span class="go-badge">&#128274; Encrypted</span>
                    <span class="go-badge">&#9989; Verified Link</span>
                    <span class="go-badge">&#128737; Safe Redirect</span>
                </div>

                <div class="go-link-section" id="go-link-section">
                    <a id="go-link" href="#" class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Open Group &rarr;</a>
                </div>

                <div class="go-back">
                    <a href="/">&larr; Back to GroupsMix</a>
                </div>
            </div>

            <!-- Ad Placeholder 1 -->
            <div class="go-ad-section">
                <div class="go-ad-placeholder">
                    <div class="go-ad-placeholder__label">Advertisement</div>
                    <div>Ad Space — 728&times;90</div>
                </div>
            </div>

            <!-- Crypto Donation Section -->
            <div class="go-donate" id="go-donate" style="display:none">
                <div class="go-donate__title">&#10084;&#65039; Show Some Love</div>
                <div class="go-donate__subtitle">Help us keep GroupsMix free and safe for everyone</div>
                <div class="go-donate__wallets" id="donate-wallets"></div>
            </div>

            <!-- Ad Placeholder 2 -->
            <div class="go-ad-section">
                <div class="go-ad-placeholder">
                    <div class="go-ad-placeholder__label">Advertisement</div>
                    <div>Ad Space — 300&times;250</div>
                </div>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', async function () {
            var COUNTDOWN_SECONDS = 5;
            var params = new URLSearchParams(window.location.search);
            var id = params.get('id');
            var encodedLink = params.get('ref');
            var targetUrl = null;

            /* Resolve the target URL */
            // 1. Check for short link code (from link shortener)
            // Audit fix #4: use window.supabaseClient (initialized client) instead of supabase (library namespace)
            var shortCode = params.get('code');
            if (!targetUrl && shortCode) {
                try {
                    var linkRes = await window.supabaseClient.from('short_links').select('id, long_url').eq('code', shortCode).single();
                    if (linkRes.data && linkRes.data.long_url && Security.isValidUrl(linkRes.data.long_url)) {
                        targetUrl = linkRes.data.long_url;
                        // Track click asynchronously
                        try {
                            var ua = navigator.userAgent || '';
                            var device = /mobile|android|iphone|ipad/i.test(ua) ? 'Mobile' : /tablet/i.test(ua) ? 'Tablet' : 'Desktop';
                            window.supabaseClient.from('link_clicks').insert({ link_id: linkRes.data.id, device: device, referrer: document.referrer || '' });
                            window.supabaseClient.rpc('increment_link_clicks', { p_link_id: linkRes.data.id });
                        } catch (e) { /* click tracking is optional */ }
                    }
                } catch (e) { /* fall through */ }
            }

            // 2. Check for obfuscated ref link
            // Audit fix #1: restrict redirects to whitelisted domains to prevent open redirect / phishing
            var ALLOWED_REDIRECT_DOMAINS = [
                'chat.whatsapp.com', 'whatsapp.com', 'www.whatsapp.com',
                't.me', 'telegram.me', 'telegram.org',
                'discord.gg', 'discord.com',
                'facebook.com', 'www.facebook.com', 'fb.com',
                'groupsmix.com', 'www.groupsmix.com'
            ];
            function isAllowedRedirect(url) {
                try {
                    var parsed = new URL(url);
                    if (parsed.protocol !== 'https:' && parsed.protocol !== 'http:') return false;
                    var hostname = parsed.hostname.toLowerCase();
                    return ALLOWED_REDIRECT_DOMAINS.some(function(d) {
                        return hostname === d || hostname.endsWith('.' + d);
                    });
                } catch (e) { return false; }
            }
            if (encodedLink) {
                try {
                    var decoded = Security.deobfuscateLink(encodedLink);
                    if (decoded && Security.isValidUrl(decoded) && isAllowedRedirect(decoded)) {
                        targetUrl = decoded;
                    }
                } catch (e) { /* fall through */ }
            }

            // 3. Check for group ID
            var groupData = null;
            if (!targetUrl && id) {
                try {
                    var group = await DB.groups.getOne(id);
                    if (group && group.link && Security.isValidUrl(group.link)) {
                        targetUrl = group.link;
                        groupData = group;
                        DB.groups.incrementClicks(id);
                        RecentlyViewed.add(group);
                    }
                } catch (e) { /* fall through */ }
            }

            // 4. For short links, try to find the matching group by link URL
            if (!groupData && targetUrl) {
                try {
                    var matchRes = await window.supabaseClient
                        .from('groups').select('*')
                        .eq('link', targetUrl)
                        .eq('status', 'approved')
                        .limit(1)
                        .single();
                    if (matchRes.data) groupData = matchRes.data;
                } catch (e) { /* group lookup is optional */ }
            }

            if (!targetUrl) {
                document.getElementById('go-icon').innerHTML = '&#9888;&#65039;';
                document.getElementById('go-title').textContent = 'Invalid Link';
                document.getElementById('go-message').textContent = 'This group link is invalid or has expired.';
                document.getElementById('countdown-ring').style.display = 'none';
                document.querySelector('.go-progress').style.display = 'none';
                document.querySelector('.go-badges').style.display = 'none';
                return;
            }

            /* Detect platform and show branded landing info */
            var platformInfo = detectPlatform(targetUrl);
            if (platformInfo) {
                var trustInfoEl = document.getElementById('go-trust-info');
                var platformBadge = document.getElementById('go-platform-badge');
                document.getElementById('go-trust-icon').textContent = platformInfo.icon;
                var groupLabel = groupData && groupData.name
                    ? 'You\'re about to join ' + groupData.name + ' on ' + platformInfo.name
                    : 'You\'re about to join a group on ' + platformInfo.name;
                document.getElementById('go-group-label').textContent = groupLabel;
                document.getElementById('go-platform-name').textContent = platformInfo.name;
                document.getElementById('go-title').textContent = 'Verifying ' + platformInfo.name + ' link...';
                document.getElementById('go-message').textContent = 'We\'re checking this group link for your safety.';
                trustInfoEl.style.display = 'block';
                platformBadge.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px;background:' + platformInfo.color + ';color:#fff;padding:4px 12px;border-radius:var(--radius-full);font-size:var(--text-xs);font-weight:600">' + platformInfo.icon + ' ' + platformInfo.name + '</span>';
                platformBadge.style.display = 'block';
            }

            /* Show Trust Score if group data is available */
            if (groupData && typeof Algorithms !== 'undefined') {
                var trustScore = Algorithms.calculateTrustScore(groupData);
                var trustScoreEl = document.getElementById('go-trust-score');
                var trustFill = document.getElementById('go-trust-fill');
                var trustValue = document.getElementById('go-trust-value');
                var groupNameEl = document.getElementById('go-group-name');

                groupNameEl.textContent = groupData.name || 'Unknown Group';

                var trustColor = trustScore >= 70 ? '#10b981' : trustScore >= 40 ? '#f59e0b' : '#ef4444';
                trustFill.style.width = trustScore + '%';
                trustFill.style.background = trustColor;
                trustValue.textContent = trustScore + '/100';
                trustValue.style.color = trustColor;

                trustScoreEl.classList.add('go-trust-score--visible');
            }

            function detectPlatform(url) {
                try {
                    var h = new URL(url).hostname.toLowerCase();
                    if (h.includes('whatsapp.com') || h.includes('wa.me')) return { name: 'WhatsApp', icon: '\uD83D\uDCAC', color: '#25D366' };
                    if (h.includes('t.me') || h.includes('telegram')) return { name: 'Telegram', icon: '\u2708\uFE0F', color: '#0088cc' };
                    if (h.includes('discord')) return { name: 'Discord', icon: '\uD83C\uDFAE', color: '#5865F2' };
                    if (h.includes('facebook.com') || h.includes('fb.com')) return { name: 'Facebook', icon: '\uD83D\uDC65', color: '#1877F2' };
                    return null;
                } catch (e) { return null; }
            }

            /* Render Crypto Donation Wallets */
            renderDonation();

            /* Start Countdown */
            var remaining = COUNTDOWN_SECONDS;
            var circumference = 2 * Math.PI * 45;
            var progressCircle = document.getElementById('countdown-progress');
            var numberEl = document.getElementById('countdown-number');
            var progressBar = document.getElementById('go-progress-bar');

            progressCircle.style.strokeDasharray = circumference;
            progressCircle.style.strokeDashoffset = '0';

            function updateCountdown() {
                numberEl.textContent = remaining;
                var progress = ((COUNTDOWN_SECONDS - remaining) / COUNTDOWN_SECONDS) * 100;
                progressBar.style.width = progress + '%';
                var offset = ((COUNTDOWN_SECONDS - remaining) / COUNTDOWN_SECONDS) * circumference;
                progressCircle.style.strokeDashoffset = offset;
            }

            updateCountdown();

            var timer = setInterval(function () {
                remaining--;
                if (remaining <= 0) {
                    clearInterval(timer);
                    remaining = 0;
                    updateCountdown();
                    progressBar.style.width = '100%';
                    progressCircle.style.strokeDashoffset = circumference;

                    /* Reveal the link */
                    document.getElementById('go-icon').innerHTML = '&#9989;';
                    if (platformInfo) {
                        document.getElementById('go-title').textContent = platformInfo.name + ' Link Verified!';
                        var joinMsg = groupData && groupData.name
                            ? 'You\'re about to join ' + groupData.name + ' on ' + platformInfo.name + '. Redirecting...'
                            : 'You\'re about to join a group on ' + platformInfo.name + '. Redirecting...';
                        document.getElementById('go-message').textContent = joinMsg;
                    } else {
                        document.getElementById('go-title').textContent = 'Connection Secured!';
                        document.getElementById('go-message').textContent = 'Your link is ready. You will be redirected shortly.';
                    }
                    document.getElementById('countdown-ring').style.display = 'none';

                    var linkEl = document.getElementById('go-link');
                    linkEl.href = targetUrl;
                    if (groupData && groupData.name) {
                        linkEl.textContent = 'Join ' + groupData.name + ' \u2192';
                    }
                    document.getElementById('go-link-section').classList.add('go-link-section--visible');

                    /* Auto-redirect after reveal */
                    setTimeout(function () {
                        window.location.href = targetUrl;
                    }, 1500);
                } else {
                    updateCountdown();
                }
            }, 1000);

            /* Donation Section */
            function renderDonation() {
                var wallets = [];
                if (typeof CONFIG !== 'undefined' && CONFIG.cryptoWallets) {
                    var cw = CONFIG.cryptoWallets;
                    if (cw.btc) wallets.push({ name: 'Bitcoin (BTC)', icon: '&#8383;', addr: cw.btc });
                    if (cw.eth) wallets.push({ name: 'Ethereum (ETH)', icon: '&#9830;', addr: cw.eth });
                    if (cw.usdt) wallets.push({ name: 'USDT (TRC20)', icon: '&#128176;', addr: cw.usdt });
                    if (cw.sol) wallets.push({ name: 'Solana (SOL)', icon: '&#9788;', addr: cw.sol });
                    if (cw.ltc) wallets.push({ name: 'Litecoin (LTC)', icon: '&#321;', addr: cw.ltc });
                    if (cw.ton) wallets.push({ name: 'TON', icon: '&#9670;', addr: cw.ton });
                }

                if (!wallets.length) {
                    wallets = [
                        { name: 'Bitcoin (BTC)', icon: '&#8383;', addr: 'bc1q...your-btc-address' },
                        { name: 'Ethereum (ETH)', icon: '&#9830;', addr: '0x...your-eth-address' },
                        { name: 'USDT (TRC20)', icon: '&#128176;', addr: 'T...your-usdt-address' }
                    ];
                }

                var container = document.getElementById('donate-wallets');
                var donateSection = document.getElementById('go-donate');
                if (!container || !donateSection) return;

                donateSection.style.display = '';
                container.innerHTML = wallets.map(function (w) {
                    return '<div class="go-donate__wallet" onclick="copyWallet(this, \'' + w.addr.replace(/'/g, "\\'") + '\')">' +
                        '<div class="go-donate__wallet-icon">' + w.icon + '</div>' +
                        '<div class="go-donate__wallet-info">' +
                        '<div class="go-donate__wallet-name">' + w.name + '</div>' +
                        '<div class="go-donate__wallet-addr">' + w.addr + '</div>' +
                        '</div>' +
                        '<div class="go-donate__wallet-copy">Copy</div>' +
                        '</div>';
                }).join('');
            }
        });

        function copyWallet(el, addr) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(addr).then(function () {
                    var copyEl = el.querySelector('.go-donate__wallet-copy');
                    if (copyEl) {
                        copyEl.textContent = 'Copied!';
                        setTimeout(function () { copyEl.textContent = 'Copy'; }, 2000);
                    }
                    if (typeof UI !== 'undefined' && UI.toast) UI.toast('Address copied!', 'success');
                });
            }
        }
    </script>
</Fragment>
</BaseLayout>
