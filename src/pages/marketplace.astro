---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Digital Products Marketplace — GroupsMix"
  description="Buy & sell digital products — bot templates, design assets, automation workflows, guides, and community tools."
  canonical="https://groupsmix.com/marketplace"
>
<style is:inline>
        .mk-hero {
            text-align: center;
            padding: var(--space-8) 0 var(--space-6);
        }
        .mk-hero__badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary, #6366f1));
            color: #fff;
            padding: var(--space-1) var(--space-3);
            border-radius: var(--radius-full);
            font-size: var(--text-xs);
            font-weight: var(--font-bold);
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: var(--space-3);
        }
        .mk-hero__subtitle {
            color: var(--text-secondary);
            margin-top: var(--space-2);
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        .mk-stats {
            display: flex;
            justify-content: center;
            gap: var(--space-8);
            margin: var(--space-6) 0;
            flex-wrap: wrap;
        }
        .mk-stat {
            text-align: center;
        }
        .mk-stat__value {
            font-size: var(--text-2xl);
            font-weight: var(--font-bold);
            color: var(--accent-primary);
        }
        .mk-stat__label {
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: .05em;
        }
        .mk-section {
            margin-bottom: var(--space-8);
        }
        .mk-section__title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-4);
        }
        /* Marketplace Listings Grid */
        .mk-listings-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-4);
        }
        .mk-listing-card {
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .mk-listing-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            border-color: var(--accent-primary);
        }
        .mk-listing-card__header {
            padding: var(--space-3) var(--space-4);
            display: flex;
            align-items: center;
            gap: var(--space-2);
            border-bottom: 1px solid var(--border-primary);
        }
        .mk-listing-card__platform {
            display: flex;
            align-items: center;
            gap: var(--space-1);
            color: var(--accent-primary);
        }
        .mk-listing-card__platform svg {
            width: 20px;
            height: 20px;
        }
        .mk-listing-card__price {
            margin-left: auto;
            font-weight: var(--font-bold);
            color: var(--success);
            font-size: var(--text-sm);
        }
        .mk-listing-card__report {
            background: none;
            border: none;
            color: var(--text-tertiary);
            cursor: pointer;
            padding: var(--space-1);
            border-radius: var(--radius-sm);
            transition: color 0.2s, background 0.2s;
            display: flex;
            align-items: center;
        }
        .mk-listing-card__report:hover {
            color: var(--error);
            background: var(--error-light);
        }
        .mk-listing-card__body {
            padding: var(--space-3) var(--space-4) var(--space-2);
        }
        .mk-listing-card__title {
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-1);
            font-size: var(--text-base);
        }
        .mk-listing-card__desc {
            color: var(--text-secondary);
            font-size: var(--text-sm);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .mk-listing-card__seller {
            padding: var(--space-2) var(--space-4);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: var(--text-xs);
        }
        .mk-listing-card__seller-link {
            display: flex;
            align-items: center;
            gap: var(--space-1);
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.2s;
        }
        .mk-listing-card__seller-link:hover {
            color: var(--accent-primary);
        }
        .mk-listing-card__rating {
            display: flex;
            align-items: center;
            gap: 2px;
            color: var(--accent-gold);
            font-size: var(--text-xs);
        }
        .mk-listing-card__footer {
            padding: var(--space-3) var(--space-4);
            border-top: 1px solid var(--border-primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mk-listing-card__stats {
            display: flex;
            gap: var(--space-3);
            color: var(--text-tertiary);
            font-size: var(--text-xs);
        }
        .mk-listing-card__contact {
            padding: 2px 12px;
            font-size: 11px;
        }
        /* Filter bar */
        .mk-filters {
            display: flex;
            gap: var(--space-3);
            margin-bottom: var(--space-4);
            flex-wrap: wrap;
            align-items: center;
        }
        .mk-filters select {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-primary);
            color: var(--text-primary);
            padding: var(--space-2) var(--space-3);
            border-radius: var(--radius-md);
            font-size: var(--text-sm);
        }
        /* Category cards */
        .mk-categories {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-3);
            margin-bottom: var(--space-6);
        }
        .mk-category-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-4) var(--space-3);
            background: var(--bg-card);
            border: 2px solid var(--border-primary);
            border-radius: var(--radius-lg);
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: center;
        }
        .mk-category-card:hover {
            border-color: var(--accent-primary);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .mk-category-card--active {
            border-color: var(--accent-primary);
            background: var(--accent-primary-light, rgba(99,102,241,0.08));
        }
        .mk-category-card__icon {
            width: 40px;
            height: 40px;
            color: var(--accent-primary);
        }
        .mk-category-card__icon svg {
            width: 100%;
            height: 100%;
        }
        .mk-category-card__name {
            font-weight: var(--font-semibold);
            font-size: var(--text-sm);
        }
        /* Trending section */
        .mk-trending-scroll {
            display: flex;
            gap: var(--space-3);
            overflow-x: auto;
            padding-bottom: var(--space-2);
            scroll-snap-type: x mandatory;
        }
        .mk-trending-scroll > * {
            flex: 0 0 280px;
            scroll-snap-align: start;
        }
        .mk-trending-badge {
            display: inline-flex;
            align-items: center;
            gap: var(--space-1);
            color: var(--warning);
            font-size: var(--text-xs);
            font-weight: var(--font-bold);
            text-transform: uppercase;
            letter-spacing: .05em;
        }
        .mk-cta {
            margin-top: var(--space-8);
            padding: var(--space-8);
            background: var(--bg-tertiary);
            border-radius: var(--radius-lg);
            text-align: center;
        }
        .mk-cta__title {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
            margin-bottom: var(--space-2);
        }
        .mk-cta__text {
            color: var(--text-secondary);
            margin-bottom: var(--space-4);
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }
        .mk-cta__actions {
            display: flex;
            gap: var(--space-3);
            justify-content: center;
            flex-wrap: wrap;
        }
        @media (max-width: 899px) {
            .mk-listings-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .mk-categories {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        @media (max-width: 599px) {
            .mk-listings-grid {
                grid-template-columns: 1fr;
            }
            .mk-categories {
                grid-template-columns: repeat(2, 1fr);
            }
            .mk-trending-scroll > * {
                flex: 0 0 240px;
            }
            .mk-flash-grid {
                grid-template-columns: 1fr;
            }
        }
        /* ─── Flash Sales Section ─── */
        .mk-flash-section {
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            border-radius: var(--radius-xl);
            padding: var(--space-6);
            margin-bottom: var(--space-8);
        }
        [data-theme="dark"] .mk-flash-section {
            background: linear-gradient(135deg, #78350f33, #92400e33);
        }
        .mk-flash-header {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            margin-bottom: var(--space-4);
        }
        .mk-flash-header svg {
            width: 24px;
            height: 24px;
            color: var(--warning);
        }
        .mk-flash-header h2 {
            font-size: var(--text-lg);
            font-weight: var(--font-bold);
            margin: 0;
        }
        .mk-flash-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-4);
        }
        .mk-flash-card {
            background: var(--bg-card);
            border: 2px solid var(--warning);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            position: relative;
            overflow: hidden;
        }
        .mk-flash-card__badge {
            position: absolute;
            top: 0;
            right: 0;
            background: var(--error);
            color: #fff;
            padding: 2px 12px;
            font-size: 11px;
            font-weight: var(--font-bold);
            border-radius: 0 0 0 var(--radius-md);
        }
        .mk-flash-card__title {
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-2);
            padding-right: var(--space-8);
        }
        .mk-flash-card__prices {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            margin-bottom: var(--space-2);
        }
        .mk-flash-card__original {
            text-decoration: line-through;
            color: var(--text-tertiary);
            font-size: var(--text-sm);
        }
        .mk-flash-card__sale {
            font-weight: var(--font-bold);
            color: var(--error);
            font-size: var(--text-lg);
        }
        .mk-flash-card__timer {
            display: flex;
            align-items: center;
            gap: var(--space-1);
            font-size: var(--text-xs);
            color: var(--text-secondary);
        }
        .mk-flash-card__timer svg {
            width: 14px;
            height: 14px;
        }
        /* ─── Offer Modal ─── */
        .mk-offer-form {
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
        }
        .mk-offer-form .form-input {
            width: 100%;
        }
        .mk-offer-suggestion {
            font-size: var(--text-xs);
            color: var(--text-tertiary);
            margin-top: 2px;
        }
        /* ─── Seller Trust Mini Badge ─── */
        .mk-trust-mini {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 1px 6px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: var(--font-semibold);
            border: 1px solid;
            white-space: nowrap;
            vertical-align: middle;
        }
        .mk-trust-mini svg {
            width: 10px;
            height: 10px;
        }
        /* ─── Also Bought Section ─── */
        .mk-also-bought {
            background: var(--bg-tertiary);
            border-radius: var(--radius-lg);
            padding: var(--space-4);
            margin-top: var(--space-4);
        }
        .mk-also-bought h3 {
            font-size: var(--text-sm);
            font-weight: var(--font-semibold);
            margin-bottom: var(--space-3);
            color: var(--text-secondary);
        }
        .mk-also-bought__list {
            display: flex;
            gap: var(--space-3);
            overflow-x: auto;
        }
        .mk-also-bought__item {
            flex: 0 0 200px;
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-md);
            padding: var(--space-3);
            font-size: var(--text-sm);
            text-decoration: none;
            color: var(--text-primary);
            transition: border-color 0.2s;
        }
        .mk-also-bought__item:hover {
            border-color: var(--accent-primary);
        }
        .mk-also-bought__price {
            color: var(--success);
            font-weight: var(--font-semibold);
            margin-top: var(--space-1);
        }
    </style>


        <div class="container" style="max-width:var(--container-lg);padding:0 var(--space-4)">
            <section class="mk-hero" aria-labelledby="mk-heading">
                <span class="mk-hero__badge">Marketplace</span>
                <h1 id="mk-heading">Digital Products Marketplace</h1>
                <p class="mk-hero__subtitle">Buy & sell digital products — bot templates, design assets, automation workflows, guides, and community management tools. Pay with GMX Coins.</p>
            </section>
            <div class="mk-stats" id="mk-stats" aria-label="Marketplace statistics">
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-ads">--</div>
                    <div class="mk-stat__label">Marketplace Listings</div>
                </div>
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-services">--</div>
                    <div class="mk-stat__label">Service Groups</div>
                </div>
                <div class="mk-stat">
                    <div class="mk-stat__value" id="mk-total-all">--</div>
                    <div class="mk-stat__label">Total Listings</div>
                </div>
            </div>
            <section class="mk-section" aria-labelledby="mk-categories-title">
                <h2 id="mk-categories-title" class="mk-section__title">Browse by Category</h2>
                <div class="mk-categories" id="mk-categories"></div>
            </section>
            <!-- Flash Sales Section -->
            <section class="mk-section" id="mk-flash-section" style="display:none" aria-labelledby="mk-flash-title">
                <div class="mk-flash-section">
                    <div class="mk-flash-header">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                        <h2 id="mk-flash-title">Flash Sales</h2>
                        <span style="margin-left:auto;font-size:var(--text-xs);color:var(--text-secondary)">Limited time deals</span>
                    </div>
                    <div class="mk-flash-grid" id="mk-flash-container"></div>
                </div>
            </section>

            <section class="mk-section" id="mk-trending-section" style="display:none" aria-labelledby="mk-trending-title">
                <h2 id="mk-trending-title" class="mk-section__title">
                    <span class="mk-trending-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                        Trending Now
                    </span>
                </h2>
                <div class="mk-trending-scroll" id="mk-trending-container"></div>
            </section>
            <section class="mk-section" aria-labelledby="mk-ads-title">
                <h2 id="mk-ads-title" class="mk-section__title">Marketplace Listings</h2>
                <div class="mk-filters">
                    <select id="mk-filter-category" aria-label="Filter by category">
                        <option value="">All Categories</option>
                        <option value="templates">Templates</option>
                        <option value="bots">Bots</option>
                        <option value="scripts">Scripts</option>
                        <option value="design_assets">Design Assets</option>
                        <option value="guides">Guides</option>
                        <option value="tools">Tools</option>
                    </select>
                    <select id="mk-filter-sort" aria-label="Sort listings">
                        <option value="smart">Smart (Shuffle + Popular)</option>
                        <option value="newest">Newest First</option>
                        <option value="popular">Most Popular</option>
                        <option value="price_low">Price: Low to High</option>
                        <option value="price_high">Price: High to Low</option>
                    </select>
                    <a href="/sell" class="btn btn-primary btn-sm" style="margin-left:auto">+ List Product</a>
                </div>
                <div id="mk-ads-container">
                    <div class="mk-listings-grid">
                        <div class="skeleton" style="height:260px;border-radius:var(--radius-lg)"></div>
                        <div class="skeleton" style="height:260px;border-radius:var(--radius-lg)"></div>
                        <div class="skeleton" style="height:260px;border-radius:var(--radius-lg)"></div>
                    </div>
                </div>
            </section>
            <section class="mk-section" aria-labelledby="mk-services-title">
                <h2 id="mk-services-title" class="mk-section__title">Service Groups</h2>
                <div id="mk-services-container">
                    <div class="grid grid-4">
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                        <div class="skeleton skeleton-card"></div>
                    </div>
                </div>
            </section>
            <section class="mk-cta" aria-labelledby="mk-cta-title">
                <h2 id="mk-cta-title" class="mk-cta__title">Sell Your Digital Products</h2>
                <p class="mk-cta__text">List your bot templates, design assets, guides, automation workflows, or community tools. Reach thousands of buyers — earn GMX Coins!</p>
                <div class="mk-cta__actions">
                    <a href="/sell" class="btn btn-primary">Create Listing</a>
                    <button class="btn btn-secondary" id="mk-promote-card-btn" type="button">Promote (Featured)</button>
                </div>
            </section>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
    document.addEventListener('DOMContentLoaded', initMarketplace);

    var marketplaceListings = [];
    var serviceGroups = [];
    var mkTimeout = null;
    var mkCurrentCategory = '';
    var mkCurrentSort = 'smart';

    async function initMarketplace() {
        mkTimeout = setTimeout(function() {
            var adsEl = document.getElementById('mk-ads-container');
            var svcEl = document.getElementById('mk-services-container');
            if (adsEl && adsEl.querySelector('.skeleton')) UI.timeoutState('mk-ads-container');
            if (svcEl && svcEl.querySelector('.skeleton')) UI.timeoutState('mk-services-container');
        }, CONFIG.timeoutDuration);
        renderCategories();
        initFilters();
        await loadMarketplace();
        initPromoteButtons();
    }

    function initFilters() {
        var categoryFilter = document.getElementById('mk-filter-category');
        var sortFilter = document.getElementById('mk-filter-sort');
        if (categoryFilter) {
            categoryFilter.addEventListener('change', function() {
                mkCurrentCategory = this.value;
                loadListings();
            });
        }
        if (sortFilter) {
            sortFilter.addEventListener('change', function() {
                mkCurrentSort = this.value;
                loadListings();
            });
        }
    }

    async function loadMarketplace() {
        try {
            await Promise.allSettled([loadListings(), loadServiceGroups(), loadTrending(), loadFlashSales()]);
            clearTimeout(mkTimeout);
            updateStats();
        } catch (err) {
            clearTimeout(mkTimeout);
        }
    }

    function renderCategories() {
        var container = document.getElementById('mk-categories');
        if (!container) return;
        var categories = Marketplace.getCategories();
        // Add "All" option at start
        var html = '<div class="mk-category-card mk-category-card--active" data-category="" tabindex="0" role="button" aria-label="All categories">' +
            '<div class="mk-category-card__icon">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>' +
            '</div>' +
            '<span class="mk-category-card__name">All</span>' +
            '</div>';
        categories.forEach(function(cat) {
            html += '<div class="mk-category-card" data-category="' + cat.id + '" tabindex="0" role="button" aria-label="' + cat.name + '">' +
                '<div class="mk-category-card__icon">' + cat.icon + '</div>' +
                '<span class="mk-category-card__name">' + cat.name + '</span>' +
                '</div>';
        });
        container.innerHTML = html;
        container.querySelectorAll('.mk-category-card').forEach(function(card) {
            card.addEventListener('click', function() {
                container.querySelectorAll('.mk-category-card').forEach(function(c) { c.classList.remove('mk-category-card--active'); });
                card.classList.add('mk-category-card--active');
                mkCurrentCategory = card.dataset.category;
                var categoryFilter = document.getElementById('mk-filter-category');
                if (categoryFilter) categoryFilter.value = mkCurrentCategory;
                loadListings();
            });
            card.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
            });
        });
    }

    async function loadTrending() {
        try {
            var trending = await Marketplace.getTrending(6);
            var section = document.getElementById('mk-trending-section');
            var container = document.getElementById('mk-trending-container');
            if (!section || !container) return;
            if (!trending.length) {
                section.style.display = 'none';
                return;
            }
            section.style.display = '';
            container.innerHTML = trending.map(function(l) { return UI.marketplaceCard(l); }).join('');
            UI.initInteractionToolbar(container);
            container.querySelectorAll('.mk-listing-card__report').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var listingId = btn.dataset.listingId;
                    if (!listingId) return;
                    UI.confirmModal('Report this listing?', 'Are you sure you want to report this listing?', function() {
                        Marketplace.reportListing(listingId);
                    });
                });
            });
            UI._loadSellerRatings(container, trending);
        } catch (err) { console.error('Error loading trending:', err); }
    }

    async function loadListings() {
        try {
            var result = await Marketplace.getListings({
                category: mkCurrentCategory,
                sort: mkCurrentSort,
                limit: 24,
                offset: 0
            });
            marketplaceListings = Array.isArray(result.data) ? result.data : [];
            UI.marketplaceGrid(marketplaceListings, 'mk-ads-container');
            updateStats();
        } catch (err) {
            console.error('Error loading marketplace listings:', err);
            UI.errorState('mk-ads-container', loadListings);
        }
    }

    async function loadServiceGroups() {
        try {
            console.log('Loading service groups...');
            var result = await DB.groups.getApproved({ sort: 'ranking', limit: 24, offset: 0 });
            console.log('Groups loaded:', result);
            var all = Array.isArray(result.data) ? result.data : [];
            serviceGroups = all.filter(function(g) {
                var tags = Array.isArray(g.tags) ? g.tags : [];
                var hasServiceTag = tags.some(function(t) {
                    return t.toLowerCase() === 'service' || t.toLowerCase() === 'services';
                });
                var isServiceCategory = g.category === 'business' || g.category === 'jobs' || g.category === 'marketing';
                return hasServiceTag || isServiceCategory;
            });
            if (!serviceGroups.length) {
                serviceGroups = all.slice(0, 12);
            }
            console.log('Service groups filtered:', serviceGroups);
            renderServices();
        } catch (err) {
            console.error('Error loading service groups:', err);
            UI.errorState('mk-services-container', loadServiceGroups);
        }
    }

    /* renderAds removed — now using UI.marketplaceGrid in loadListings */

    // ─── Flash Sales ───
    async function loadFlashSales() {
        try {
            var sales = await Marketplace.getFlashSales(6);
            var section = document.getElementById('mk-flash-section');
            var container = document.getElementById('mk-flash-container');
            if (!section || !container) return;
            if (!sales.length) { section.style.display = 'none'; return; }
            section.style.display = '';
            container.innerHTML = sales.map(function(l) {
                var endsAt = new Date(l.sale_ends_at);
                var now = Date.now();
                var diff = endsAt.getTime() - now;
                var hours = Math.max(0, Math.floor(diff / 3600000));
                var mins = Math.max(0, Math.floor((diff % 3600000) / 60000));
                var timeStr = hours > 0 ? hours + 'h ' + mins + 'm left' : mins + 'm left';
                var discount = l.sale_discount || Math.round((1 - l.sale_price / l.price) * 100);
                return '<div class="mk-flash-card">' +
                    '<span class="mk-flash-card__badge">-' + discount + '%</span>' +
                    '<div class="mk-flash-card__title">' + Security.sanitize(l.title || '') + '</div>' +
                    '<div class="mk-flash-card__prices">' +
                    '<span class="mk-flash-card__original">' + l.price + ' GMX</span>' +
                    '<span class="mk-flash-card__sale">' + l.sale_price + ' GMX</span>' +
                    '</div>' +
                    '<div class="mk-flash-card__timer" data-ends="' + l.sale_ends_at + '">' +
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' +
                    '<span>' + timeStr + '</span>' +
                    '</div>' +
                    '</div>';
            }).join('');
            // Update timers every minute
            setInterval(function() {
                container.querySelectorAll('.mk-flash-card__timer').forEach(function(el) {
                    var ends = el.dataset.ends;
                    if (!ends) return;
                    var diff = new Date(ends).getTime() - Date.now();
                    if (diff <= 0) { el.querySelector('span').textContent = 'Ended'; return; }
                    var h = Math.floor(diff / 3600000);
                    var m = Math.floor((diff % 3600000) / 60000);
                    el.querySelector('span').textContent = h > 0 ? h + 'h ' + m + 'm left' : m + 'm left';
                });
            }, 60000);
        } catch (err) { console.error('Error loading flash sales:', err); }
    }

    // ─── Make Offer Modal ───
    window.openOfferModal = function(listingId, listPrice) {
        UI.modal({
            title: 'Make an Offer',
            content:
                '<div class="mk-offer-form">' +
                '<p style="color:var(--text-secondary);font-size:var(--text-sm)">List price: <strong>' + listPrice + ' GMX Coins</strong></p>' +
                '<div class="form-group">' +
                '<label class="form-label" for="offer-amount">Your Offer (GMX Coins)</label>' +
                '<input type="number" class="form-input" id="offer-amount" min="1" max="' + (listPrice - 1) + '" placeholder="Enter your offer">' +
                '<div class="mk-offer-suggestion">Tip: Offers around ' + Math.round(listPrice * 0.8) + '–' + Math.round(listPrice * 0.9) + ' GMX are more likely to be accepted</div>' +
                '</div>' +
                '<div class="form-group">' +
                '<label class="form-label" for="offer-message">Message (optional)</label>' +
                '<input type="text" class="form-input" id="offer-message" maxlength="300" placeholder="Hi, I\'m interested in...">' +
                '</div>' +
                '</div>',
            footer: '<button class="btn btn-secondary" onclick="UI.closeModal()" type="button">Cancel</button>' +
                '<button class="btn btn-primary" id="offer-submit-btn" type="button">Send Offer</button>'
        });
        var submitBtn = document.getElementById('offer-submit-btn');
        if (submitBtn) {
            submitBtn.addEventListener('click', async function() {
                var amount = parseInt(document.getElementById('offer-amount').value);
                var message = (document.getElementById('offer-message').value || '').trim();
                if (!amount || amount < 1) { UI.toast('Please enter a valid offer amount.', 'error'); return; }
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="btn-spinner"></span>';
                var result = await Marketplace.makeOffer(listingId, amount, message);
                if (result) {
                    UI.closeModal();
                } else {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Send Offer';
                }
            });
        }
    };

    function renderServices() {
        UI.groupGrid(serviceGroups, 'mk-services-container');
    }

    function updateStats() {
        var adsEl = document.getElementById('mk-total-ads');
        var svcEl = document.getElementById('mk-total-services');
        var allEl = document.getElementById('mk-total-all');
        if (adsEl) UI.countUp(adsEl, marketplaceListings.length);
        if (svcEl) UI.countUp(svcEl, serviceGroups.length);
        if (allEl) UI.countUp(allEl, marketplaceListings.length + serviceGroups.length);
    }

    function initPromoteButtons() {
        var cardBtn = document.getElementById('mk-promote-card-btn');
        var cryptoBtn = document.getElementById('mk-promote-crypto-btn');
        if (cardBtn) {
            cardBtn.addEventListener('click', function() {
                if (!Auth.requireAuth()) return;
                if (CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.products && CONFIG.lemonSqueezy.products.ad_featured_weekly) {
                    window.open(CONFIG.lemonSqueezy.products.ad_featured_weekly, '_blank');
                } else if (CONFIG.lemonSqueezy && CONFIG.lemonSqueezy.storeUrl) {
                    window.open(CONFIG.lemonSqueezy.storeUrl, '_blank');
                } else {
                    UI.toast('Card payments are being set up. Please use crypto or contact support.', 'info');
                }
            });
        }
        if (cryptoBtn) {
            cryptoBtn.addEventListener('click', function() {
                if (!Auth.requireAuth()) return;
                openCryptoPayment();
            });
        }
    }

    function openCryptoPayment() {
        var price = getPrice('ad_featured_weekly');
        UI.modal({
            title: 'Pay with Crypto',
            content:
                '<p style="color:var(--text-secondary);margin-bottom:var(--space-4)">Marketplace Featured Listing: <strong>' + UI.formatCurrency(price) + '/week</strong></p>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-currency">Currency</label>' +
                '<select class="form-select" id="mk-currency">' +
                '<option value="btc">Bitcoin (BTC)</option>' +
                '<option value="usdt">USDT (TRC-20)</option>' +
                '<option value="sol">Solana (SOL)</option>' +
                '</select></div>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-wallet-display">Send to:</label>' +
                '<div class="form-input" id="mk-wallet" style="word-break:break-all;height:auto;padding:10px 14px;cursor:pointer" role="button" tabindex="0" aria-label="Click to copy wallet address">Loading...</div>' +
                '</div>' +
                '<p style="color:var(--warning);font-size:var(--text-xs);margin-bottom:var(--space-3)">Send ONLY via the correct network. Other networks will lose funds.</p>' +
                '<div class="form-group">' +
                '<label class="form-label" for="mk-tx-hash">Transaction Hash *</label>' +
                '<input type="text" class="form-input" id="mk-tx-hash" placeholder="Paste your transaction hash" required>' +
                '</div>',
            footer: '<button class="btn btn-secondary" id="mk-pay-cancel" type="button">Cancel</button>' +
                '<button class="btn btn-primary" id="mk-pay-submit" type="button">Submit Payment</button>'
        });
        updateMkWallet();
        var currencyEl = document.getElementById('mk-currency');
        if (currencyEl) currencyEl.addEventListener('change', updateMkWallet);
        var walletEl = document.getElementById('mk-wallet');
        if (walletEl) {
            walletEl.addEventListener('click', function() { UI.copyToClipboard(this.textContent); });
            walletEl.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    UI.copyToClipboard(this.textContent);
                }
            });
        }
        var cancelBtn = document.getElementById('mk-pay-cancel');
        if (cancelBtn) cancelBtn.addEventListener('click', UI.closeModal);
        var submitBtn = document.getElementById('mk-pay-submit');
        if (submitBtn) {
            submitBtn.addEventListener('click', async function() {
                var txHashEl = document.getElementById('mk-tx-hash');
                var currEl = document.getElementById('mk-currency');
                var txHash = txHashEl ? txHashEl.value.trim() : '';
                var currency = currEl ? currEl.value : 'btc';
                if (!txHash) { UI.toast('Please enter the transaction hash', 'error'); return; }
                if (!Security.isValidTxHash(txHash, currency)) { UI.toast('Invalid transaction hash format', 'error'); return; }
                var btn = document.getElementById('mk-pay-submit');
                if (btn) { btn.disabled = true; btn.innerHTML = '<span class="btn-spinner"></span>'; }
                var result = await DB.payments.submit({
                    type: 'ad',
                    service: 'ad_featured_weekly',
                    currency: currency,
                    amount: price,
                    tx_hash: txHash,
                    wallet_address: CONFIG.cryptoWallets ? CONFIG.cryptoWallets[currency] || '' : ''
                });
                if (result) {
                    UI.toast('Payment submitted! We will verify within 24 hours.', 'success');
                    UI.closeModal();
                } else if (btn) {
                    btn.disabled = false;
                    btn.textContent = 'Submit Payment';
                }
            });
        }
    }

    function updateMkWallet() {
        var currEl = document.getElementById('mk-currency');
        var currency = currEl ? currEl.value : 'btc';
        var el = document.getElementById('mk-wallet');
        if (el) el.textContent = (CONFIG.cryptoWallets && CONFIG.cryptoWallets[currency]) ? CONFIG.cryptoWallets[currency] : 'Not configured - contact admin';
    }
    </script>
</Fragment>
</BaseLayout>
