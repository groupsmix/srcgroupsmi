---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — GroupsMix"
  description="Get in touch with the GroupsMix team."
>
<style is:inline>
        .legal-hero{text-align:center;padding:var(--space-8) 0 var(--space-4)}
        .legal-hero__icon{font-size:var(--text-5xl);margin-bottom:var(--space-3)}
        .legal-hero__subtitle{color:var(--text-secondary);margin-top:var(--space-2);max-width:560px;margin-left:auto;margin-right:auto;font-size:var(--text-base)}
        .glass-card{background:rgba(22,22,31,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(42,42,62,0.6);border-radius:var(--radius-xl);padding:var(--space-6);box-shadow:0 8px 32px rgba(0,0,0,0.2);transition:transform .2s ease,box-shadow .2s ease}
        .glass-card:hover{box-shadow:0 12px 40px rgba(0,0,0,0.3)}
        .glass-card__body{line-height:var(--leading-relaxed);color:var(--text-secondary)}
        .glass-card__body h2{color:var(--text-primary);margin:var(--space-6) 0 var(--space-3);font-size:var(--text-lg);font-weight:var(--font-bold);display:flex;align-items:center;gap:var(--space-2)}
        .glass-card__body h2::before{content:'';width:3px;height:20px;background:var(--accent-primary);border-radius:var(--radius-full);flex-shrink:0}
        .glass-card__body p{margin-bottom:var(--space-3)}
        .glass-card__body ul{margin-bottom:var(--space-4);padding-left:var(--space-4)}
        .glass-card__body ul li{margin-bottom:var(--space-2);line-height:1.6}
        .glass-card__body a{color:var(--accent-primary);text-decoration:none;font-weight:var(--font-medium)}
        .glass-card__body a:hover{text-decoration:underline}
        .legal-meta{display:inline-flex;align-items:center;gap:var(--space-2);padding:var(--space-1) var(--space-3);background:rgba(108,92,231,0.1);border:1px solid rgba(108,92,231,0.2);border-radius:var(--radius-full);font-size:var(--text-xs);color:var(--accent-primary);font-weight:var(--font-semibold);margin-bottom:var(--space-6)}
        .legal-nav{display:flex;gap:var(--space-2);flex-wrap:wrap;justify-content:center;margin-bottom:var(--space-6)}
        .legal-nav a{padding:var(--space-2) var(--space-3);border-radius:var(--radius-full);border:1px solid var(--border-primary);background:var(--bg-card);color:var(--text-secondary);font-size:var(--text-sm);text-decoration:none;transition:all .15s ease}
        .legal-nav a:hover,.legal-nav a.active{background:var(--accent-primary);color:#fff;border-color:var(--accent-primary)}
        [data-theme="light"] .glass-card{background:rgba(255,255,255,0.75);border-color:rgba(200,200,220,0.5);box-shadow:0 8px 32px rgba(0,0,0,0.08)}
        .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-6);margin-bottom:var(--space-8)}
        .contact-card{background:rgba(22,22,31,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(42,42,62,0.6);border-radius:var(--radius-xl);padding:var(--space-6);text-align:center;transition:transform .2s ease,border-color .2s ease}
        .contact-card:hover{transform:translateY(-2px);border-color:var(--accent-primary)}
        .contact-card__icon{font-size:var(--text-4xl);margin-bottom:var(--space-3)}
        .contact-card__title{font-weight:var(--font-bold);margin-bottom:var(--space-2);color:var(--text-primary);font-size:var(--text-base)}
        .contact-card__text{font-size:var(--text-sm);color:var(--text-secondary);line-height:1.6}
        .contact-form-card{background:rgba(22,22,31,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(42,42,62,0.6);border-radius:var(--radius-xl);padding:var(--space-8)}
        .contact-form-card .form-group{margin-bottom:var(--space-4)}
        .contact-form-card .form-label{margin-bottom:var(--space-2);display:block;font-weight:var(--font-medium);color:var(--text-primary);font-size:var(--text-sm)}
        .contact-response-note{text-align:center;margin-top:var(--space-4);font-size:var(--text-sm);color:var(--text-tertiary)}
        [data-theme="light"] .contact-card,[data-theme="light"] .contact-form-card{background:rgba(255,255,255,0.75);border-color:rgba(200,200,220,0.5)}
        @media(max-width:599px){.contact-grid{grid-template-columns:1fr}}
    </style>


        <div class="container" style="max-width:var(--container-md);padding:var(--space-8) var(--space-4)">
            <section class="legal-hero">
                <div class="legal-hero__icon">&#128236;</div>
                <h1>Contact Us</h1>
                <p class="legal-hero__subtitle">Have a question, suggestion, or need help? We&#39;d love to hear from you.</p>
            </section>
            <nav class="legal-nav">
                <a href="/terms">Terms</a>
                <a href="/privacy">Privacy</a>
                <a href="/about">About</a>
                <a href="/faq">FAQ</a>
                <a href="/contact">Contact</a>
                <a href="/support">Support Center</a>
            </nav>
            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-card__icon">&#128231;</div>
                    <div class="contact-card__title">Email Support</div>
                    <div class="contact-card__text">For general inquiries and support requests. We typically respond within 24&ndash;48 hours.</div>
                    <a href="#contact-form-section" style="display:inline-block;margin-top:var(--space-2);font-size:var(--text-sm);color:var(--accent-primary);text-decoration:none;font-weight:var(--font-medium)">&#128232; Use the form below</a>
                </div>
                <div class="contact-card">
                    <div class="contact-card__icon">&#128737;&#65039;</div>
                    <div class="contact-card__title">Report an Issue</div>
                    <div class="contact-card__text">Found a bug or scam group? Use the report button on any group page, or describe the issue below.</div>
                </div>
                <div class="contact-card">
                    <div class="contact-card__icon">&#129309;</div>
                    <div class="contact-card__title">Partnerships</div>
                    <div class="contact-card__text">Interested in advertising, sponsorships, or integrations? Share your proposal with us.</div>
                </div>
                <div class="contact-card">
                    <div class="contact-card__icon">&#128161;</div>
                    <div class="contact-card__title">Feature Requests</div>
                    <div class="contact-card__text">Have an idea to improve GroupsMix? We value community feedback and review every suggestion.</div>
                </div>
            </div>

            <div class="contact-form-card" id="contact-form-section">
                <h2 style="margin-bottom:var(--space-2);text-align:center;color:var(--text-primary)">Send Us a Message</h2>
                <p style="text-align:center;color:var(--text-tertiary);font-size:var(--text-sm);margin-bottom:var(--space-6)">Fill out the form below and we will get back to you as soon as possible.</p>

                <div class="form-group">
                    <label class="form-label" for="contact-name">Name</label>
                    <input type="text" class="form-input" id="contact-name" placeholder="Your full name" maxlength="100">
                </div>
                <div class="form-group">
                    <label class="form-label" for="contact-email">Email</label>
                    <input type="email" class="form-input" id="contact-email" placeholder="your@email.com" maxlength="200">
                </div>
                <div class="form-group">
                    <label class="form-label" for="contact-subject">Subject</label>
                    <select class="form-select" id="contact-subject">
                        <option value="general">General Inquiry</option>
                        <option value="support">Technical Support</option>
                        <option value="report">Report an Issue</option>
                        <option value="partnership">Partnership / Advertising</option>
                        <option value="feature">Feature Request</option>
                        <option value="billing">Billing &amp; Payments</option>
                        <option value="account">Account &amp; Privacy</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="contact-message">Message</label>
                    <textarea class="form-textarea" id="contact-message" placeholder="Describe your question or issue in detail..." maxlength="2000" style="min-height:140px"></textarea>
                </div>
                <div class="form-group" id="contact-turnstile-wrapper" style="display:none"><div id="contact-turnstile-widget"></div></div>
                <button class="btn btn-primary btn-full" id="contact-submit">&#128232; Send Message</button>
                <p class="contact-response-note">We typically respond within 24&ndash;48 hours. For urgent issues, please include &ldquo;URGENT&rdquo; in your subject.</p>
            </div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            var user = Auth.getUser();
            if (user) {
                var nameEl = document.getElementById('contact-name');
                var emailEl = document.getElementById('contact-email');
                if (nameEl && user.display_name) nameEl.value = Security.sanitize(user.display_name);
                if (emailEl && user.email) emailEl.value = Security.sanitize(user.email);
            }
            document.getElementById('contact-submit').addEventListener('click', submitContact);
            /* Turnstile CAPTCHA: poll for SDK readiness */
            if (CONFIG.turnstileSiteKey) {
                var _tsAttempts = 0, _tsMaxAttempts = 50; // 50 × 200 ms = 10 s
                var _tsWrap = document.getElementById('contact-turnstile-wrapper');
                if (_tsWrap) _tsWrap.innerHTML = '<div style="text-align:center;padding:var(--space-2);color:var(--text-tertiary);font-size:var(--text-sm)">Loading CAPTCHA\u2026</div>';
                (function pollTurnstile() {
                    if (typeof turnstile !== 'undefined') {
                        document.getElementById('contact-turnstile-wrapper').style.display = '';
                        if (_tsWrap) _tsWrap.innerHTML = '<div id="contact-turnstile-widget"></div>';
                        turnstile.render('#contact-turnstile-widget', {
                            sitekey: CONFIG.turnstileSiteKey,
                            callback: function(token) { window._contactTurnstileToken = token; }
                        });
                    } else if (++_tsAttempts < _tsMaxAttempts) {
                        if (_tsWrap) _tsWrap.style.display = '';
                        setTimeout(pollTurnstile, 200);
                    } else {
                        // SDK never loaded — allow form submission
                        if (_tsWrap) _tsWrap.innerHTML = '<div style="color:var(--text-tertiary);font-size:var(--text-xs);text-align:center">CAPTCHA unavailable \u2014 you may continue</div>';
                        window._contactTurnstileToken = 'bypass_sdk_unavailable';
                    }
                })();
            }
        });

        async function submitContact() {
            var name = Security.sanitize(document.getElementById('contact-name').value.trim());
            var email = document.getElementById('contact-email').value.trim();
            var subject = document.getElementById('contact-subject').value;
            var message = Security.sanitize(document.getElementById('contact-message').value.trim());

            if (!name) { UI.toast('Please enter your name', 'error'); return; }
            if (!email || !Security.isValidEmail(email)) { UI.toast('Please enter a valid email', 'error'); return; }
            if (!message || message.length < 10) { UI.toast('Please enter a message (at least 10 characters)', 'error'); return; }
            if (CONFIG.turnstileSiteKey && !window._contactTurnstileToken) { UI.toast('Please complete the CAPTCHA verification.', 'error'); return; }

            var btn = document.getElementById('contact-submit');
            btn.disabled = true;
            btn.innerHTML = '<span class="btn-spinner"></span> Sending...';

            /* Server-side validation (rate limit + email + Turnstile) */
            var sv = await Security.serverValidate({ email: email, turnstileToken: window._contactTurnstileToken || null, action: 'contact' });
            if (!sv.ok) { UI.toast(sv.errors?.[0] || 'Validation failed.', 'error'); btn.disabled = false; btn.innerHTML = '&#128232; Send Message'; return; }

            try {
                var { error } = await window.supabaseClient.from('contacts').insert({
                    name: name,
                    email: email,
                    subject: subject,
                    message: message
                });
                if (error) throw error;
                /* Send email notification to site owner (non-blocking) */
                fetch('/api/contact-notify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: name, email: email, subject: subject, message: message })
                }).catch(function() { /* silent — form already saved to DB */ });
                UI.toast('Message sent successfully! We will get back to you soon.', 'success');
                document.getElementById('contact-message').value = '';
            } catch (err) {
                console.error('Contact submit:', err);
                UI.toast('Failed to send message. Please try again.', 'error');
            }
            btn.disabled = false;
            btn.innerHTML = '&#128232; Send Message';
        }
    </script>
</Fragment>
</BaseLayout>
