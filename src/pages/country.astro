---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Browse by Country — GroupsMix"
  description="Browse social media groups by country. Find local communities near you."
>
<style is:inline>
        .browse-hero {
            padding: var(--space-8) 0;
            text-align: center;
        }

        .browse-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-3);
            margin-bottom: var(--space-8);
        }

        .browse-card {
            display: flex;
            align-items: center;
            gap: var(--space-2);
            padding: var(--space-3) var(--space-4);
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-md);
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.2s ease;
            cursor: pointer;
            font-size: var(--text-sm);
        }

        .browse-card:hover {
            border-color: var(--accent-primary);
            transform: translateY(-2px);
            color: var(--text-primary);
        }

        .browse-card--active {
            border-color: var(--accent-primary);
            background: var(--accent-primary-light);
        }

        .browse-search {
            max-width: 400px;
            margin: 0 auto var(--space-6);
        }

        @media (max-width: 767px) {
            .browse-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>


        <div class="container">
            <section class="browse-hero">
                <h1>🌍 Browse by Country</h1>
                <p style="color:var(--text-secondary);margin-top:var(--space-2)">Find local groups near you</p>
            </section>
            <div class="browse-search"><input type="search" class="form-input" id="country-search"
                    placeholder="Search countries..." aria-label="Search countries"></div>
            <div class="browse-grid" id="country-grid"></div>
            <div id="filter-container" style="display:none;margin-bottom:var(--space-6)"></div>
            <div id="results-header" style="display:none;margin-bottom:var(--space-4)">
                <h2 id="results-title" style="font-size:var(--text-xl)"></h2><span id="results-count"
                    style="color:var(--text-secondary);font-size:var(--text-sm)"></span>
            </div>
            <div id="results-container"></div>
            <div id="pagination-container"></div>
        </div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', initPage);
        let currentCountry = '', currentPage = 1;
        let currentFilters = { platform: '', category: '', sort: 'ranking' };

        function initPage() {
            const params = new URLSearchParams(window.location.search);
            currentCountry = params.get('c') || '';
            currentFilters.platform = params.get('platform') || '';
            currentFilters.category = params.get('category') || '';
            currentFilters.sort = params.get('sort') || 'ranking';

            renderGrid();
            document.getElementById('country-search')?.addEventListener('input', filterGrid);
            if (currentCountry) {
                renderFilters();
                loadGroups();
            }
        }

        function renderGrid(filter) {
            const countries = filter ? CONFIG.countries.filter(c => c.name.toLowerCase().includes(filter.toLowerCase())) : CONFIG.countries;
            document.getElementById('country-grid').innerHTML = countries.map(c =>
                '<div class="browse-card' + (currentCountry === c.code ? ' browse-card--active' : '') + '" data-code="' + c.code + '">' + c.flag + ' ' + c.name + '</div>'
            ).join('');
            document.querySelectorAll('.browse-card').forEach(card => {
                card.addEventListener('click', () => {
                    currentCountry = card.dataset.code;
                    currentPage = 1;
                    updateUrl();
                    document.querySelectorAll('.browse-card').forEach(c => c.classList.remove('browse-card--active'));
                    card.classList.add('browse-card--active');
                    renderFilters();
                    loadGroups();
                });
            });
        }

        function filterGrid() { renderGrid(document.getElementById('country-search')?.value || ''); }

        function renderFilters() {
            const fc = document.getElementById('filter-container');
            fc.style.display = 'block';
            fc.innerHTML = UI.searchFilters({ country: currentCountry, ...currentFilters });
            UI.initFilters(onFilterChange);
        }

        function onFilterChange(filters) {
            currentCountry = filters.country || '';
            Object.assign(currentFilters, filters);
            currentPage = 1;
            updateUrl();
            document.querySelectorAll('.browse-card').forEach(c => c.classList.remove('browse-card--active'));
            if (currentCountry) {
                const card = document.querySelector('.browse-card[data-code="' + currentCountry + '"]');
                if (card) card.classList.add('browse-card--active');
            } else {
                document.getElementById('filter-container').style.display = 'none';
                document.getElementById('results-header').style.display = 'none';
                document.getElementById('results-container').innerHTML = '';
                document.getElementById('pagination-container').innerHTML = '';
                return; // if they cleared country
            }
            renderFilters();
            loadGroups();
        }

        function updateUrl() {
            const params = new URLSearchParams();
            if (currentCountry) params.set('c', currentCountry);
            if (currentFilters.platform) params.set('platform', currentFilters.platform);
            if (currentFilters.category) params.set('category', currentFilters.category);
            if (currentFilters.sort && currentFilters.sort !== 'ranking') params.set('sort', currentFilters.sort);
            const qs = params.toString();
            history.replaceState(null, '', window.location.pathname + (qs ? '?' + qs : ''));
        }

        async function loadGroups() {
            const country = CONFIG.countries.find(c => c.code === currentCountry);
            document.getElementById('results-header').style.display = '';
            document.getElementById('results-title').textContent = (country?.flag || '🌍') + ' ' + (country?.name || currentCountry);
            UI.groupGridSkeleton(12, 'results-container');
            const offset = (currentPage - 1) * CONFIG.perPage;
            try {
                const { data, count } = await DB.groups.getByCountry(currentCountry, { ...currentFilters, limit: CONFIG.perPage, offset });
                document.getElementById('results-count').textContent = (count || 0) + ' groups';
                if (!data?.length) { UI.emptyState('results-container', '📭', 'No Groups Yet', 'Be the first to submit a group from this country!', 'Submit Group', '/submit'); return; }
                UI.groupGrid(data, 'results-container');
                const totalPages = Math.ceil((count || 0) / CONFIG.perPage);
                if (totalPages > 1) {
                    document.getElementById('pagination-container').innerHTML = UI.pagination(currentPage, totalPages);
                    UI.initPagination('pagination-container', (p) => { currentPage = p; loadGroups(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
                }
            } catch { UI.errorState('results-container', loadGroups); }
        }
    </script>
</Fragment>
</BaseLayout>
