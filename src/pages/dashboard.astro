---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Dashboard — GroupsMix"
  description="Your GroupsMix dashboard. View your stats, groups, purchases, and referrals."
  noIndex={true}
  cssFiles={["/assets/css/features.css?v=20260310b"]}
  includeFeatures={true}
>
<style is:inline>
        .dashboard {
            max-width: var(--container-lg);
            margin: 0 auto;
            padding: var(--space-8) var(--space-4);
        }

        .profile-card {
            display: flex;
            gap: var(--space-6);
            align-items: center;
            background: var(--bg-card);
            border: 1px solid var(--border-primary);
            border-radius: var(--radius-xl);
            padding: var(--space-6);
            margin-bottom: var(--space-6);
        }

        .profile-card__avatar {
            width: 80px;
            height: 80px;
            border-radius: var(--radius-full);
            background: var(--accent-primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: var(--text-3xl);
            flex-shrink: 0;
        }

        .profile-card__info {
            flex: 1;
        }

        .profile-card__name {
            font-size: var(--text-xl);
            font-weight: var(--font-bold);
        }

        .profile-card__level {
            font-size: var(--text-sm);
            color: var(--text-secondary);
            margin-top: var(--space-1);
        }

        .gxp-bar {
            height: 8px;
            background: var(--bg-tertiary);
            border-radius: var(--radius-full);
            margin-top: var(--space-2);
            overflow: hidden;
        }

        .gxp-bar__fill {
            height: 100%;
            background: var(--accent-primary);
            border-radius: var(--radius-full);
            transition: width 0.8s ease;
        }

        .notif-item {
            display: flex;
            gap: var(--space-3);
            padding: var(--space-3) var(--space-4);
            border-bottom: 1px solid var(--border-primary);
            cursor: pointer;
            transition: background 0.15s ease;
            align-items: flex-start;
        }

        .notif-item:hover {
            background: var(--bg-card-hover);
        }

        .notif-item--unread {
            background: var(--accent-primary-light);
        }

        @media (max-width: 640px) {
            .profile-card {
                flex-direction: column;
                text-align: center;
            }
        }
    </style>


        <div class="dashboard" id="dashboard"></div>
    
<Fragment slot="scripts">
<script is:inline>
        document.addEventListener('DOMContentLoaded', async () => {
            await Auth.waitForAuth();

            if (Auth.isLoggedIn()) {
                initDashboard();
            } else {
                UI.authModal('signin');
            }

            window.supabaseClient.auth.onAuthStateChange((event, session) => {
                if ((event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED') && session) {
                    Auth._session = session;
                    if (!document.getElementById('dashboard').innerHTML.includes('profile-card')) {
                        initDashboard();
                    }
                }
            });
        });

        var _dashRetries = 0;
        var _activeTab = 'overview';

        async function initDashboard() {
            if (!Auth.isLoggedIn()) { UI.authModal('signin'); return; }
            const user = Auth.getUser();
            if (!user) {
                if (++_dashRetries < 20) {
                    setTimeout(initDashboard, 500);
                } else {
                    var errEl = document.getElementById('dashboard');
                    if (errEl) errEl.innerHTML = '<div style="text-align:center;padding:var(--space-12)">' +
                        '<h2>Unable to load profile</h2>' +
                        '<p style="color:var(--text-secondary);margin:var(--space-4) 0">Your profile data could not be loaded. Please try refreshing the page.</p>' +
                        '<button class="btn btn-primary" onclick="location.reload()">Refresh Page</button>' +
                        '</div>';
                }
                return;
            }
            const level = Algorithms.getLevelInfo(user.gxp || 0);
            var dashEl = document.getElementById('dashboard');
            dashEl.innerHTML =
                '<h1 style="margin-bottom:var(--space-6)">&#128202; Dashboard</h1>' +

                // Profile Card
                '<div class="profile-card">' +
                '<div class="profile-card__avatar">' + (user.display_name || 'U').charAt(0).toUpperCase() + '</div>' +
                '<div class="profile-card__info">' +
                '<div class="profile-card__name">' + Security.sanitize(user.display_name || 'User') + '</div>' +
                '<div class="profile-card__level">' + level.emoji + ' Level ' + level.level + ' — ' + level.name + ' · ' + UI.formatNumber(user.gxp || 0) + ' GXP</div>' +
                '<div class="gxp-bar"><div class="gxp-bar__fill" style="width:' + Math.round(level.progress * 100) + '%"></div></div>' +
                '<div style="font-size:var(--text-xs);color:var(--text-tertiary);margin-top:4px">' + (level.progress < 1 ? (UI.formatNumber(level.nextLevelGxp - (user.gxp || 0)) + ' GXP to next level') : 'Max level reached!') + '</div>' +
                '</div>' +
                '<button class="btn btn-secondary btn-sm" id="edit-profile-btn">&#9998; Edit</button>' +
                '</div>' +

                // Quick Stats
                '<div class="grid grid-4" style="margin-bottom:var(--space-6)">' +
                '<a href="/my-groups" class="stat-card" style="text-decoration:none;color:inherit"><div class="stat-card__value" id="my-groups-count">&mdash;</div><div class="stat-card__label">My Groups</div></a>' +
                '<a href="/saved" class="stat-card" style="text-decoration:none;color:inherit"><div class="stat-card__value">&#128278;</div><div class="stat-card__label">My Library</div></a>' +
                '<a href="/wishlist" class="stat-card" style="text-decoration:none;color:inherit"><div class="stat-card__value" id="wishlist-count">&mdash;</div><div class="stat-card__label">Wishlist</div></a>' +
                '<div class="stat-card"><div class="stat-card__value">' + (user.unread_notifications || 0) + '</div><div class="stat-card__label">Notifications</div></div>' +
                '</div>' +

                // Tabs
                '<div class="feature-tabs" id="dash-tabs">' +
                '<button class="feature-tab feature-tab--active" data-tab="overview">Overview</button>' +
                '<button class="feature-tab" data-tab="purchases">Purchases</button>' +
                '<button class="feature-tab" data-tab="referrals">Referrals</button>' +
                '<button class="feature-tab" data-tab="notifications">Notifications</button>' +
                '</div>' +

                // Tab Content Area
                '<div id="tab-content"></div>';

            // Event listeners
            document.getElementById('edit-profile-btn')?.addEventListener('click', openEditProfile);
            document.querySelectorAll('#dash-tabs .feature-tab').forEach(function(tab) {
                tab.addEventListener('click', function() {
                    document.querySelectorAll('#dash-tabs .feature-tab').forEach(function(t) { t.classList.remove('feature-tab--active'); });
                    tab.classList.add('feature-tab--active');
                    _activeTab = tab.dataset.tab;
                    renderTab(_activeTab);
                });
            });

            // Load initial data
            loadMyGroupsCount();
            document.getElementById('wishlist-count').textContent = Wishlist.getCount();
            renderTab('overview');
        }

        function renderTab(tab) {
            var el = document.getElementById('tab-content');
            el.innerHTML = '<div class="skeleton" style="height:200px;border-radius:var(--radius-lg);margin-top:var(--space-4)"></div>';

            switch (tab) {
                case 'overview': renderOverview(); break;
                case 'purchases': renderPurchases(); break;
                case 'referrals': renderReferrals(); break;
                case 'notifications': renderNotifications(); break;
            }
        }

        // ─── Overview Tab ──────────────────────
        async function renderOverview() {
            var el = document.getElementById('tab-content');
            el.innerHTML =
                '<section class="dash-section">' +
                '<div class="dash-section__header"><div class="dash-section__title">' + ICONS.clock + ' Recently Viewed</div></div>' +
                '<div id="recent-list"></div>' +
                '</section>';
            renderRecentlyViewed();
        }

        // ─── Purchases Tab ─────────────────────
        async function renderPurchases() {
            var el = document.getElementById('tab-content');
            el.innerHTML = '<div class="skeleton" style="height:200px;border-radius:var(--radius-lg);margin-top:var(--space-4)"></div>';
            try {
                var purchases = await Purchases.getByUser();
                if (!purchases || !purchases.length) {
                    el.innerHTML =
                        '<div class="feature-empty" style="margin-top:var(--space-5)">' +
                        '<div class="feature-empty__icon">' + ICONS.shopping_bag + '</div>' +
                        '<div class="feature-empty__title">No Purchases Yet</div>' +
                        '<div class="feature-empty__text">Your purchase history will appear here when you buy promoted listings or premium features.</div>' +
                        '<a href="/store" class="btn btn-primary">Visit Store</a>' +
                        '</div>';
                    return;
                }
                el.innerHTML =
                    '<div class="dash-section" style="margin-top:var(--space-4)">' +
                    '<div class="dash-section__header"><div class="dash-section__title">' + ICONS.shopping_bag + ' Purchase History</div></div>' +
                    '<div style="display:flex;flex-direction:column;gap:var(--space-3)">' +
                    purchases.map(function(p) {
                        return '<div class="purchase-card">' +
                            '<div class="purchase-card__icon">' + ICONS.shopping_bag + '</div>' +
                            '<div class="purchase-card__info">' +
                            '<div class="purchase-card__name">' + Security.sanitize(p.product_name || 'Purchase') + '</div>' +
                            '<div class="purchase-card__meta">Order #' + Security.sanitize(p.order_id || '') + ' &middot; ' + UI.formatDate(p.created_at) + '</div>' +
                            '</div>' +
                            '<div class="purchase-card__price">' + Purchases.formatPrice(p.price, p.currency) + '</div>' +
                            '<div class="purchase-card__status">' + Purchases.formatStatus(p.status) + '</div>' +
                            '</div>';
                    }).join('') +
                    '</div></div>';
            } catch (err) {
                el.innerHTML = '<div style="text-align:center;padding:var(--space-6);color:var(--text-secondary)">Unable to load purchases.</div>';
            }
        }

        // ─── Referrals Tab ─────────────────────
        async function renderReferrals() {
            var el = document.getElementById('tab-content');
            el.innerHTML = '<div class="skeleton" style="height:200px;border-radius:var(--radius-lg);margin-top:var(--space-4)"></div>';
            try {
                var refCode = await Referrals.generateCode();
                var stats = await Referrals.getMyStats();

                var refUrl = refCode ? Referrals.getReferralUrl(refCode.code) : '';

                el.innerHTML =
                    // Referral Hero
                    '<div class="referral-hero" style="margin-top:var(--space-4)">' +
                    '<div class="referral-hero__title">Earn Rewards by Sharing</div>' +
                    '<div class="referral-hero__subtitle">Share your unique link. When someone signs up or makes a purchase, you earn commission!</div>' +
                    (refCode ? '<div class="referral-code-box">' +
                    '<span class="referral-code-box__code">' + Security.sanitize(refCode.code) + '</span>' +
                    '<button class="referral-code-box__copy" id="copy-ref-code" data-url="' + Security.sanitize(refUrl) + '">Copy Link</button>' +
                    '</div>' : '<div style="color:rgba(255,255,255,0.7);font-size:var(--text-sm)">Unable to generate referral code</div>') +
                    '</div>' +

                    // Stats
                    '<div class="referral-stats-grid" style="margin-bottom:var(--space-5)">' +
                    refStatCard(stats && stats.total_clicks ? stats.total_clicks : 0, 'Total Clicks') +
                    refStatCard(stats && stats.total_signups ? stats.total_signups : 0, 'Signups') +
                    refStatCard(stats && stats.total_purchases ? stats.total_purchases : 0, 'Purchases') +
                    refStatCard(refCode ? (refCode.commission_rate || 10) + '%' : '10%', 'Commission') +
                    '</div>' +

                    // How It Works
                    '<div class="dash-section">' +
                    '<div class="dash-section__header"><div class="dash-section__title">How It Works</div></div>' +
                    '<div class="steps-grid">' +
                    stepCard('1', 'Share Your Link', 'Copy your unique referral link and share it on social media, messaging apps, or your website.') +
                    stepCard('2', 'Friends Sign Up', 'When someone clicks your link and creates an account, we track the referral.') +
                    stepCard('3', 'Earn Commission', 'When your referrals make purchases, you earn a commission on each sale!') +
                    '</div></div>';

                // Copy button event
                var copyBtn = document.getElementById('copy-ref-code');
                if (copyBtn) {
                    copyBtn.addEventListener('click', function() {
                        var url = this.dataset.url;
                        navigator.clipboard.writeText(url).then(function() {
                            UI.toast('Referral link copied!', 'success');
                        }).catch(function() {
                            // Fallback
                            var t = document.createElement('textarea');
                            t.value = url;
                            document.body.appendChild(t);
                            t.select();
                            document.execCommand('copy');
                            t.remove();
                            UI.toast('Referral link copied!', 'success');
                        });
                    });
                }
            } catch (err) {
                el.innerHTML = '<div style="text-align:center;padding:var(--space-6);color:var(--text-secondary)">Unable to load referral data.</div>';
            }
        }

        function refStatCard(value, label) {
            return '<div class="referral-stat-card"><div class="referral-stat-card__value">' + value + '</div><div class="referral-stat-card__label">' + label + '</div></div>';
        }

        function stepCard(num, title, desc) {
            return '<div class="step-card"><div class="step-card__number">' + num + '</div><div class="step-card__title">' + title + '</div><div class="step-card__desc">' + desc + '</div></div>';
        }

        // ─── Notifications Tab ─────────────────
        async function renderNotifications() {
            var el = document.getElementById('tab-content');
            el.innerHTML =
                '<div class="dash-section" style="margin-top:var(--space-4)">' +
                '<div class="dash-section__header">' +
                '<div class="dash-section__title">' + ICONS.bell + ' Notifications</div>' +
                '<button class="btn btn-ghost btn-sm" id="mark-all-read">Mark All Read</button>' +
                '</div>' +
                '<div id="notifications-list"><div class="skeleton" style="height:200px"></div></div>' +
                '</div>';

            document.getElementById('mark-all-read')?.addEventListener('click', async () => {
                var user = Auth.getUser();
                if (user) {
                    await DB.notifications.markAllRead(user.id);
                    UI.toast('All notifications marked as read', 'success');
                    loadNotifications();
                }
            });
            loadNotifications();
        }

        // ─── Shared Functions ──────────────────
        async function loadMyGroupsCount() {
            try {
                const groups = await DB.groups.getByUser(Auth.getUserId());
                const el = document.getElementById('my-groups-count');
                if (el) el.textContent = groups?.length || 0;
            } catch { }
        }

        async function loadNotifications() {
            const el = document.getElementById('notifications-list');
            if (!el) return;
            try {
                const { data } = await DB.notifications.getByUser(Auth.getUserId(), { limit: 20 });
                if (!data?.length) { el.innerHTML = '<div style="padding:var(--space-6);text-align:center;color:var(--text-tertiary)">No notifications yet</div>'; return; }
                el.innerHTML = data.map(n => {
                    const t = CONFIG.notificationTypes[n.type] || CONFIG.notificationTypes.info;
                    return '<div class="notif-item' + (n.read ? '' : ' notif-item--unread') + '" data-id="' + n.id + '"' + (n.link ? ' data-link="' + Security.sanitize(n.link) + '"' : '') + '>' +
                        '<span style="font-size:var(--text-lg)">' + t.icon + '</span>' +
                        '<div style="flex:1"><div style="font-weight:var(--font-semibold);font-size:var(--text-sm)">' + Security.sanitize(n.title || t.title) + '</div>' +
                        '<div style="font-size:var(--text-sm);color:var(--text-secondary)">' + Security.sanitize(n.message || '') + '</div>' +
                        '<div style="font-size:var(--text-xs);color:var(--text-tertiary);margin-top:2px">' + UI.formatDate(n.created_at) + '</div></div></div>';
                }).join('');
                el.querySelectorAll('.notif-item').forEach(item => {
                    item.addEventListener('click', async () => {
                        await DB.notifications.markRead(item.dataset.id);
                        item.classList.remove('notif-item--unread');
                        if (item.dataset.link && Security.isSafeNavigationUrl(item.dataset.link)) {
                            window.location.href = item.dataset.link;
                        } else if (item.dataset.link) {
                            console.warn('Blocked unsafe notification link:', item.dataset.link);
                        }
                    });
                });
            } catch { el.innerHTML = '<div style="padding:var(--space-4);text-align:center;color:var(--text-tertiary)">Unable to load</div>'; }
        }

        function renderRecentlyViewed() {
            const el = document.getElementById('recent-list');
            if (!el) return;
            const recent = RecentlyViewed.getAll();
            if (!recent.length) { el.innerHTML = '<div style="color:var(--text-tertiary);font-size:var(--text-sm)">No recently viewed groups</div>'; return; }
            el.innerHTML = '<div class="grid grid-4">' + recent.slice(0, 8).map(g =>
                '<a href="/group?id=' + g.id + '" class="card card--clickable"><div class="card__body" style="padding:var(--space-3)">' +
                '<div style="font-weight:var(--font-semibold);font-size:var(--text-sm)">' + Security.sanitize(g.name) + '</div>' +
                '<div style="font-size:var(--text-xs);color:var(--text-tertiary)">' + Security.sanitize(g.platform || '') + '</div>' +
                '</div></a>'
            ).join('') + '</div>';
        }

        function openEditProfile() {
            const user = Auth.getUser();
            UI.modal({
                title: '&#9998; Edit Profile',
                content: '<div class="form-group"><label class="form-label">Display Name</label><input type="text" class="form-input" id="edit-name" value="' + Security.sanitize(user?.display_name || '') + '" maxlength="50"></div>',
                footer: '<button class="btn btn-secondary" id="cancel-profile">Cancel</button><button class="btn btn-primary" id="save-profile">Save</button>',
                size: 'small'
            });
            document.getElementById('cancel-profile')?.addEventListener('click', UI.closeModal);
            document.getElementById('save-profile')?.addEventListener('click', async () => {
                const name = document.getElementById('edit-name')?.value?.trim();
                if (!name || name.length < 2) { UI.toast('Name must be at least 2 characters', 'error'); return; }
                const ok = await DB.user.updateProfile(Auth.getUserId(), { display_name: Security.sanitize(name) });
                if (ok) { UI.toast('Profile updated!', 'success'); UI.closeModal(); CACHE.remove('user_profile'); location.reload(); }
            });
        }
    </script>
</Fragment>
</BaseLayout>
