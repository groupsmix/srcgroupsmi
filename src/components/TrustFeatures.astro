---
/**
 * TrustFeatures — "Why GroupsMix" trust badges row.
 * Re-usable on landing pages, about page, etc.
 */
---

<section class="home-section home-section--why">
    <div class="trust-features">
        <div class="trust-feature">
            <div class="trust-feature__icon"><svg class="svg-icon svg-icon--lg" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
            <div class="trust-feature__info">
                <div class="trust-feature__title">Verified Groups</div>
                <div class="trust-feature__text">Reviewed and scored for safety.</div>
            </div>
        </div>
        <div class="trust-feature">
            <div class="trust-feature__icon"><svg class="svg-icon svg-icon--lg" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
            <div class="trust-feature__info">
                <div class="trust-feature__title">Community Rated</div>
                <div class="trust-feature__text">Real reviews from real users.</div>
            </div>
        </div>
        <div class="trust-feature">
            <div class="trust-feature__icon"><svg class="svg-icon svg-icon--lg" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="8" y1="11" x2="16" y2="11"/></svg></div>
            <div class="trust-feature__info">
                <div class="trust-feature__title">Scam Protected</div>
                <div class="trust-feature__text">Report suspicious groups to our <a href="/scam-wall" style="color:var(--accent-primary);text-decoration:underline">Scam Wall</a>.</div>
            </div>
        </div>
    </div>
</section>
