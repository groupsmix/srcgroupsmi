---
/**
 * Hero — landing page hero with search, platform pills & inline CTAs.
 * Re-usable: pass different titles/subtitles for campaign pages.
 */
interface Props {
  title?: string;
  highlight?: string;
  subtitle?: string;
}

const {
  title = 'Your #1 Directory for',
  highlight = 'Trusted Groups',
  subtitle = 'Discover, join &amp; promote verified communities in a smart, safe ecosystem.',
} = Astro.props;
---

<section class="hero">
    <h1 class="hero__title">{title} <span class="hero__title-highlight">{highlight}</span></h1>
    <p class="hero__subtitle" set:html={subtitle} />
    <form class="hero__search" id="hero-search-form" action="/search" method="get">
        <input type="search" name="q" class="hero__search-input" placeholder="Search groups by name, category, or platform..."
            aria-label="Search groups">
        <button type="submit" class="hero__search-btn" aria-label="Search"><svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
    </form>
    <div class="scroll-container hero-platforms-scroll">
        <button class="scroll-arrow scroll-arrow--left" aria-label="Scroll left">&lsaquo;</button>
        <div class="hero__platforms" id="hero-platforms"></div>
        <button class="scroll-arrow scroll-arrow--right" aria-label="Scroll right">&rsaquo;</button>
    </div>

    <!-- Inline CTAs -->
    <div class="hero__inline-cta">
        <a href="/submit"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Submit Your Group</a>
        <span style="color:var(--text-tertiary)">·</span>
        <a href="/browse">Browse All Groups &rarr;</a>
    </div>
</section>
