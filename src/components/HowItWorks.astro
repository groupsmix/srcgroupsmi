---
/**
 * HowItWorks — three-step onboarding explainer.
 * Re-usable on landing pages, about page, etc.
 */
---

<section class="home-section home-section--alt home-section--howit">
    <div class="home-section__header">
        <h2 class="home-section__title"><span><svg class="svg-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg></span> How It Works</h2>
    </div>
    <div class="how-it-works">
        <div class="how-it-works__step">
            <div class="how-it-works__number">1</div>
            <div class="how-it-works__info">
                <div class="how-it-works__title">Search or Browse</div>
                <div class="how-it-works__text">Find groups by platform, category, or country.</div>
            </div>
        </div>
        <div class="how-it-works__step">
            <div class="how-it-works__number">2</div>
            <div class="how-it-works__info">
                <div class="how-it-works__title trust-explainer" tabindex="0">Check Trust Score
                    <div class="trust-explainer__tip">
                        <strong>How Trust Score Works</strong>
                        Each group gets a score based on multiple factors:
                        <ul class="trust-explainer__list">
                            <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 4 12 14.01 9 11.01"/></svg> Admin verification status</li>
                            <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Community ratings &amp; reviews</li>
                            <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Member count &amp; activity</li>
                            <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> AI moderation checks</li>
                            <li><svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Report history</li>
                        </ul>
                    </div>
                </div>
                <div class="how-it-works__text">See verification, ratings, and feedback.</div>
            </div>
        </div>
        <div class="how-it-works__step">
            <div class="how-it-works__number">3</div>
            <div class="how-it-works__info">
                <div class="how-it-works__title">Join with Confidence</div>
                <div class="how-it-works__text">Reviewed and rated by real members.</div>
            </div>
        </div>
    </div>
</section>
