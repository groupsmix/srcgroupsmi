# Supabase (required)
# Server-side — keep SUPABASE_SERVICE_KEY out of any client/public bundle.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Supabase (public, build-time)
# These are read by scripts/stamp-supabase-config.js at build time so
# different environments can target different Supabase projects without
# editing source. Fall back to SUPABASE_URL / SUPABASE_ANON_KEY if unset.
# PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudflare Turnstile (required — used by auth + abuse-prevention flows)
TURNSTILE_SECRET_KEY=your_turnstile_secret

# AI providers (required — used by article, store, and jobs AI endpoints)
GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=or_your_key_here

# LemonSqueezy (payments)
# LEMONSQUEEZY_WEBHOOK_SECRET is REQUIRED for /api/lemonsqueezy-webhook:
# without it the webhook refuses all requests (fail closed) so attackers
# cannot forge `order_created` events to credit coins.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cron (required for /api/compute-feed — feed scoring, embeddings, cleanup)
# /api/compute-feed refuses to run without this secret matching the
# X-Cron-Secret header.
CRON_SECRET=

# Contact form email (optional)
# If either is unset, submissions are still persisted to the
# contact_submissions table so nothing is dropped.
RESEND_API_KEY=
CONTACT_EMAIL_TO=

# Observability (all optional — see docs/observability.md, docs/alerts.md)
# Scaffolding is inert until DSNs are set, so unsetting these disables
# all Sentry reporting without code changes.
SENTRY_DSN_EDGE=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Exposed to the browser at build time via scripts/stamp-site-config.js.
# Each field is independently optional — leaving a field blank disables
# only its corresponding loader.
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_RELEASE=
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
PUBLIC_ENVIRONMENT=

# Product analytics — Plausible (cookieless, GDPR-friendly). See H-3 in
# docs/observability.md. Unset => no script is loaded client-side.
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_HOST=
PUBLIC_PLAUSIBLE_VARIANT=
