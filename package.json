{
  "name": "groupsmix",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/stamp-sw.js && node scripts/stamp-supabase-config.js && node scripts/stamp-analytics-config.js && node scripts/stamp-head-scripts.js",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutate": "stryker run",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "check": "astro check",
    "worker:dev": "wrangler dev",
    "worker:deploy": "npm run build && node scripts/verify-stamped-config.js && wrangler deploy",
    "worker:tail": "wrangler tail"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.2",
    "astro": "^6.1.8",
    "preact": "^10.29.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/cloudflare": "^2.7.15",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  }
}
