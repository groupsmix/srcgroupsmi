{
  "name": "groupsmix",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/stamp-sw.js && node scripts/stamp-supabase-config.js && node scripts/stamp-analytics-config.js",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "astro check",
    "worker:dev": "wrangler dev",
    "worker:deploy": "npm run build && wrangler deploy",
    "worker:tail": "wrangler tail"
  },
  "dependencies": {
    "astro": "^6.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "^2.4.12",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.0.0"
  }
}
