{
  "name": "groupsmix",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/stamp-sw.js && node scripts/stamp-supabase-config.js && node scripts/stamp-analytics-config.js",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "astro check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,astro,json}": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write"
    ]
  },
  "dependencies": {
    "astro": "^6.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "^2.4.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
