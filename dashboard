    // PAGES
    function showPage(id) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        document.getElementById('page-' + id).classList.add('active');
        
        const titles = {
            overview: '📊 Overview', progress: '✅ Progress Tracker',
            income: '💰 Income Tracker', games: '🎮 Games',
            pod: '🖨️ Print on Demand', freelance: '💼 Freelance',
            apps: '📱 Apps & Sites', bots: '🤖 Bots',
            digital: '📦 Digital Products', platforms: '🌐 Platforms',
            roadmap: '🗺️ Roadmap', notes: '📝 Notes', tasks: '📋 Tasks'
        };
        
        document.getElementById('pageTitle').textContent = titles[id] || id;
        
        const navItems = document.querySelectorAll('.nav-item');
        navItems.forEach(item => {
            if (item.getAttribute('onclick') === `showPage('${id}')`) {
                item.classList.add('active');
            }
        });

        if (id === 'income') renderIncome();
        if (id === 'progress') renderProgress();
        if (id === 'tasks') renderTasks();
        if (id === 'notes') loadNotes();
        if (id === 'overview') updateStats();
        if (id === 'roadmap') loadRoadmap();
    }

    // CHECKBOXES
    function saveCheck(checkbox) {
        const checks = JSON.parse(localStorage.getItem('biz-checks') || '{}');
        checks[checkbox.id] = checkbox.checked;
        localStorage.setItem('biz-checks', JSON.stringify(checks));
        
        const label = checkbox.nextElementSibling;
        if (checkbox.checked) {
            label.classList.add('done');
            showToast('✅ Marked as done!');
        } else {
            label.classList.remove('done');
        }
        updateStats();
        updateProgress();
    }

    function loadChecks() {
        const checks = JSON.parse(localStorage.getItem('biz-checks') || '{}');
        Object.keys(checks).forEach(id => {
            const checkbox = document.getElementById(id);
            if (checkbox && checks[id]) {
                checkbox.checked = true;
                const label = checkbox.nextElementSibling;
                if (label) label.classList.add('done');
            }
        });
        updateProgress();
        updateStats();
    }

    // PROGRESS
    function updateProgress() {
        const categories = {
            games: { prefix: 'g', total: 27 },
            pod: { prefix: 'p', total: 25 },
            freelance: { prefix: 'f', total: 29 },
            apps: { prefix: 'a', total: 25 },
            bots: { prefix: 'b', total: 21 },
            digital: { prefix: 'd', total: 29 }
        };

        const checks = JSON.parse(localStorage.getItem('biz-checks') || '{}');

        Object.keys(categories).forEach(cat => {
            const { prefix, total } = categories[cat];
            let done = 0;
            for (let i = 1; i <= total; i++) {
                if (checks[prefix + i]) done++;
            }
            const pct = Math.round((done / total) * 100);
            const bar = document.getElementById('prog-' + cat);
            const text = document.getElementById('prog-' + cat + '-text');
            if (bar) bar.style.width = pct + '%';
            if (text) text.textContent = pct + '%';
        });
    }

    // STATS
    function updateStats() {
        const totalTasks = tasks.length;
        const doneTasks = tasks.filter(t => t.done).length;
        document.getElementById('stat-tasks').textContent = totalTasks;
        document.getElementById('stat-done').textContent = doneTasks;
        
        const total = Object.values(incomeData).reduce((a, b) => a + (parseFloat(b) || 0), 0);
        document.getElementById('stat-income').textContent = '$' + total.toFixed(0);
    }

    // PROGRESS PAGE
    function renderProgress() {
        const categories = [
            { id: 'games', name: 'Games', icon: '🎮', prefix: 'g', total: 27 },
            { id: 'pod', name: 'Print on Demand', icon: '🖨️', prefix: 'p', total: 25 },
            { id: 'freelance', name: 'Freelance', icon: '💼', prefix: 'f', total: 29 },
            { id: 'apps', name: 'Apps & Sites', icon: '📱', prefix: 'a', total: 25 },
            { id: 'bots', name: 'Bots', icon: '🤖', prefix: 'b', total: 21 },
            { id: 'digital', name: 'Digital Products', icon: '📦', prefix: 'd', total: 29 }
        ];

        const checks = JSON.parse(localStorage.getItem('biz-checks') || '{}');
        const container = document.getElementById('progressCards');
        container.innerHTML = '';

        categories.forEach(cat => {
            let done = 0;
            for (let i = 1; i <= cat.total; i++) {
                if (checks[cat.prefix + i]) done++;
            }
            const pct = Math.round((done / cat.total) * 100);

            container.innerHTML += `
                <div class="category-card">
                    <div class="card-header">
                        <div class="card-title">
                            <span class="icon">${cat.icon}</span>
                            <h3>${cat.name}</h3>
                        </div>
                        <span class="badge">${pct}%</span>
                    </div>
                    <div style="font-size:13px;color:var(--text2);margin-bottom:8px">${done} of ${cat.total} items completed</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width:${pct}%"></div>
                    </div>
                    <div class="progress-text">
                        <span>${done} done</span>
                        <span>${cat.total - done} remaining</span>
                    </div>
                    <div class="card-actions" style="margin-top:12px">
                        <button class="btn btn-primary" onclick="showPage('${cat.id}')">Go to ${cat.name} →</button>
                    </div>
                </div>
            `;
        });
    }

    // INCOME
    function renderIncome() {
        const container = document.getElementById('incomeCards');
        container.innerHTML = '';

        incomeCategories.forEach(cat => {
            const amount = incomeData[cat.id] || 0;
            container.innerHTML += `
                <div class="income-card">
                    <div class="income-header">
                        <div class="income-source">${cat.icon} ${cat.name}</div>
                    </div>
                    <div class="income-amount">$${parseFloat(amount || 0).toFixed(2)}</div>
                    <input type="number" class="income-input" placeholder="Enter monthly income ($)"
                        value="${amount || ''}"
                        oninput="updateIncome('${cat.id}', this.value)">
                </div>
            `;
        });

        calcTotalIncome();
    }

    function updateIncome(id, val) {
        incomeData[id] = parseFloat(val) || 0;
        localStorage.setItem('biz-income', JSON.stringify(incomeData));
        calcTotalIncome();
        updateStats();
    }

    function calcTotalIncome() {
        const total = Object.values(incomeData).reduce((a, b) => a + (parseFloat(b) || 0), 0);
        document.getElementById('totalIncome').textContent = '$' + total.toFixed(2);
    }

    // NOTES
    function saveNote(key, val) {
        notes[key] = val;
        localStorage.setItem('biz-notes', JSON.stringify(notes));
    }

    function loadNotes() {
        Object.keys(notes).forEach(key => {
            const el = document.getElementById('note-' + key);
            if (el) el.value = notes[key];
        });
    }

    // ROADMAP
    function toggleRoadmap(num) {
        roadmapDone[num] = !roadmapDone[num];
        localStorage.setItem('biz-roadmap', JSON.stringify(roadmapDone));
        loadRoadmap();
        showToast(roadmapDone[num] ? '🎉 Step completed!' : '↩️ Step unmarked');
    }

    function loadRoadmap() {
        for (let i = 1; i <= 8; i++) {
            const dot = document.getElementById('rd' + i);
            if (dot) {
                dot.classList.toggle('done', !!roadmapDone[i]);
            }
        }
    }

    // TASKS
    function openModal(id) {
        document.getElementById('modal-' + id).classList.add('open');
    }

    function closeModal(id) {
        document.getElementById('modal-' + id).classList.remove('open');
    }

    function addTask() {
        const name = document.getElementById('taskName').value.trim();
        if (!name) { showToast('⚠️ Enter a task name!'); return; }

        const task = {
            id: Date.now(),
            name: name,
            category: document.getElementById('taskCategory').value,
            priority: document.getElementById('taskPriority').value,
            notes: document.getElementById('taskNotes').value,
            done: false,
            date: new Date().toLocaleDateString()
        };

        tasks.push(task);
        localStorage.setItem('biz-tasks', JSON.stringify(tasks));
        closeModal('addTask');
        document.getElementById('taskName').value = '';
        document.getElementById('taskNotes').value = '';
        renderTasks();
        updateStats();
        showToast('✅ Task added!');
    }

    function toggleTask(id) {
        tasks = tasks.map(t => t.id === id ? { ...t, done: !t.done } : t);
        localStorage.setItem('biz-tasks', JSON.stringify(tasks));
        renderTasks();
        updateStats();
    }

    function deleteTask(id) {
        tasks = tasks.filter(t => t.id !== id);
        localStorage.setItem('biz-tasks', JSON.stringify(tasks));
        renderTasks();
        updateStats();
        showToast('🗑️ Task deleted');
    }

    let taskFilter = 'all';
    function filterTasks(filter) {
        taskFilter = filter;
        renderTasks();
    }

    function clearDoneTasks() {
        tasks = tasks.filter(t => !t.done);
        localStorage.setItem('biz-tasks', JSON.stringify(tasks));
        renderTasks();
        updateStats();
        showToast('🧹 Done tasks cleared!');
    }

    function renderTasks() {
        const container = document.getElementById('tasksList');
        if (!container) return;

        let filtered = tasks;
        if (taskFilter === 'pending') filtered = tasks.filter(t => !t.done);
        if (taskFilter === 'done') filtered = tasks.filter(t => t.done);

        if (filtered.length === 0) {
            container.innerHTML = `<div style="color:var(--text2);font-size:14px;padding:20px">No tasks found. Add your first task! 🎯</div>`;
            return;
        }

        container.innerHTML = filtered.map(task => `
            <div class="category-card" style="opacity:${task.done ? 0.6 : 1}">
                <div class="card-header">
                    <div class="card-title">
                        <span class="icon">${categoryEmojis[task.category] || '📋'}</span>
                        <h3 style="text-decoration:${task.done ? 'line-through' : 'none'}">${task.name}</h3>
                    </div>
                    <div style="width:10px;height:10px;border-radius:50%;background:${priorityColors[task.priority]}"></div>
                </div>
                ${task.notes ? `<p style="font-size:13px;color:var(--text2);margin-bottom:8px">${task.notes}</p>` : ''}
                <div style="font-size:12px;color:var(--text2);margin-bottom:12px">
                    <span class="tag tag-purple">${task.category}</span>
                    <span class="tag tag-blue">${task.priority} priority</span>
                    <span style="margin-left:8px">📅 ${task.date}</span>
                </div>
                <div class="card-actions">
                    <button class="btn btn-primary" onclick="toggleTask(${task.id})">${task.done ? '↩️ Undo' : '✅ Done'}</button>
                    <button class="btn btn-danger" onclick="deleteTask(${task.id})">🗑️ Delete</button>
                </div>
            </div>
        `).join('');
    }

    // TOAST
    function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
    }

    // CLOSE MODAL ON OVERLAY CLICK
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', function(e) {
            if (e.target === this) {
                this.classList.remove('open');
            }
        });
    });

    // INIT
    window.onload = function() {
        loadChecks();
        loadNotes();
        loadRoadmap();
        updateStats();
        renderTasks();
    };
</script>
</body>
</html>
